---
export const prerender = false;

import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getBlogPost } from '../../lib/db';

const { slug } = Astro.params;
const db = Astro.locals.runtime.env.DB;

const post = slug ? await getBlogPost(db, slug) : null;

if (!post || !post.published) {
  return Astro.redirect('/blog');
}
---

<html lang="en">
  <head>
    <BaseHead title={`${post.title} — Force of Nature Press`} description={post.excerpt} />
  </head>
  <body>
    <Header />
    <main>
      <article>
        {post.coverImage && (
          <div class="hero-image">
            <img src={post.coverImage} alt="" />
          </div>
        )}
        <div class="prose">
          <div class="post-header">
            <div class="date">
              {new Date(post.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              {post.updatedAt !== post.createdAt && (
                <span class="last-updated"> · Updated {new Date(post.updatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              )}
            </div>
            <h1>{post.title}</h1>
            <hr />
          </div>
          <div class="post-content" set:html={post.content}></div>
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    padding: 2rem 1rem 5rem;
  }
  .hero-image {
    max-width: 900px;
    margin: 0 auto 2rem;
  }
  .hero-image img {
    width: 100%;
    border-radius: 12px;
    box-shadow: var(--box-shadow);
  }
  .prose {
    max-width: 720px;
    margin: 0 auto;
  }
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
  }
  .date {
    color: var(--brown-mid);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  .last-updated { font-style: italic; }
  .prose h1 { margin-bottom: 0.5rem; }
  .prose hr { margin: 1.5rem 0; border-color: var(--border); }

  .post-content :global(h2) { font-size: 1.4rem; margin: 1.5em 0 0.5em; }
  .post-content :global(h3) { font-size: 1.15rem; margin: 1.2em 0 0.4em; }
  .post-content :global(p) { margin: 0 0 1em; line-height: 1.7; }
  .post-content :global(blockquote) {
    border-left: 4px solid var(--orange);
    margin: 1em 0;
    padding: 0.5em 1.2em;
    background: rgba(200, 120, 48, 0.06);
    color: var(--brown-mid);
    font-style: italic;
  }
  .post-content :global(a) { color: var(--green-dark); }
  .post-content :global(img) { max-width: 100%; border-radius: 8px; margin: 1em 0; }
  .post-content :global(ul), .post-content :global(ol) { margin: 0.5em 0; padding-left: 1.5em; }
  .post-content :global(li) { margin-bottom: 0.3em; }
</style>
