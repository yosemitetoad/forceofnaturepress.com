---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { getPageContentMulti } from '../lib/db';
import { mdInline, md } from '../lib/markdown';

const db = Astro.locals.runtime?.env?.DB;
const content = db ? await getPageContentMulti(db, ['not_found_subtitle', 'not_found_message']) : {};
const subtitle = await mdInline(content['not_found_subtitle'] || "Looks like this page got lost in the woods.");
const message = await md(content['not_found_message'] || "The page you're looking for doesn't exist or may have been moved.");
---

<Base title="Page Not Found — Force of Nature Press" fullWidth>
  <div class="not-found">
    <div class="not-found-content">
      <h1>404</h1>
      <p class="subtitle" set:html={subtitle} />
      <div class="message" set:html={message} />
      <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
  </div>
</Base>

<style>
  .not-found {
    background: url('/plainstarbanner.webp') center / cover no-repeat;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    margin: 0;
  }
  :global(main) {
    padding: 0 !important;
  }
  :global(footer) {
    margin-top: 0 !important;
  }

  .not-found-content {
    background: rgba(240, 230, 208, 0.88);
    border: 2px solid var(--border);
    border-radius: 12px;
    padding: 4rem 5rem;
    text-align: center;
    max-width: 620px;
    width: 100%;
  }

  h1 {
    font-size: 5rem;
    color: var(--orange);
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .subtitle {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--brown);
    margin: 0 0 1rem;
  }

  .message {
    font-size: 1.05rem;
    color: var(--brown-mid);
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }
  .message p { margin: 0 0 0.8em; }
  .message p:last-child { margin: 0; }
  .message a { color: var(--teal); }
  .message a:hover { color: var(--teal-dark); }
  .subtitle a { color: var(--teal); }
  .subtitle a:hover { color: var(--teal-dark); }

  .btn {
    display: inline-block;
    padding: 0.6em 1.5em;
    border-radius: 8px;
    font-family: inherit;
    font-weight: 800;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-primary {
    background: var(--orange);
    color: var(--cream-light);
    border: 2px solid var(--orange);
  }
  .btn-primary:hover { background: var(--orange-dark); border-color: var(--orange-dark); }

  @media (max-width: 600px) {
    .not-found-content { padding: 2rem 1.5rem; }
    h1 { font-size: 3rem; }
  }
</style>
