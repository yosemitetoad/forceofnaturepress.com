---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { getPageContentMulti, getAllGameCards } from '../../lib/db';
import type { GameCard } from '../../lib/db';
import { mdInline } from '../../lib/markdown';

let gamesHeader = 'Games';
let gamesSubheader = 'Interactive projects and browser games — click to play right here in your browser.';
let gameCards: GameCard[] = [];

try {
  const db = Astro.locals.runtime.env.DB;
  if (db) {
    const content = await getPageContentMulti(db, ['games_header', 'games_subheader']);
    if (content.games_header) gamesHeader = content.games_header;
    if (content.games_subheader) gamesSubheader = content.games_subheader;
    gameCards = await getAllGameCards(db);
  }
} catch (e) {
  console.warn('[games] D1 unavailable:', e);
}

const gameCardsHtml = await Promise.all(gameCards.map(async card => ({
  ...card,
  descriptionHtml: await mdInline(card.description),
})));
---

<Base title="Games — Force of Nature Press" description="Play Dress Up Beetle! and other interactive projects by Force of Nature Press." fullWidth>

  <div class="games-header">
    <div class="container">
      <h1>{gamesHeader}</h1>
      <p>{gamesSubheader}</p>
    </div>
  </div>

  <div class="container games-body">
    <div class="games-grid">

      {gameCardsHtml.map(card => (
        <div class={`game-card ${card.status === 'in_development' ? 'game-card--in-dev' : ''}`}>
          <div class="game-preview-col">
            <div class="game-preview">
              <img src={card.image} alt={`${card.title} preview`} class="game-thumb" />
            </div>
            {card.status === 'in_development' ? (
              <span class="btn btn-in-dev">In Development</span>
            ) : (
              <button class="btn btn-primary game-play-btn" data-game={card.link} data-title={card.title}>
                Play Now
              </button>
            )}
          </div>
          <div class="game-info">
            <h2>{card.title}</h2>
            <p class="game-meta">{card.category}</p>
            <p><Fragment set:html={card.descriptionHtml} /></p>
          </div>
        </div>
      ))}

    </div>
  </div>

  <!-- Game Overlay / Modal -->
  <div class="game-overlay" id="gameOverlay" aria-hidden="true">
    <div class="overlay-bar">
      <span class="overlay-title" id="overlayTitle">Dress Up Beetle!</span>
      <button class="overlay-close" id="overlayClose" aria-label="Close game">← Back to forceofnaturepress.com</button>
    </div>
    <iframe id="gameFrame" src="" title="Game" allow="fullscreen"></iframe>
  </div>

</Base>

<script data-astro-rerun>
  const overlay = document.getElementById('gameOverlay')!;
  const frame = document.getElementById('gameFrame') as HTMLIFrameElement;
  const closeBtn = document.getElementById('overlayClose')!;

  const overlayTitle = document.getElementById('overlayTitle')!;

  document.querySelectorAll<HTMLButtonElement>('.game-play-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.game ?? '';
      frame.src = src;
      overlayTitle.textContent = btn.dataset.title ?? '';
      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      const a11y = document.getElementById('a11yWidget');
      const a11yRestore = document.getElementById('a11yRestore');
      if (a11y) a11y.style.display = 'none';
      if (a11yRestore) a11yRestore.style.display = 'none';
    });
  });

  function closeOverlay() {
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    frame.src = '';
    document.body.style.overflow = '';
    const a11y = document.getElementById('a11yWidget');
    const a11yRestore = document.getElementById('a11yRestore');
    if (a11y) a11y.style.display = '';
    if (a11yRestore) a11yRestore.style.display = '';
  }

  closeBtn.addEventListener('click', closeOverlay);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeOverlay();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeOverlay();
  });
</script>

<style>
  .games-header {
    background: url('/plainstarbanner.webp') center / cover no-repeat;
    border-bottom: 2px solid var(--border);
    padding: 2.5rem 0 1.5rem;
    position: relative;
  }
  .games-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(250, 245, 234, 0.75);
  }
  .games-header .container { position: relative; }
  .games-header h1 { margin-bottom: 0.3em; }
  .games-header p { color: var(--brown-mid); margin: 0; }

  .games-body { padding-top: 2.5rem; padding-bottom: 5rem; }

  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(480px, 1fr));
    gap: 2rem;
  }

  .game-card {
    display: flex;
    gap: 1.5rem;
    background: var(--cream-light);
    border: 2px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    align-items: flex-start;
  }

  .game-preview-col {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .game-preview {
    width: 140px;
    height: 185px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid var(--border);
    background: var(--cream-dark);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .game-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
  }
  .game-info { flex: 1; }
  .game-info h2 { font-size: 1.5rem; margin-bottom: 0.2em; }
  .game-meta { color: var(--brown-mid); font-size: 0.85rem; margin-bottom: 0.8rem; font-style: italic; }
  .game-info p { font-size: 0.95rem; line-height: 1.6; margin-bottom: 1rem; }

  .game-card--in-dev { opacity: 0.85; }
  .btn-in-dev {
    display: inline-block;
    background: var(--brown-mid);
    color: var(--cream-light);
    font-family: inherit;
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.45em 1.1em;
    border-radius: 8px;
    text-align: center;
    letter-spacing: 0.02em;
  }

  /* OVERLAY */
  .game-overlay {
    position: fixed;
    inset: 0;
    background: var(--brown);
    z-index: 1000;
    display: none;
    flex-direction: column;
  }
  .game-overlay.open { display: flex; }

  .overlay-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.3rem 1rem;
    background: var(--brown);
    border-bottom: 2px solid rgba(228, 211, 184, 0.2);
    flex-shrink: 0;
  }
  .overlay-title {
    color: var(--cream-light);
    font-weight: 800;
    font-size: 1rem;
  }
  .overlay-close {
    background: rgba(228, 211, 184, 0.15);
    border: 1px solid rgba(228, 211, 184, 0.3);
    color: var(--cream-light);
    font-family: inherit;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.4em 0.9em;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s;
  }
  .overlay-close:hover { background: rgba(228, 211, 184, 0.25); }

  #gameFrame {
    flex: 1;
    border: none;
    width: 100%;
    background: var(--cream);
  }

  @media (max-width: 600px) {
    .games-grid { grid-template-columns: 1fr; }
    .game-card { flex-direction: column; }
    .game-preview { width: 100%; height: auto; }
    .game-thumb { object-fit: contain; height: auto; }
  }
</style>
