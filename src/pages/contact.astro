---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { ETSY_SHOP_URL, INSTAGRAM_URL, PINTEREST_URL, EMAIL } from '../consts';
import { getPageContentMulti } from '../lib/db';
import { mdInline } from '../lib/markdown';

let contactHeader = 'Get in Touch';
let contactSubheader = 'Questions about an order, a wholesale inquiry, or just want to say hi? Here\'s where to find me.';
let cardDescriptions: Record<string, string> = {};
let cardHtml: Record<string, string> = {};

try {
  const db = Astro.locals.runtime.env.DB;
  if (db) {
    const content = await getPageContentMulti(db, ['contact_header', 'contact_subheader', 'contact_cards']);
    if (content.contact_header) contactHeader = content.contact_header;
    if (content.contact_subheader) contactSubheader = content.contact_subheader;
    if (content.contact_cards) {
      try {
        const cards: { key: string; description: string }[] = JSON.parse(content.contact_cards);
        for (const c of cards) cardDescriptions[c.key] = c.description;
      } catch {}
    }
  }
} catch (e) {
  console.warn('[contact] D1 unavailable:', e);
}

for (const [key, val] of Object.entries(cardDescriptions)) {
  cardHtml[key] = await mdInline(val);
}
---

<Base title="Contact — Force of Nature Press" description="Get in touch with Force of Nature Press — find us on Etsy, Instagram, Pinterest, or send an email." fullWidth>

  <div class="contact-wrap">
    <div class="container contact-body">
      <div class="contact-layout">

      <!-- Left: social/email links -->
      <div class="contact-cards">
        <a href={`mailto:${EMAIL}`} class="contact-card">
          <div class="contact-icon email-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </div>
          <div class="contact-info">
            <h2>Email</h2>
            <p><Fragment set:html={cardHtml.email ?? 'For wholesale inquiries, freelance opportunities, collabs, projects, or anything else.'} /></p>
            <span class="contact-handle">{EMAIL}</span>
          </div>
          <span class="contact-arrow">→</span>
        </a>

        <a href="/newsletter" class="contact-card">
          <div class="contact-icon newsletter-icon">
            <img src="/newslettericon.webp" alt="" class="newsletter-logo-img" />
          </div>
          <div class="contact-info">
            <h2>Newsletter</h2>
            <p><Fragment set:html={cardHtml.newsletter ?? 'Sign up for Field Notes from Force of Nature Press and get a free digital field guide + updates on new art, shop drops, and more.'} /></p>
            <span class="contact-handle">Field Notes from Force of Nature Press</span>
          </div>
          <span class="contact-arrow">&rarr;</span>
        </a>

        <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" class="contact-card">
          <div class="contact-icon instagram-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
          <div class="contact-info">
            <h2>Instagram</h2>
            <p><Fragment set:html={cardHtml.instagram ?? 'Behind-the-scenes, new releases, and nature photography.'} /></p>
            <span class="contact-handle">@forceofnature.press</span>
          </div>
          <span class="contact-arrow">→</span>
        </a>

        <a href={PINTEREST_URL} target="_blank" rel="noopener noreferrer" class="contact-card">
          <div class="contact-icon pinterest-icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
            </svg>
          </div>
          <div class="contact-info">
            <h2>Pinterest</h2>
            <p><Fragment set:html={cardHtml.pinterest ?? 'Nature inspiration boards and artwork collections.'} /></p>
            <span class="contact-handle">pinterest.com/forceofnaturepress</span>
          </div>
          <span class="contact-arrow">→</span>
        </a>

        <a href={ETSY_SHOP_URL} target="_blank" rel="noopener noreferrer" class="contact-card">
          <div class="contact-icon etsy-icon">
            <img src="/etsylogo.webp" alt="" class="etsy-logo-img" />
          </div>
          <div class="contact-info">
            <h2>Etsy</h2>
            <p><Fragment set:html={cardHtml.etsy ?? 'For questions regarding Etsy orders, please message me on Etsy instead of emailing or filling out the contact form!'} /></p>
            <span class="contact-handle">forceofnaturepress.etsy.com</span>
          </div>
          <span class="contact-arrow">→</span>
        </a>
      </div>

      <!-- Right: contact form -->
      <form
        class="contact-form"
        action="https://formspree.io/f/xaqpwzvz"
        method="POST"
        id="contactForm"
      >
        <h2 class="form-title">Send a Message</h2>
        <div class="form-row">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="form-row">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-row">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" required />
        </div>
        <div class="form-row">
          <label for="message">Message</label>
          <textarea id="message" name="message" required rows="6"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send Message</button>
        <p class="form-success" id="formSuccess">Message sent! I'll get back to you soon.</p>
      </form>

    </div>
  </div>
  </div>

</Base>

<script>
function initContact() {
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const success = document.getElementById('formSuccess');
  if (!form || !success) return;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch(form.action, {
      method: 'POST',
      body: data,
      headers: { Accept: 'application/json' },
    });
    if (res.ok) {
      form.reset();
      success.classList.add('visible');
      setTimeout(() => success.classList.add('fading'), 6000);
      setTimeout(() => { success.classList.remove('visible', 'fading'); }, 8000);
    }
  });
}
initContact();
document.addEventListener('astro:after-swap', initContact);
</script>

<style>
  .contact-wrap {
    background: url('/plainstarbanner.webp') center / cover no-repeat;
    min-height: calc(100vh - 72px - 120px);
    padding: 1.5rem 0 2rem;
    margin-bottom: -4rem;
  }

  .contact-body { padding-top: 0; padding-bottom: 0; }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: stretch;
  }

  /* Cards */
  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-card { flex: 1; }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: rgba(240, 230, 208, 0.88);
    border: 2px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--brown);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .contact-card:hover {
    border-color: var(--orange);
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
    color: var(--brown);
  }

  .contact-icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .contact-icon svg { width: 24px; height: 24px; }

  .etsy-icon      { background: #f0d9be; padding: 8px; }
  .etsy-logo-img  { width: 100%; height: 100%; object-fit: contain; display: block; border-radius: 0; }
  .instagram-icon { background: #eed4c6; color: #e1306c; }
  .pinterest-icon { background: #efcfbf; color: #e60023; }
  .email-icon     { background: #ebd9bd; color: var(--orange); }
  .newsletter-icon { background: #d9e6df; padding: 8px; }
  .newsletter-logo-img { width: 100%; height: 100%; object-fit: contain; display: block; border-radius: 0; }

  .contact-info { flex: 1; min-width: 0; }
  .contact-info h2 { font-size: 1rem; margin: 0 0 0.15em 0; }
  .contact-info p { font-size: 0.82rem; color: var(--brown-mid); margin: 0 0 0.25em 0; line-height: 1.4; }

  .contact-handle {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--teal);
  }

  .contact-arrow {
    font-size: 1.2rem;
    color: var(--border);
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }
  .contact-card:hover .contact-arrow {
    color: var(--orange);
    transform: translateX(3px);
  }

  /* Form */
  .contact-form {
    background: rgba(240, 230, 208, 0.88);
    border: 2px solid var(--border);
    border-radius: 14px;
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .form-title {
    font-size: 1.4rem;
    margin: 0 0 0.3rem;
    color: var(--brown);
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  label {
    font-weight: 700;
    font-size: 0.88rem;
    color: var(--brown);
  }

  input, textarea {
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--brown);
    background: var(--cream-light);
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 0.55em 0.8em;
    transition: border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }
  input:focus, textarea:focus {
    outline: none;
    border-color: var(--orange);
  }
  textarea { resize: vertical; }

  .form-success {
    display: none;
    color: var(--teal-dark);
    font-weight: 700;
    font-size: 0.95rem;
    margin: 0;
    transition: opacity 2s ease;
  }
  .form-success.visible { display: block; opacity: 1; }
  .form-success.fading { opacity: 0; }

  @media (max-width: 800px) {
    .contact-layout { grid-template-columns: 1fr; }
    .contact-arrow { display: none; }
  }
</style>
