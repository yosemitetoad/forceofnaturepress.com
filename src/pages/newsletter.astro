---
import Base from '../layouts/Base.astro';
---

<Base title="Newsletter — Force of Nature Press" description="Sign up for Field Notes from Force of Nature Press and get a free digital field guide.">

  <div class="newsletter-wrap">
    <div class="container newsletter-body">
      <div class="newsletter-layout">

        <div class="newsletter-intro">
          <h1>Field Notes from Force of Nature Press</h1>
          <p>Sign up to receive a free digital field guide + periodical updates in your inbox, including new art, shop drops, market dates, site updates, and more.</p>
        </div>

        <div class="newsletter-form-wrap">
          <!-- MailerLite Embedded Form -->
          <div id="mlb2-38936232" class="ml-form-embedContainer ml-subscribe-form ml-subscribe-form-38936232">
            <div class="ml-form-align-center">
              <div class="ml-form-embedWrapper embedForm">
                <div class="ml-form-embedBody ml-form-embedBodyDefault row-form">
                  <div class="ml-form-embedContent" style="">
                    <h4>Get Field Notes from Force of Nature Press</h4>
                    <p>Sign up to receive&nbsp;a free digital field guide + periodical&nbsp;updates on Force of Nature Press in your inbox, including new art, shop drops, market dates,&nbsp;site updates, and more!</p>
                  </div>
                  <form class="ml-block-form" action="https://assets.mailerlite.com/jsonp/2216294/forms/182854136374494712/subscribe" data-code="" method="post" target="_blank">
                    <div class="ml-form-formContent">
                      <div class="ml-form-fieldRow ml-last-item">
                        <div class="ml-field-group ml-field-email ml-validate-email ml-validate-required">
                          <input aria-label="email" aria-required="true" type="email" class="form-control" data-inputmask="" name="fields[email]" placeholder="Email" autocomplete="email">
                        </div>
                      </div>
                    </div>
                    <div class="ml-form-embedPermissions" style="">
                      <div class="ml-form-embedPermissionsContent default privacy-policy">
                        <p>You can unsubscribe anytime. For more details, review our Privacy Policy.</p>
                      </div>
                    </div>
                    <div class="ml-form-recaptcha ml-validate-required" style="float: left;">
                      <script src="https://www.google.com/recaptcha/api.js"></script>
                      <div class="g-recaptcha" data-sitekey="6Lf1KHQUAAAAAFNKEX1hdSWCS3mRMv4FlFaNslaD"></div>
                    </div>
                    <input type="hidden" name="ml-submit" value="1">
                    <div class="ml-form-embedSubmit">
                      <button type="submit" class="primary">Count Me In!</button>
                      <button disabled="disabled" style="display: none;" type="button" class="loading">
                        <div class="ml-form-embedSubmitLoad"></div>
                        <span class="sr-only">Loading...</span>
                      </button>
                    </div>
                    <input type="hidden" name="anticsrf" value="true">
                  </form>
                </div>
                <div class="ml-form-successBody row-success" style="display: none">
                  <div class="ml-form-successContent">
                    <h4>Welcome to the Crew!</h4>
                    <p>Check your inbox for your free download. We'll be in touch with new art drops, market dates, and shop news!</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- /MailerLite Embedded Form -->
        </div>

      </div>
    </div>
  </div>

</Base>

<script>
  function ml_webform_success_38936232() {
    var $ = ml_jQuery || jQuery;
    $('.ml-subscribe-form-38936232 .row-success').show();
    $('.ml-subscribe-form-38936232 .row-form').hide();
  }
</script>
<script src="https://groot.mailerlite.com/js/w/webforms.min.js?v95037e5bac78f29ed026832ca21a7c7b" type="text/javascript"></script>
<script>
  fetch("https://assets.mailerlite.com/jsonp/2216294/forms/182854136374494712/takel")
</script>

<style>
  /* MailerLite overrides to match site */
  @import url("https://assets.mlcdn.com/fonts.css?version=1774528");

  .newsletter-wrap {
    background: url('/plainstarbanner.webp') center / cover no-repeat;
    min-height: calc(100vh - 72px - 120px);
    padding: 3rem 0;
    margin-bottom: -4rem;
    display: flex;
    align-items: center;
  }

  .newsletter-body {
    max-width: 600px;
    margin: 0 auto;
  }

  .newsletter-layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .newsletter-intro {
    text-align: center;
  }

  .newsletter-intro h1 {
    font-size: 1.8rem;
    color: var(--brown);
    margin: 0 0 0.6rem;
  }

  .newsletter-intro p {
    color: var(--brown-mid);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .newsletter-form-wrap {
    background: rgba(240, 230, 208, 0.92);
    border: 2px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
  }

  /* MailerLite form style overrides */
  #mlb2-38936232.ml-form-embedContainer {
    width: 100% !important;
  }

  #mlb2-38936232 .ml-form-embedWrapper {
    background-color: transparent !important;
    border: none !important;
    box-shadow: none !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  #mlb2-38936232 .ml-form-embedBody {
    padding: 0 !important;
  }

  #mlb2-38936232 .ml-form-embedContent h4 {
    font-family: var(--font-heading, 'Roboto Slab', serif) !important;
    color: var(--brown) !important;
    font-size: 1.3rem !important;
  }

  #mlb2-38936232 .ml-form-embedContent p {
    color: var(--brown-mid) !important;
    font-family: inherit !important;
    font-size: 0.9rem !important;
    line-height: 1.5 !important;
  }

  #mlb2-38936232 .ml-form-fieldRow input {
    font-family: inherit !important;
    border: 2px solid var(--border) !important;
    border-radius: 8px !important;
    background: var(--cream-light) !important;
    color: var(--brown) !important;
    padding: 0.6em 0.8em !important;
  }

  #mlb2-38936232 .ml-form-fieldRow input:focus {
    border-color: var(--orange) !important;
    outline: none !important;
  }

  #mlb2-38936232 .ml-form-embedSubmit button.primary {
    background-color: var(--orange, #c87830) !important;
    border: none !important;
    border-radius: 8px !important;
    font-family: var(--font-heading, 'Roboto Slab', serif) !important;
    font-size: 1rem !important;
    font-weight: 700 !important;
    padding: 0.65em 1.2em !important;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  #mlb2-38936232 .ml-form-embedSubmit button.primary:hover {
    background-color: var(--orange-dark, #8b5520) !important;
  }

  #mlb2-38936232 .ml-form-embedPermissions p {
    font-size: 0.78rem !important;
    color: var(--brown-mid) !important;
  }

  #mlb2-38936232 .ml-form-successContent h4 {
    font-family: var(--font-heading, 'Roboto Slab', serif) !important;
    color: var(--brown) !important;
  }

  #mlb2-38936232 .ml-form-successContent p {
    color: var(--brown-mid) !important;
    font-family: inherit !important;
  }

  /* Loader */
  .ml-form-embedSubmitLoad {
    display: inline-block;
    width: 20px;
    height: 20px;
  }
  .ml-form-embedSubmitLoad:after {
    content: " ";
    display: block;
    width: 11px;
    height: 11px;
    margin: 1px;
    border-radius: 50%;
    border: 4px solid #fff;
    border-color: #ffffff #ffffff #ffffff transparent;
    animation: ml-form-embedSubmitLoad 1.2s linear infinite;
  }
  @keyframes ml-form-embedSubmitLoad {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }

  .g-recaptcha {
    margin-bottom: 20px;
  }

  @media (max-width: 480px) {
    .g-recaptcha {
      transform: scale(0.78);
      -webkit-transform: scale(0.78);
      transform-origin: 0 0;
    }
  }

  @media (max-width: 600px) {
    .newsletter-intro h1 { font-size: 1.4rem; }
    .newsletter-form-wrap { padding: 1rem; }
  }
</style>
