  .review-confirm-btn { padding: 0.6em 1.4em; border: none; border-radius: 8px; background: #c87830; color: #faf5ea; font-family: inherit; font-weight: 700; font-size: 0.9rem; cursor: pointer; }
  .review-confirm-btn:hover { background: #a05e18; }
  .review-confirm-btn:disabled { opacity: 0.6; cursor: not-allowed; }
