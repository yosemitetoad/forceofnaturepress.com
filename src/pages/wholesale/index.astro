  .review-util-btn { padding: 0.5em 1em; border: 2px solid #d4b896; border-radius: 8px; background: transparent; color: #6b4a2a; font-family: inherit; font-weight: 700; font-size: 0.82rem; cursor: pointer; white-space: nowrap; }
  .review-util-btn:hover { background: #e4d3b8; }
</style>

<script>
  const modal = document.getElementById('modal') as HTMLElement;
  const modalClose = document.getElementById('modalClose');
  const modalImg = document.getElementById('modalImg') as HTMLImageElement;
  const modalTitle = document.getElementById('modalTitle')!;
  const modalDescription = document.getElementById('modalDescription')!;
  const modalWholesalePrice = document.getElementById('modalWholesalePrice')!;
  const modalRrp = document.getElementById('modalRrp')!;
  const modalMoq = document.getElementById('modalMoq')!;

  // ── Catalog filter tabs ────────────────────────────────────────────────────
  const catalogTabs = document.querySelectorAll<HTMLButtonElement>('.catalog-tab');
  const catalogCategories = document.querySelectorAll<HTMLElement>('.catalog-category');
  catalogTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      catalogTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      tab.classList.add('active'); tab.setAttribute('aria-selected', 'true');
      const selected = tab.dataset.tab!;
      catalogCategories.forEach(cat => {
        const matches = selected === 'all' || cat.dataset.group === selected;
        cat.style.display = matches ? '' : 'none';
      });
    });
  });

  // Order form
  const orderForm = document.getElementById('orderForm') as HTMLFormElement | null;
  if (orderForm) {
    const orderSubmitBtn = document.getElementById('orderSubmitBtn') as HTMLButtonElement;
    const orderFormStatus = document.getElementById('orderFormStatus')!;
    const sameAsShipping = document.getElementById('sameAsShipping') as HTMLInputElement;
    const billingFields = document.getElementById('billingFields')!;
    const websiteInput = document.getElementById('website') as HTMLInputElement;
    const socialInput = document.getElementById('social') as HTMLInputElement;
    const businessAddrInput = document.getElementById('business_address') as HTMLInputElement;
    const presenceError = document.getElementById('presence-error');

    sameAsShipping?.addEventListener('change', () => {
      billingFields.style.display = sameAsShipping.checked ? 'none' : '';
    });

    // ── Order product grid ────────────────────────────────────────────────────
    const orderCatSelect = document.getElementById('orderCategorySelect') as HTMLSelectElement;
    const orderTotalRow = document.getElementById('orderTotalRow') as HTMLElement;
    const orderTotalValue = document.getElementById('orderTotalValue')!;
    const orderItemsError = document.getElementById('order-items-error');
    const productsHidden = document.getElementById('productsHidden') as HTMLInputElement;

    orderCatSelect?.addEventListener('change', () => {
      document.querySelectorAll<HTMLElement>('.order-product-grid').forEach(grid => {
        grid.style.display = grid.dataset.cat !== orderCatSelect.value ? 'none' : '';
      });
    });

    function updateOrderTotal() {
      let total = 0; let hasItems = false;
      document.querySelectorAll<HTMLInputElement>('.qty-input').forEach(input => {
        const qty = parseInt(input.value) || 0;
        input.classList.toggle('has-qty', qty > 0);
        if (qty > 0) { total += qty * parseFloat(input.dataset.ws || '0'); hasItems = true; }
      });
      if (orderTotalRow) orderTotalRow.hidden = !hasItems;
      if (orderTotalValue) orderTotalValue.textContent = `$${total.toFixed(2)}`;
    }
    document.querySelectorAll<HTMLInputElement>('.qty-input').forEach(input => {
      let lastQty = 0;
      input.addEventListener('focus', () => { lastQty = parseInt(input.value) || 0; });
      input.addEventListener('input', updateOrderTotal);
      input.addEventListener('change', () => {
        const qty = parseInt(input.value) || 0;
        const moq = parseInt(input.dataset.moq || '1');
        if (qty < 0) {
          input.value = '0';
        } else if (qty > 0 && qty < moq) {
          // Going up from 0: snap to MOQ. Lowering below MOQ: snap to 0.
          input.value = lastQty === 0 ? String(moq) : '0';
        }
        lastQty = parseInt(input.value) || 0;
        updateOrderTotal();
      });
    });

    const businessTypeSelect = document.getElementById('business_type') as HTMLSelectElement;
    const businessTypeOtherWrap = document.getElementById('businessTypeOtherWrap');
    const businessTypeOtherInput = document.getElementById('business_type_other') as HTMLInputElement;
    businessTypeSelect?.addEventListener('change', () => {
      const isOther = businessTypeSelect.value === 'other';
      businessTypeOtherWrap?.toggleAttribute('hidden', !isOther);
      if (businessTypeOtherInput) {
        businessTypeOtherInput.disabled = !isOther;
        businessTypeOtherInput.required = isOther;
      }
    });

    // ── Order review modal ────────────────────────────────────────────────────
    const reviewModal = document.getElementById('reviewModal') as HTMLElement;
    const reviewModalBody = document.getElementById('reviewModalBody')!;
    const reviewEditBtn = document.getElementById('reviewEditBtn') as HTMLButtonElement;
    const reviewConfirmBtn = document.getElementById('reviewConfirmBtn') as HTMLButtonElement;
    const reviewSubmitStatus = document.getElementById('reviewSubmitStatus')!;
    const viewOrderBtn = document.getElementById('viewOrderBtn') as HTMLButtonElement;

    function closeReviewModal() {
      reviewModal.setAttribute('hidden', '');
      document.body.style.overflow = '';
    }

    reviewEditBtn?.addEventListener('click', closeReviewModal);
    document.getElementById('reviewModalClose')?.addEventListener('click', closeReviewModal);
    document.getElementById('reviewModalBackdrop')?.addEventListener('click', closeReviewModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !reviewModal.hasAttribute('hidden')) closeReviewModal();
    });

    function collectFormSummary() {
      const sections: { heading: string; rows: { label: string; value: string; isCheck?: boolean }[] }[] = [];
      const seen = new Set<string>();
      document.querySelectorAll<HTMLElement>('.order-section').forEach(section => {
        const heading = section.querySelector('.order-section-heading')?.textContent?.trim() ?? '';
        const rows: { label: string; value: string; isCheck?: boolean }[] = [];
        section.querySelectorAll<HTMLElement>('[name]:not([name="products"])').forEach(el => {
          if (el instanceof HTMLInputElement && el.type === 'hidden') return;
          if (el instanceof HTMLInputElement && el.classList.contains('qty-input')) return;
          const name = el.getAttribute('name') ?? '';
          if (!name || seen.has(name)) return;
          // Group shipping address
          if (name === 'shipping_address') {
            const block = el.closest('.address-block');
            if (block) {
              const vals = [...block.querySelectorAll<HTMLInputElement>('input:not([type="checkbox"])')].map(i => i.value.trim()).filter(Boolean);
              if (vals.length) rows.push({ label: 'Shipping Address', value: vals.join(', ') });
              block.querySelectorAll<HTMLInputElement>('input').forEach(i => seen.add(i.getAttribute('name') ?? ''));
            }
            return;
          }
          // Group billing address
          if (name === 'billing_address') {
            const sameAs = document.getElementById('sameAsShipping') as HTMLInputElement;
            if (sameAs?.checked) {
              rows.push({ label: 'Billing Address', value: 'Same as shipping address' });
            } else {
              const block = el.closest('.address-block');
              const vals = block ? [...block.querySelectorAll<HTMLInputElement>('input:not([type="checkbox"])')].map(i => i.value.trim()).filter(Boolean) : [];
              if (vals.length) rows.push({ label: 'Billing Address', value: vals.join(', ') });
            }
            ['billing_address','billing_city','billing_state','billing_zip','billing_country'].forEach(n => seen.add(n));
            return;
          }
          if (['billing_city','billing_state','billing_zip','billing_country'].includes(name)) return;
          // Find label
          let labelText = '';
          if (el.id) {
            const lbl = section.querySelector<HTMLElement>(`label[for="${el.id}"]`);
            if (lbl) labelText = lbl.textContent?.trim().replace(/\s*\*$/, '').replace(/\s+/g, ' ') ?? '';
          }
          // Checkbox — always show, checked or not
          if (el instanceof HTMLInputElement && el.type === 'checkbox') {
            const cbText = el.closest('label')?.textContent?.trim() ?? labelText;
            rows.push({ label: el.checked ? '✓' : '✗', value: cbText.length > 120 ? cbText.slice(0, 120) + '…' : cbText, isCheck: true });
            seen.add(name);
            return;
          }
          // Select
          if (el instanceof HTMLSelectElement) {
            const opt = el.options[el.selectedIndex];
            if (!opt?.value) return;
            let val = opt.text;
            if (opt.value === 'other') {
              const oi = document.getElementById('business_type_other') as HTMLInputElement;
              if (oi?.value.trim()) { val += ': ' + oi.value.trim(); seen.add('business_type_other'); }
            }
            if (labelText) { rows.push({ label: labelText, value: val }); seen.add(name); }
            return;
          }
          // Textarea / input
          const val = el instanceof HTMLTextAreaElement ? el.value.trim() : (el as HTMLInputElement).value?.trim() ?? '';
          if (val && labelText) { rows.push({ label: labelText, value: val }); seen.add(name); }
        });
        if (rows.length) sections.push({ heading, rows });
      });
      return sections;
    }

    function openViewOrderModal() {
      reviewModalBody.innerHTML = '';

      // ── Order items first ────────────────────────────────────────────────
      const orderSec = document.createElement('div');
      orderSec.className = 'review-form-section';
      orderSec.innerHTML = '<h4 class="review-section-heading">Order Items</h4>';
      const orderLines: { title: string; qty: number; ws: number; image: string }[] = [];
      document.querySelectorAll<HTMLInputElement>('.qty-input').forEach(input => {
        const qty = parseInt(input.value) || 0;
        if (qty > 0) orderLines.push({
          title: input.dataset.title || '',
          qty,
          ws: parseFloat(input.dataset.ws || '0'),
          image: input.dataset.image || '',
        });
      });
      if (orderLines.length === 0) {
        orderSec.innerHTML += '<p class="review-empty">No items added yet.</p>';
      } else {
        let total = 0;
        orderLines.forEach(({ title, qty, ws, image }) => {
          const lt = qty * ws; total += lt;
          const row = document.createElement('div');
          row.className = 'review-item-row';
          row.innerHTML = `
            ${image ? `<img src="${image}" alt="${title}" class="review-item-img" />` : ''}
            <span class="review-item-name">${title}</span>
            <span class="review-item-meta">QTY: ${qty}</span>
            <span class="review-item-meta">TOTAL: $${lt.toFixed(2)}</span>
          `;
          orderSec.appendChild(row);
        });
        const totalRow = document.createElement('div');
        totalRow.className = 'review-order-total-row';
        totalRow.innerHTML = `<span class="review-total-label">Estimated wholesale total: </span><span class="review-total-value">$${total.toFixed(2)}</span>`;
        orderSec.appendChild(totalRow);
      }
      reviewModalBody.appendChild(orderSec);

      // ── Form summary sections ────────────────────────────────────────────
      collectFormSummary().forEach(({ heading, rows }) => {
        const sec = document.createElement('div');
        sec.className = 'review-form-section';
        sec.innerHTML = `<h4 class="review-section-heading">${heading}</h4>`;
        rows.forEach(r => {
          const row = document.createElement('div');
          if (r.isCheck) {
            row.className = 'review-check-row';
            const isYes = r.label === '✓';
            row.innerHTML = `<span class="review-check-mark ${isYes ? 'is-yes' : 'is-no'}">${r.label}</span><span class="review-check-text"> ${r.value}</span>`;
          } else {
            row.className = 'review-form-row';
            row.innerHTML = `<span class="review-form-label">${r.label}: </span><span class="review-form-value">${r.value}</span>`;
          }
          sec.appendChild(row);
        });
        reviewModalBody.appendChild(sec);
      });

      reviewSubmitStatus.textContent = '';
      reviewSubmitStatus.className = 'order-form-status';
      reviewConfirmBtn.disabled = false;
      reviewModal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    }

    async function doSubmit(fromModal: boolean) {
      const statusEl = fromModal ? reviewSubmitStatus : orderFormStatus;
      // Validate order items
      if (productsHidden) {
        const lines: string[] = [];
        document.querySelectorAll<HTMLInputElement>('.qty-input').forEach(input => {
          const qty = parseInt(input.value) || 0;
          if (qty > 0) lines.push(`${input.dataset.title} × ${qty}`);
        });
        if (lines.length === 0) {
          closeReviewModal();
          orderItemsError?.removeAttribute('hidden');
          orderItemsError?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        orderItemsError?.setAttribute('hidden', '');
        productsHidden.value = lines.join('\n');
      }
      // Enforce $100 order minimum
      const orderMinError = document.getElementById('order-min-error');
      let orderTotal = 0;
      document.querySelectorAll<HTMLInputElement>('.qty-input').forEach(input => {
        const qty = parseInt(input.value) || 0;
        if (qty > 0) orderTotal += qty * parseFloat(input.dataset.ws || '0');
      });
      if (orderTotal < 100) {
        closeReviewModal();
        orderMinError?.removeAttribute('hidden');
        orderMinError?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      orderMinError?.setAttribute('hidden', '');
      // Validate online presence
      if (presenceError) {
        const w = websiteInput?.value.trim() ?? '';
        const s = socialInput?.value.trim() ?? '';
        const b = businessAddrInput?.value.trim() ?? '';
        if (!w && !s && !b) {
          closeReviewModal();
          presenceError.removeAttribute('hidden');
          presenceError.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        presenceError.setAttribute('hidden', '');
      }
      // Browser validation
      if (!orderForm.checkValidity()) {
        closeReviewModal();
        orderForm.reportValidity();
        return;
      }
      reviewConfirmBtn.disabled = true;
      orderSubmitBtn.disabled = true;
      statusEl.textContent = 'Submitting…';
      statusEl.className = 'order-form-status';
      const formData = new FormData(orderForm);
      if (sameAsShipping?.checked) {
        formData.set('billing_address', 'Same as shipping address');
        formData.delete('billing_city'); formData.delete('billing_state');
        formData.delete('billing_zip'); formData.delete('billing_country');
      }
      try {
        const res = await fetch(orderForm.action, {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: formData,
        });
        if (res.ok) {
          closeReviewModal();
          orderFormStatus.textContent = 'Thank you! Your order request has been submitted. We\'ll be in touch soon.';
          orderFormStatus.className = 'order-form-status success';
          orderForm.reset();
          if (billingFields) billingFields.style.display = '';
          updateOrderTotal();
        } else {
          const data: any = await res.json().catch(() => ({}));
          statusEl.textContent = data.error ?? 'Something went wrong. Please try again or email us directly.';
          statusEl.className = 'order-form-status error';
        }
      } catch {
        statusEl.textContent = 'Network error. Please check your connection and try again.';
        statusEl.className = 'order-form-status error';
      }
      reviewConfirmBtn.disabled = false;
      orderSubmitBtn.disabled = false;
    }

    reviewConfirmBtn?.addEventListener('click', () => doSubmit(true));
    viewOrderBtn?.addEventListener('click', openViewOrderModal);

    orderForm.addEventListener('submit', (e) => {
      e.preventDefault();
      doSubmit(false);
    });

    // ── Print / Download order summary ────────────────────────────────────────
    function buildOrderPrintHtml() {
      const date = new Date().toLocaleString();
      let body = `<h1>Force of Nature Press — Wholesale Order Request</h1><p class="date">Generated: ${date}</p>`;
      body += `<h2>Order Items</h2>`;
      let total = 0; let hasItems = false;
      document.querySelectorAll<HTMLInputElement>('.qty-input').forEach(input => {
        const qty = parseInt(input.value) || 0;
        if (qty <= 0) return;
        hasItems = true;
        const title = (input.dataset.title ?? 'Unknown').replace(/</g, '&lt;');
        const price = parseFloat(input.dataset.ws || '0');
        const lineTotal = qty * price;
        total += lineTotal;
        body += `<div class="item-row">${title}<span class="meta">QTY: ${qty} | $${lineTotal.toFixed(2)}</span></div>`;
      });
      if (!hasItems) body += `<div class="item-row">(no items selected)</div>`;
      body += `<div class="total-row">Estimated wholesale total: $${total.toFixed(2)}</div>`;
      collectFormSummary().forEach(({ heading, rows }) => {
        body += `<h2>${heading.replace(/</g, '&lt;')}</h2>`;
        rows.forEach(r => {
          if (r.isCheck) {
            const cls = r.label === '✓' ? 'yes' : 'no';
            body += `<div class="check-row"><span class="${cls}">${r.label}</span> ${r.value.replace(/</g, '&lt;')}</div>`;
          } else {
            body += `<div class="field-row"><span class="lbl">${r.label.replace(/</g, '&lt;')}:</span><span class="val">${r.value.replace(/</g, '&lt;')}</span></div>`;
          }
        });
      });
      return `<!doctype html><html><head><title>Order Request — Force of Nature Press</title><style>
        body{font-family:Georgia,serif;max-width:640px;margin:2rem auto;color:#2d1f0e;line-height:1.6;font-size:14px}
        h1{font-size:1.1rem;margin:0 0 .2rem}
        .date{font-size:.85rem;color:#6b4a2a;margin-bottom:1.5rem}
        h2{font-size:.8rem;font-weight:bold;text-transform:uppercase;letter-spacing:.05em;margin:1.4rem 0 .4rem;border-bottom:1px solid #d4b896;padding-bottom:.2rem;color:#6b4a2a}
        .item-row{display:flex;justify-content:space-between;padding:.2rem 0;font-size:.9rem;border-bottom:1px solid #f0e6d0}
        .meta{color:#6b4a2a;font-size:.85rem}
        .total-row{font-weight:bold;margin-top:.6rem;font-size:.95rem}
        .field-row{display:flex;gap:.5rem;padding:.15rem 0}
        .lbl{min-width:150px;font-weight:bold;font-size:.85rem;color:#6b4a2a;flex-shrink:0}
        .val{font-size:.9rem}
        .check-row{padding:.15rem 0;font-size:.85rem}
        .yes{color:#3d7a6e;font-weight:bold}.no{color:#b44;font-weight:bold}
        @media print{body{margin:1rem}}
      </style></head><body>${body}</body></html>`;
    }

    function buildOrderText() {
      const lines: string[] = [];
      lines.push('FORCE OF NATURE PRESS — WHOLESALE ORDER REQUEST');
      lines.push('Generated: ' + new Date().toLocaleString());
      lines.push('');
      lines.push('ORDER ITEMS');
      lines.push('─'.repeat(50));
      let total = 0; let hasItems = false;
      document.querySelectorAll<HTMLInputElement>('.qty-input').forEach(input => {
        const qty = parseInt(input.value) || 0;
        if (qty <= 0) return;
        hasItems = true;
        const title = input.dataset.title ?? 'Unknown';
        const price = parseFloat(input.dataset.ws || '0');
        const lineTotal = qty * price;
        total += lineTotal;
        lines.push(`${title}   QTY: ${qty}   $${lineTotal.toFixed(2)}`);
      });
      if (!hasItems) lines.push('(no items selected)');
      lines.push(`Estimated wholesale total: $${total.toFixed(2)}`);
      lines.push('');
      collectFormSummary().forEach(({ heading, rows }) => {
        lines.push(heading.toUpperCase());
        lines.push('─'.repeat(50));
        rows.forEach(r => {
          if (r.isCheck) lines.push(`  ${r.label} ${r.value}`);
          else lines.push(`  ${r.label}: ${r.value}`);
        });
        lines.push('');
      });
      return lines.join('\n');
    }

    document.getElementById('reviewPrintBtn')?.addEventListener('click', () => {
      const win = window.open('', '_blank', 'width=720,height=900');
      if (!win) return;
      win.document.write(buildOrderPrintHtml());
      win.document.close();
      win.focus();
      win.print();
    });

    document.getElementById('reviewDownloadBtn')?.addEventListener('click', () => {
      const blob = new Blob([buildOrderText()], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'wholesale-order-request.txt';
      a.click();
      URL.revokeObjectURL(url);
    });
  }

  if (modal) {
    document.querySelectorAll<HTMLButtonElement>('.product-card').forEach(card => {
      card.addEventListener('click', () => {
        const data = JSON.parse(card.dataset.item || '{}');
        modalImg.src = data.image || '';
        modalImg.alt = data.title || '';
        modalTitle.textContent = data.title || '';
        modalDescription.textContent = data.description || '';
        modalDescription.style.display = data.description ? '' : 'none';
        modalWholesalePrice.textContent = `$${Number(data.wholesalePrice).toFixed(2)} per unit`;
        modalRrp.textContent = `$${Number(data.rrp).toFixed(2)}`;
        modalMoq.textContent = `${data.moq} unit${data.moq !== 1 ? 's' : ''} minimum`;
        modal.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
        modalClose?.focus();
      });
    });

    function closeModal() {
      modal.setAttribute('hidden', '');
      document.body.style.overflow = '';
    }

    modalClose?.addEventListener('click', closeModal);
    modal.querySelector('.modal-backdrop')?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal(); });
  }

  // Block right-click and drag on all images
  document.addEventListener('contextmenu', (e) => { if (e.target instanceof HTMLImageElement) e.preventDefault(); });
  document.addEventListener('dragstart', (e) => { if (e.target instanceof HTMLImageElement) e.preventDefault(); });
</script>
