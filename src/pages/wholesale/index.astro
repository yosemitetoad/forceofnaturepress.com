---
export const prerender = false;

import { getPublishedWholesaleItems, getPageContentMulti, getWholesaleCategories, getWholesaleFormConfig } from '../../lib/db';
import { md } from '../../lib/markdown';
import { SITE_TITLE } from '../../consts';

const db = Astro.locals.runtime.env.DB;

const content = await getPageContentMulti(db, ['wholesale_terms', 'wholesale_contact_intro', 'wholesale_contact_email', 'wholesale_form_url', 'wholesale_catalog_intro', 'wholesale_under_construction']);

const [items, wholesaleCategories, formConfig] = await Promise.all([
  getPublishedWholesaleItems(db),
  getWholesaleCategories(db),
  getWholesaleFormConfig(db),
]);
const termsHtml = await md(content.wholesale_terms ?? '');
const contactIntro = content.wholesale_contact_intro ?? '';
const contactEmail = content.wholesale_contact_email ?? '';
const formUrl = content.wholesale_form_url ?? '';
const catalogIntro = content.wholesale_catalog_intro ?? '';
const underConstruction = content.wholesale_under_construction === '1';

// Flatten visible fields for JS validation logic
const visibleFieldIds = new Set(
  (formConfig?.sections ?? []).flatMap(s => s.visible ? s.fields.filter(f => f.visible).map(f => f.id) : [])
);
const showWebsiteSocial = visibleFieldIds.has('website') || visibleFieldIds.has('social');

// Group items by effective category, ordered by DB sort_order
const catLabelMap = new Map(wholesaleCategories.map(c => [c.slug, c.label]));
const catOrderMap = new Map(wholesaleCategories.map(c => [c.slug, c.sortOrder]));
const catDescMap = new Map(wholesaleCategories.map(c => [c.slug, c.description]));
const catGroupMap = new Map(wholesaleCategories.map(c => [c.slug, c.group ?? '']));
// Ordered unique groups (preserving first-appearance order)
const catalogGroups = [...new Map(wholesaleCategories.filter(c => c.group).map(c => [c.group, c.group])).values()];
const groupedItems = new Map<string, typeof items>();
for (const item of items) {
  const cat = item.category || 'other';
  if (!groupedItems.has(cat)) groupedItems.set(cat, []);
  groupedItems.get(cat)!.push(item);
}
const sortedCats = [...groupedItems.keys()].sort((a, b) => {
  const ao = catOrderMap.get(a) ?? 999;
  const bo = catOrderMap.get(b) ?? 999;
  if (ao !== bo) return ao - bo;
  return a.localeCompare(b);
});
function formatCat(cat: string) {
  return catLabelMap.get(cat) ?? cat.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Wholesale — {SITE_TITLE}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800&display=swap" rel="stylesheet" />
  <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
  <link rel="icon" type="image/png" href="/beetleshopiconsquare.webp" />
</head>
<body>

{underConstruction ? (
  <div class="construction-wrap">
    <div class="construction-box">
      <img src="/beetleshopiconsquare.webp" alt="Force of Nature Press" class="construction-logo" />
      <h1>Wholesale — Coming Soon</h1>
      <p>Our wholesale ordering page is under construction. Please check back soon, or get in touch directly.</p>
      <a href="/" class="construction-home">&#8592; Back to homepage</a>
    </div>
  </div>
) : (
<>
    <header class="site-header">
      <div class="container">
        <a href="/" class="header-brand">
          <img src="/beetleshopiconsquare.webp" alt="Force of Nature Press" width="36" height="36" />
          Force of Nature Press
        </a>
        <nav class="header-nav">
          <a href="#terms">Terms &amp; Conditions</a>
          <a href="#catalog">Catalog</a>
          <a href="#order-form">Order Form</a>
        </nav>
        <a href="/" class="header-back">&#8592; Back to homepage</a>
      </div>
    </header>

    <main>
      <!-- Terms -->
      {termsHtml && (
        <section class="terms-section container" id="terms">
          <details class="section-details" open>
            <summary class="section-heading">Terms &amp; Conditions</summary>
            <div class="terms-scroll-wrap">
              <div class="terms-body">
                <Fragment set:html={termsHtml} />
              </div>
            </div>
          </details>
        </section>
      )}

      <!-- Catalog -->
      <section class="catalog-section container" id="catalog">
        <details class="section-details" open>
          <summary class="section-heading">Catalog</summary>
          {catalogIntro && <p class="catalog-intro">{catalogIntro}</p>}
          {catalogGroups.length > 0 && (
            <div class="catalog-tabs" role="tablist">
              <button class="catalog-tab active" data-tab="all" role="tab" aria-selected="true">All</button>
              {catalogGroups.map(g => (
                <button class="catalog-tab" data-tab={g} role="tab" aria-selected="false">{g}</button>
              ))}
            </div>
          )}
          {items.length === 0 ? (
            <p class="empty-catalog">No items available yet — check back soon.</p>
          ) : (
            sortedCats.map(cat => {
              const catItems = groupedItems.get(cat)!;
              return (
                <details class="catalog-category" open data-group={catGroupMap.get(cat) ?? ''}>
                  <summary class="category-heading">{formatCat(cat)}</summary>
                  {catDescMap.get(cat) && <p class="category-description">{catDescMap.get(cat)}</p>}
                  <div class="product-grid">
                    {catItems.map(item => (
                    <button
                      class="product-card"
                      data-item={JSON.stringify({
                        title: item.title,
                        image: item.image,
                        description: item.description,
                        wholesalePrice: item.wholesalePrice,
                        rrp: item.rrp,
                        moq: item.moq,
                      })}
                      aria-label={`View details for ${item.title}`}
                    >
                      <div class="card-img-wrap">
                        <img src={item.image} alt={item.title} loading="lazy" />
                      </div>
                      <div class="card-info">
                        <span class="card-title">{item.title}</span>
                      </div>
                    </button>
                    ))}
                  </div>
                </details>
              );
            })
          )}
        </details>
      </section>

      <!-- Contact / Order Form -->
      <section class="contact-section container" id="order-form">
        <h2 class="section-heading">Wholesale Order Form</h2>
        {contactIntro && <p class="contact-intro">{contactIntro}</p>}
        {contactEmail && <p class="contact-email">Email: <a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>}
        {formUrl && formConfig && (
          <form id="orderForm" class="order-form" action={formUrl} method="POST" novalidate>
            <input type="hidden" name="_subject" value="Wholesale Order Request" />

            {formConfig.sections.filter(s => s.visible).map(section => (
              <div class="order-section">
                <h3 class="order-section-heading">{section.heading}</h3>

                {/* Pair up inline fields (non-textarea, non-checkbox, non-address) two per row */}
                {(() => {
                  const visFields = section.fields.filter(f => f.visible);
                  const rendered: any[] = [];
                  let i = 0;
                  while (i < visFields.length) {
                    const f = visFields[i];

                    if (f.type === 'address') {
                      rendered.push(
                        <div class="address-block">
                          <label class="address-label">{f.label}{f.required && <span class="req"> *</span>}</label>
                          <input type="text" name="shipping_address" placeholder="Street address" required={f.required} class="address-input" />
                          <div class="address-row">
                            <input type="text" name="shipping_city" placeholder="City" required={f.required} class="address-input" />
                            <input type="text" name="shipping_state" placeholder="State / Province" required={f.required} class="address-input" />
                          </div>
                          <div class="address-row">
                            <input type="text" name="shipping_zip" placeholder="ZIP / Postal code" required={f.required} class="address-input" />
                            <input type="text" name="shipping_country" placeholder="Country" required={f.required} class="address-input" />
                          </div>
                        </div>
                      );
                      i++; continue;
                    }

                    if (f.type === 'address-billing') {
                      rendered.push(
                        <div class="address-block">
                          <label class="address-label">{f.label}</label>
                          <label class="same-as-shipping checkbox-label">
                            <input type="checkbox" id="sameAsShipping" />
                            Same as shipping address
                          </label>
                          <div id="billingFields">
                            <input type="text" name="billing_address" placeholder="Street address" class="address-input" />
                            <div class="address-row">
                              <input type="text" name="billing_city" placeholder="City" class="address-input" />
                              <input type="text" name="billing_state" placeholder="State / Province" class="address-input" />
                            </div>
                            <div class="address-row">
                              <input type="text" name="billing_zip" placeholder="ZIP / Postal code" class="address-input" />
                              <input type="text" name="billing_country" placeholder="Country" class="address-input" />
                            </div>
                          </div>
                        </div>
                      );
                      i++; continue;
                    }

                    if (f.id === 'products') {
                      rendered.push(
                        <div class="field">
                          <label for="orderCategorySelect">{f.label}{f.required && <span class="req"> *</span>}</label>
                          <p class="field-help">Pick a category from the dropdown, enter quantities for what you'd like, then switch to another category if needed. Your quantities are saved as you go.</p>
                          <select id="orderCategorySelect" class="order-cat-select">
                            {sortedCats.map((cat, idx) => (
                              <option value={cat} selected={idx === 0}>{formatCat(cat)}</option>
                            ))}
                          </select>
                          <div id="orderGrids">
                            {sortedCats.map((cat, idx) => (
                              <div class="order-product-grid" data-cat={cat} style={idx !== 0 ? 'display:none' : ''}>
                                {(groupedItems.get(cat) ?? []).map(item => (
                                  <div class="order-product-card">
                                    <div class="order-card-img">
                                      <img src={item.image} alt={item.title} loading="lazy" />
                                    </div>
                                    <div class="order-card-body">
                                      <span class="order-card-title">{item.title}</span>
                                      <div class="order-card-meta">
                                        <span><strong>WSP:</strong> ${item.wholesalePrice.toFixed(2)}</span>
                                        <span><strong>RRP:</strong> ${item.rrp.toFixed(2)}</span>
                                        <span><strong>MOQ:</strong> {item.moq}</span>
                                      </div>
                                    </div>
                                    <div class="order-card-qty-row">
                                      <label for={`qty_${item.id}`} class="qty-label">Qty</label>
                                      <input
                                        type="number" id={`qty_${item.id}`} class="qty-input"
                                        data-id={item.id} data-title={item.title}
                                        data-ws={item.wholesalePrice} data-moq={item.moq}
                                        data-image={item.image || ''}
                                        min="0" step="1" placeholder="0"
                                      />
                                    </div>
                                  </div>
                                ))}
                              </div>
                            ))}
                          </div>
                          <div class="order-total-row" id="orderTotalRow" hidden>
                            <span class="order-total-label">Estimated wholesale total:</span>
                            <span class="order-total-value" id="orderTotalValue">$0.00</span>
                          </div>
                          <p class="order-minimum-note">Opening orders: $150 minimum &bull; Reorders: $100 minimum</p>
                          <p id="order-items-error" class="field-error" hidden>Please add at least one item to your order.</p>
                          <p id="order-min-error" class="field-error" hidden>Your order total is below the $100 minimum. Please add more items before submitting.</p>
                          <input type="hidden" name="products" id="productsHidden" />
                        </div>
                      );
                      i++; continue;
                    }

                    if (f.type === 'textarea') {
                      rendered.push(
                        <div class="field">
                          <label for={f.id}>{f.label}{f.required && <span class="req"> *</span>}</label>
                          {f.helpText && <p class="field-help">{f.helpText}</p>}
                          <textarea id={f.id} name={f.id} rows={f.rows ?? 4} required={f.required} placeholder={f.placeholder ?? ''}></textarea>
                        </div>
                      );
                      i++; continue;
                    }

                    if (f.type === 'select') {
                      rendered.push(
                        <div class="field">
                          <label for={f.id}>{f.label}{f.required && <span class="req"> *</span>}</label>
                          {f.helpText && <p class="field-help">{f.helpText}</p>}
                          <select id={f.id} name={f.id} required={f.required}>
                            <option value="">Select...</option>
                            <option value="brick-and-mortar">Brick-and-mortar store</option>
                            <option value="online-retailer">Online retailer</option>
                            <option value="museum-institution">Museum or institution</option>
                            <option value="nature-center">Nature center</option>
                            <option value="other">Other</option>
                          </select>
                          {f.id === 'business_type' && (
                            <div id="businessTypeOtherWrap" hidden style="margin-top:0.6rem">
                              <label for="business_type_other" class="sub-label">Please describe your business: <span class="req">*</span></label>
                              <input type="text" id="business_type_other" name="business_type_other" disabled />
                            </div>
                          )}
                        </div>
                      );
                      i++; continue;
                    }

                    if (f.type === 'checkbox') {
                      const isTerms = f.id === 'agree_terms';
                      rendered.push(
                        <div class="agreement-field">
                          <label class="checkbox-label">
                            <input type="checkbox" name={f.id} required={f.required} />
                            {isTerms
                              ? <span>I have read and agree to the <a href="#terms">Force of Nature Press wholesale terms</a>.</span>
                              : f.label}
                          </label>
                        </div>
                      );
                      i++; continue;
                    }

                    // Inline fields: group website+social+business_address together, otherwise pair consecutive inline fields
                    const next = visFields[i + 1];
                    const isWebsite = f.id === 'website';
                    const isSocial = f.id === 'social';
                    const isBusinessAddr = f.id === 'business_address';
                    const nextIsSocial = next?.id === 'social';

                    if (isWebsite && nextIsSocial) {
                      const afterNext = visFields[i + 2];
                      const hasBusinessAddr = afterNext?.id === 'business_address';
                      rendered.push(
                        <div class="field">
                          <label>Website, Social Media{hasBusinessAddr ? ', or Store Address' : ''}<span class="req"> *</span></label>
                          <p class="field-help">{f.helpText || 'Please provide at least one.'}</p>
                          <div class="form-row">
                            <div class="field mb-0">
                              <label for="website" class="sub-label">Website URL</label>
                              <input type="text" id="website" name="website" placeholder={f.placeholder ?? 'https://... or websitename.com'} />
                            </div>
                            <div class="field mb-0">
                              <label for="social" class="sub-label">Social Media Handle(s)</label>
                              <input type="text" id="social" name="social" placeholder={next.placeholder ?? '@handle or profile link'} />
                            </div>
                          </div>
                          {hasBusinessAddr && (
                            <div class="field mb-0" style="margin-top:0.6rem">
                              <label for="business_address" class="sub-label">{afterNext.label}</label>
                              <input type="text" id="business_address" name="business_address" placeholder={afterNext.placeholder ?? ''} />
                            </div>
                          )}
                          <p id="presence-error" class="field-error" hidden>Please provide a website, social media handle, or store address.</p>
                        </div>
                      );
                      i += hasBusinessAddr ? 3 : 2; continue;
                    }

                    // Skip social/business_address if already rendered as part of the website group
                    if (isSocial && visFields[i - 1]?.id === 'website') { i++; continue; }
                    if (isBusinessAddr && (visFields[i - 1]?.id === 'social' || visFields[i - 2]?.id === 'website')) { i++; continue; }

                    // Pair two consecutive inline fields in a form-row
                    const canPair = next && !['textarea','select','checkbox','address','address-billing'].includes(next.type);
                    if (canPair) {
                      rendered.push(
                        <div class="form-row">
                          <div class="field">
                            <label for={f.id}>{f.label}{f.required && <span class="req"> *</span>}</label>
                            {f.helpText && <p class="field-help">{f.helpText}</p>}
                            <input type={f.type as string} id={f.id} name={f.id} placeholder={f.placeholder ?? ''} required={f.required} />
                          </div>
                          <div class="field">
                            <label for={next.id}>{next.label}{next.required && <span class="req"> *</span>}</label>
                            {next.helpText && <p class="field-help">{next.helpText}</p>}
                            <input type={next.type as string} id={next.id} name={next.id} placeholder={next.placeholder ?? ''} required={next.required} />
                          </div>
                        </div>
                      );
                      i += 2; continue;
                    }

                    // Single inline field
                    rendered.push(
                      <div class="field">
                        <label for={f.id}>{f.label}{f.required && <span class="req"> *</span>}</label>
                        {f.helpText && <p class="field-help">{f.helpText}</p>}
                        <input type={f.type as string} id={f.id} name={f.id} placeholder={f.placeholder ?? ''} required={f.required} />
                      </div>
                    );
                    i++;
                  }
                  return rendered;
                })()}
              </div>
            ))}

            <div class="form-submit-row">
              <button type="button" class="view-order-btn" id="viewOrderBtn">Review Order</button>
              <button type="submit" class="submit-btn" id="orderSubmitBtn">{formConfig.submitButtonText}</button>
              <span id="orderFormStatus" class="order-form-status"></span>
            </div>
          </form>
        )}
      </section>
    </main>

    <footer class="site-footer">
      <div class="container">
        <a href="/" class="footer-back">&#8592; Back to homepage</a>
        <p>&copy; {new Date().getFullYear()} Force of Nature Press. All rights reserved.</p>
      </div>
    </footer>

    <!-- Modal -->
    <div id="modal" class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle" hidden>
      <div class="modal-backdrop"></div>
      <div class="modal-box">
        <button class="modal-close" id="modalClose" aria-label="Close">&times;</button>
        <div class="modal-content">
          <img id="modalImg" src="" alt="" class="modal-img" />
          <div class="modal-details">
            <h3 id="modalTitle"></h3>
            <p id="modalDescription" class="modal-description"></p>
            <dl class="modal-pricing">
              <div class="pricing-row">
                <dt>Wholesale Price</dt>
                <dd id="modalWholesalePrice"></dd>
              </div>
              <div class="pricing-row">
                <dt>RRP</dt>
                <dd id="modalRrp"></dd>
              </div>
              <div class="pricing-row">
                <dt>Minimum Order</dt>
                <dd id="modalMoq"></dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>

    <!-- Order Review Modal -->
    <div id="reviewModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="reviewModalTitle" hidden>
      <div class="modal-backdrop" id="reviewModalBackdrop"></div>
      <div class="modal-box review-modal-box">
        <button class="modal-close" id="reviewModalClose" aria-label="Close">&times;</button>
        <h3 class="review-modal-heading" id="reviewModalTitle">Order Review</h3>
        <div id="reviewModalBody" class="review-modal-body"></div>
        <div class="review-actions">
          <button type="button" class="review-edit-btn" id="reviewEditBtn">Close</button>
          <div class="review-util-btns">
            <button type="button" class="review-util-btn" id="reviewPrintBtn">Print</button>
            <button type="button" class="review-util-btn" id="reviewDownloadBtn">Download</button>
          </div>
          <button type="button" class="review-confirm-btn" id="reviewConfirmBtn">Submit Order Request</button>
        </div>
        <p id="reviewSubmitStatus" class="order-form-status" style="margin-top:0.8rem"></p>
      </div>
    </div>
</>
)}

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; }
  body { font-family: 'Nunito', sans-serif; margin: 0; background: #f0e6d0; color: #2d1f0e; line-height: 1.6; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }

  /* Header */
  .site-header { background: #2d1f0e; color: #faf5ea; padding: 0 0; }
  .site-header .container { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; height: 56px; }
  .header-brand { display: flex; align-items: center; gap: 0.6rem; color: #faf5ea; text-decoration: none; font-weight: 800; font-size: 1rem; justify-self: start; }
  .header-brand img { border-radius: 4px; }
  .header-nav { display: flex; align-items: center; gap: 1.6rem; }
  .header-nav a { color: #c8a878; text-decoration: none; font-size: 0.88rem; font-weight: 700; white-space: nowrap; transition: color 0.15s; }
  .header-nav a:hover { color: #faf5ea; }
  .header-back { color: #a08060; text-decoration: none; font-size: 0.82rem; font-weight: 700; white-space: nowrap; justify-self: end; transition: color 0.15s; }
  .header-back:hover { color: #faf5ea; }
  /* Under construction page */
  .construction-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: #f0e6d0; }
  .construction-box { background: #faf5ea; border: 2px solid #d4b896; border-radius: 14px; padding: 2.5rem; width: 100%; max-width: 460px; text-align: center; }
  .construction-logo { width: 72px; height: 72px; margin-bottom: 1rem; border-radius: 8px; }
  .construction-box h1 { font-size: 1.5rem; font-weight: 800; margin: 0 0 0.8rem; }
  .construction-box p { color: #5a3e1e; font-size: 0.95rem; line-height: 1.7; margin: 0 0 1.5rem; }
  .construction-home { display: inline-block; color: #c87830; font-weight: 700; text-decoration: none; font-size: 0.9rem; }
  .construction-home:hover { color: #a05e18; }
  @media (max-width: 820px) {
    .header-nav { gap: 1rem; }
    .header-nav a { font-size: 0.78rem; }
  }
  @media (max-width: 640px) {
    .site-header .container { grid-template-columns: 1fr auto; }
    .header-nav { display: none; }
    .header-back { display: none; }
  }

  /* Sections */
  .terms-section { padding: 3rem 1.5rem 2rem; }
  .catalog-section { padding: 2rem 1.5rem; }
  .contact-section { padding: 2rem 1.5rem 3rem; }
  .section-heading { font-size: 1.5rem; font-weight: 800; margin: 0 0 1.2rem; color: #2d1f0e; padding-bottom: 0.5rem; border-bottom: 2px solid #d4b896; }

  /* Collapsible details */
  .section-details, .catalog-category { display: block; }
  .section-details > summary,
  .catalog-category > summary {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
  }
  .section-details > summary::-webkit-details-marker,
  .catalog-category > summary::-webkit-details-marker { display: none; }
  .section-details > summary::after,
  .catalog-category > summary::after {
    content: '▾';
    font-weight: 400;
    color: #a08060;
    transition: transform 0.18s;
    flex-shrink: 0;
    margin-left: 0.6rem;
    font-size: 1.1em;
    line-height: 1;
  }
  .section-details:not([open]) > summary::after,
  .catalog-category:not([open]) > summary::after { transform: rotate(-90deg); }
  .section-details > summary:hover::after,
  .catalog-category > summary:hover::after { color: #6b4a2a; }

  /* Terms */
  .terms-scroll-wrap { position: relative; }
  .terms-scroll-wrap::after {
    content: '';
    position: absolute;
    bottom: 0; left: 2px; right: 2px;
    height: 44px;
    background: linear-gradient(to bottom, transparent, #faf5ea);
    border-radius: 0 0 10px 10px;
    pointer-events: none;
    z-index: 1;
  }
