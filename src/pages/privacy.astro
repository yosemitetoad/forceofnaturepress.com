---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { EMAIL } from '../consts';
import { getPageContent } from '../lib/db';
import { marked } from 'marked';

let content = '';
try {
  const db = Astro.locals.runtime.env.DB;
  if (db) {
    const raw = await getPageContent(db, 'privacy_content');
    if (raw) {
      const withEmail = raw.replace(/\{EMAIL_LINK\}/g, `[${EMAIL}](mailto:${EMAIL})`);
      content = await marked(withEmail);
    }
  }
} catch (e) {
  console.warn('[privacy] D1 unavailable:', e);
}
---

<Base title="Privacy Policy — Force of Nature Press" description="Privacy policy for Force of Nature Press.">
  <div class="legal-page">
    <h1>Privacy Policy</h1>
    <p class="last-updated">Last updated: March 2026</p>
    <Fragment set:html={content} />
  </div>
</Base>

<style>
  .legal-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .legal-page h1 {
    margin-bottom: 0.3rem;
  }
  .last-updated {
    color: var(--brown-mid);
    font-size: 0.9rem;
    font-style: italic;
    margin-bottom: 2rem;
  }
  .legal-page h2 {
    font-size: 1.3rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--brown);
  }
  .legal-page h3 {
    font-size: 1.05rem;
    margin-top: 1.2rem;
    margin-bottom: 0.3rem;
  }
  .legal-page p, .legal-page li {
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .legal-page ul {
    padding-left: 1.5rem;
  }
  .legal-page li {
    margin-bottom: 0.4rem;
  }
</style>
