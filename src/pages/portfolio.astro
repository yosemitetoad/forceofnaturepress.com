---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { getAllPortfolioItems, getPortfolioCategories, getPortfolioProjects, getPageContentMulti } from '../lib/db';
import { mdInline } from '../lib/markdown';

const db = Astro.locals.runtime.env.DB;
const items = await getAllPortfolioItems(db);
const categories = await getPortfolioCategories(db);
const projects = await getPortfolioProjects(db);

// Pre-render markdown in descriptions
const descHtml: Record<number, string> = {};
for (const item of items) {
  if (item.description) {
    descHtml[item.id] = await mdInline(item.description);
  }
}

const content = await getPageContentMulti(db, ['portfolio_header', 'portfolio_subheader']);
const portfolioHeader = content.portfolio_header ?? 'Portfolio';
const portfolioSubheader = content.portfolio_subheader ?? 'Original nature illustrations — sticker designs, linocut prints, and art prints.';
---

<Base
  title="Portfolio — Force of Nature Press"
  description="Original nature illustration portfolio by Riley Briggs — sticker designs, linocut prints, and art prints."
  fullWidth
>

  <div class="portfolio-header">
    <div class="container">
      <h1>{portfolioHeader}</h1>
      <p>{portfolioSubheader}</p>
    </div>
  </div>

  <div class="container portfolio-body">

    {(categories.length > 0 || projects.length > 0) && (
      <div class="filter-bar">
        <button class="filter-btn active" data-cat="all">All Work</button>
        {categories.map(cat => (
          <button class="filter-btn" data-cat={cat}>{cat}</button>
        ))}
        {projects.length > 0 && categories.length > 0 && <span class="filter-divider"></span>}
        {projects.map(proj => (
          <button class="filter-btn filter-project" data-project={proj}>{proj}</button>
        ))}
      </div>
    )}

    <div class="portfolio-grid" id="portfolioGrid">
      {items.map(item => (
        <div
          class="artwork-card"
          data-category={item.category ?? ''}
          data-project={item.project ?? ''}
          data-title={item.title ?? ''}
          data-image={item.image ?? ''}
          data-medium={item.medium ?? ''}
          data-year={item.year ?? ''}
          data-link={item.link ?? ''}
        >
          {descHtml[item.id] && <template class="desc-html"><Fragment set:html={descHtml[item.id]} /></template>}
          <div class="artwork-img-wrap">
            {item.image
              ? <img src={item.image} alt={item.title ?? ''} loading="lazy" width="500" height="500" />
              : <div class="artwork-placeholder"></div>
            }
            <div class="artwork-overlay">
              <span class="overlay-hint">Click to view</span>
            </div>
          </div>
          {item.title && <p class="artwork-title">{item.title}</p>}
        </div>
      ))}
    </div>

    <!-- Lightbox modal -->
    <div class="lightbox" id="lightbox">
      <button class="lightbox-close" id="lightboxClose" aria-label="Close">&times;</button>
      <div class="lightbox-content">
        <div class="lightbox-img-wrap">
          <img id="lightboxImg" src="" alt="" />
        </div>
        <div class="lightbox-info" id="lightboxInfo"></div>
      </div>
    </div>

    {items.length === 0 && (
      <p class="empty-msg">Portfolio pieces coming soon.</p>
    )}

  </div>

</Base>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.artwork-card');

  // Filtering
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      const proj = btn.dataset.project;
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      cards.forEach(card => {
        let show = false;
        if (cat === 'all') show = true;
        else if (proj) show = card.dataset.project === proj;
        else if (cat) show = card.dataset.category === cat;
        card.style.display = show ? '' : 'none';
      });
    });
  });

  // Lightbox
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
  const lightboxInfo = document.getElementById('lightboxInfo')!;
  const lightboxClose = document.getElementById('lightboxClose')!;

  function openLightbox(card: HTMLElement) {
    const { title, image, medium, year, link, project } = card.dataset;
    if (!image) return;

    lightboxImg.src = image;
    lightboxImg.alt = title || '';

    // Get pre-rendered description HTML from template element
    const tpl = card.querySelector('template.desc-html');
    const descHtml = tpl ? tpl.innerHTML : '';

    let html = '';
    if (title) html += `<h2 class="lb-title">${title}</h2>`;
    if (project) html += `<span class="lb-project">Project: ${project}</span>`;
    const meta: string[] = [];
    if (medium) meta.push(medium);
    if (year) meta.push(year);
    if (meta.length) html += `<p class="lb-meta">${meta.join(' · ')}</p>`;
    if (descHtml) html += `<div class="lb-desc">${descHtml}</div>`;
    if (link) html += `<a href="${link}" target="_blank" rel="noopener noreferrer" class="lb-link">View project &rarr;</a>`;

    lightboxInfo.innerHTML = html;
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
    lightboxImg.src = '';
  }

  cards.forEach(card => {
    card.style.cursor = 'pointer';
    card.addEventListener('click', () => openLightbox(card));
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('open')) closeLightbox();
  });
</script>

<style>
  .portfolio-header {
    background: url('/plainstarbanner.webp') center / cover no-repeat;
    border-bottom: 2px solid var(--border);
    padding: 2.5rem 0 1.5rem;
    position: relative;
  }
  .portfolio-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(250, 245, 234, 0.75);
  }
  .portfolio-header .container { position: relative; }
  .portfolio-header h1 { margin-bottom: 0.3em; }
  .portfolio-header p { color: var(--brown-mid); margin: 0; }

  .portfolio-body { padding-top: 2rem; padding-bottom: 4rem; }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .filter-btn {
    padding: 0.45em 1.2em;
    border: 2px solid var(--border);
    border-radius: 999px;
    background: var(--cream-light);
    color: var(--brown);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .filter-divider { width: 2px; height: 1.5em; background: var(--border); align-self: center; }
  .filter-btn:hover { border-color: var(--orange); }
  .filter-btn.active {
    background: var(--orange);
    border-color: var(--orange);
    color: var(--cream-light);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.2rem;
  }

  .artwork-card {
    display: block;
    color: var(--brown);
    cursor: pointer;
  }

  .artwork-img-wrap {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 10px;
    border: 2px solid var(--border);
    background: var(--cream-dark);
  }
  .artwork-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.25s;
    display: block;
  }
  .artwork-placeholder {
    width: 100%;
    height: 100%;
    background: var(--cream-dark);
  }

  .artwork-overlay {
    position: absolute;
    inset: 0;
    background: rgba(45, 31, 14, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s;
  }
  .overlay-hint {
    color: var(--cream-light);
    font-weight: 700;
    font-size: 0.9rem;
    background: rgba(45, 31, 14, 0.6);
    padding: 0.4em 1em;
    border-radius: 999px;
  }

  .artwork-card:hover .artwork-overlay { opacity: 1; }
  .artwork-card:hover .artwork-img-wrap img { transform: scale(1.04); }
  .artwork-card:hover .artwork-img-wrap { border-color: var(--orange); }

  .artwork-title {
    margin: 0.5rem 0 0 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--brown-mid);
    line-height: 1.3;
  }

  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(45, 31, 14, 0.7);
    backdrop-filter: blur(4px);
    overflow-y: auto;
    padding: 2rem;
  }
  .lightbox.open { display: flex; align-items: center; justify-content: center; }

  .lightbox-close {
    position: fixed;
    top: 1rem;
    right: 1.2rem;
    z-index: 1001;
    background: none;
    border: none;
    color: var(--cream-light);
    font-size: 2.2rem;
    cursor: pointer;
    line-height: 1;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.15s;
  }
  .lightbox-close:hover { background: rgba(255,255,255,0.15); }

  .lightbox-content {
    background: var(--cream-light);
    border-radius: 12px;
    border: 2px solid var(--border);
    max-width: 900px;
    width: 100%;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.3);
  }

  .lightbox-img-wrap {
    background: var(--cream-dark);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox-img-wrap img {
    width: 100%;
    max-height: 70vh;
    object-fit: contain;
    display: block;
  }

  .lightbox-info {
    padding: 1.5rem 2rem;
  }
  .lightbox-info:empty { display: none; }

  .lb-title {
    font-size: 1.4rem;
    font-weight: 800;
    margin: 0 0 0.3rem;
    color: var(--brown);
  }
  .lb-project {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--orange);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }
  .lb-meta {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--brown-mid);
    margin: 0.3rem 0;
  }
  .lb-desc {
    font-size: 0.9rem;
    color: var(--brown-mid);
    line-height: 1.5;
    margin: 0.5rem 0 0;
  }
  .lb-desc a {
    color: var(--orange);
    font-weight: 700;
    text-decoration: none;
  }
  .lb-desc a:hover { text-decoration: underline; }
  .lb-link {
    display: inline-block;
    margin-top: 0.8rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--orange);
    text-decoration: none;
  }
  .lb-link:hover { text-decoration: underline; }

  .empty-msg {
    text-align: center;
    color: var(--brown-mid);
    font-style: italic;
    padding: 3rem 0;
  }

  @media (max-width: 600px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
    .lightbox { padding: 1rem; }
    .lightbox-info { padding: 1.2rem; }
    .lb-title { font-size: 1.2rem; }
  }
</style>
