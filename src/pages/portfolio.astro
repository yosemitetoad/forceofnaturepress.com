---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { getAllPortfolioItems, getPortfolioCategories, getPageContentMulti } from '../lib/db';

const db = Astro.locals.runtime.env.DB;
const items = await getAllPortfolioItems(db);
const categories = await getPortfolioCategories(db);

const content = await getPageContentMulti(db, ['portfolio_header', 'portfolio_subheader']);
const portfolioHeader = content.portfolio_header ?? 'Portfolio';
const portfolioSubheader = content.portfolio_subheader ?? 'Original nature illustrations — sticker designs, linocut prints, and art prints.';
---

<Base
  title="Portfolio — Force of Nature Press"
  description="Original nature illustration portfolio by Riley Briggs — sticker designs, linocut prints, and art prints."
  fullWidth
>

  <div class="portfolio-header">
    <div class="container">
      <h1>{portfolioHeader}</h1>
      <p>{portfolioSubheader}</p>
    </div>
  </div>

  <div class="container portfolio-body">

    {categories.length > 0 && (
      <div class="filter-bar">
        <button class="filter-btn active" data-cat="all">All Work</button>
        {categories.map(cat => (
          <button class="filter-btn" data-cat={cat}>{cat}</button>
        ))}
      </div>
    )}

    <div class="portfolio-grid" id="portfolioGrid">
      {items.map(item => {
        const hasInfo = item.medium || item.year || item.description;
        const inner = (
          <div class="artwork-card" data-category={item.category ?? ''}>
            <div class="artwork-img-wrap">
              {item.image
                ? <img src={item.image} alt={item.title ?? ''} loading="lazy" width="500" height="500" />
                : <div class="artwork-placeholder"></div>
              }
              {hasInfo && (
                <div class="artwork-overlay">
                  {item.medium && <span class="overlay-medium">{item.medium}</span>}
                  {item.year && <span class="overlay-year">{item.year}</span>}
                  {item.description && <p class="overlay-desc">{item.description}</p>}
                  {item.link && <span class="overlay-link-hint">View project</span>}
                </div>
              )}
            </div>
            {item.title && <p class="artwork-title">{item.title}</p>}
          </div>
        );

        return item.link
          ? <a href={item.link} target="_blank" rel="noopener noreferrer" class="artwork-link">{inner}</a>
          : inner;
      })}
    </div>

    {items.length === 0 && (
      <p class="empty-msg">Portfolio pieces coming soon.</p>
    )}

  </div>

</Base>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.artwork-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      cards.forEach(card => {
        const el = card.closest('.artwork-link') as HTMLElement | null;
        const target = el ?? card;
        const show = cat === 'all' || card.dataset.category === cat;
        target.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .portfolio-header {
    background: url('/plainstarbanner.webp') center / cover no-repeat;
    border-bottom: 2px solid var(--border);
    padding: 2.5rem 0 1.5rem;
    position: relative;
  }
  .portfolio-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(250, 245, 234, 0.75);
  }
  .portfolio-header .container { position: relative; }
  .portfolio-header h1 { margin-bottom: 0.3em; }
  .portfolio-header p { color: var(--brown-mid); margin: 0; }

  .portfolio-body { padding-top: 2rem; padding-bottom: 4rem; }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .filter-btn {
    padding: 0.45em 1.2em;
    border: 2px solid var(--border);
    border-radius: 999px;
    background: var(--cream-light);
    color: var(--brown);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .filter-btn:hover { border-color: var(--orange); }
  .filter-btn.active {
    background: var(--orange);
    border-color: var(--orange);
    color: var(--cream-light);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.2rem;
  }

  .artwork-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .artwork-card {
    display: block;
    color: var(--brown);
  }

  .artwork-img-wrap {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 10px;
    border: 2px solid var(--border);
    background: var(--cream-dark);
  }
  .artwork-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.25s;
    display: block;
  }
  .artwork-placeholder {
    width: 100%;
    height: 100%;
    background: var(--cream-dark);
  }

  .artwork-overlay {
    position: absolute;
    inset: 0;
    background: rgba(245, 230, 200, 0.92);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.25s;
    color: var(--brown);
    padding: 1.2rem;
    text-align: center;
    gap: 0.25rem;
  }
  .overlay-medium { font-weight: 800; font-size: 0.9rem; }
  .overlay-year { font-size: 0.85rem; color: var(--brown-mid); }
  .overlay-desc {
    font-size: 0.8rem;
    margin: 0.4rem 0 0;
    line-height: 1.4;
    color: var(--brown-mid);
  }
  .overlay-link-hint {
    margin-top: 0.6rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--orange);
  }

  .artwork-card:hover .artwork-overlay { opacity: 1; }
  .artwork-card:hover .artwork-img-wrap img { transform: scale(1.04); }
  .artwork-card:hover .artwork-img-wrap,
  .artwork-link:hover .artwork-img-wrap { border-color: var(--orange); }

  .artwork-title {
    margin: 0.5rem 0 0 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--brown-mid);
    line-height: 1.3;
  }

  .empty-msg {
    text-align: center;
    color: var(--brown-mid);
    font-style: italic;
    padding: 3rem 0;
  }

  @media (max-width: 600px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
  }
</style>
