---
import Base from '../../layouts/Base.astro';
import { SHOP_ITEMS, CATEGORY_LABELS, getEtsyUrl } from '../../data/shop';
import type { ShopCategory } from '../../data/shop';

const categories = Object.entries(CATEGORY_LABELS) as [ShopCategory, string][];
---

<Base title="Shop — Force of Nature Press" description="Nature-themed stickers, keychains, earrings, linocut prints, and more. Handmade in the Pacific Northwest." fullWidth>

  <div class="shop-header">
    <div class="container">
      <h1>Shop</h1>
      <p>All products ship from the Pacific Northwest. Click any item to purchase on Etsy.</p>
    </div>
  </div>

  <div class="container shop-body">

    <!-- CATEGORY FILTER -->
    <div class="filter-bar" role="tablist" aria-label="Filter by category">
      <button class="filter-btn active" data-cat="all" role="tab" aria-selected="true">All</button>
      {categories.map(([cat, label]) => (
        <button class="filter-btn" data-cat={cat} role="tab" aria-selected="false">{label}</button>
      ))}
    </div>

    <!-- PRODUCT GRID -->
    <div class="product-grid" id="productGrid">
      {SHOP_ITEMS.map(item => (
        <a
          href={getEtsyUrl(item)}
          target="_blank"
          rel="noopener noreferrer"
          class="product-card"
          data-category={item.category}
          aria-label={`${item.title} — $${item.price.toFixed(2)} — opens on Etsy`}
        >
          <div class="product-img-wrap">
            <img src={item.image} alt={item.title} loading="lazy" width="400" height="400" />
          </div>
          <div class="product-info">
            <span class="product-title">{item.title}</span>
            <span class="product-price">${item.price.toFixed(2)}</span>
          </div>
        </a>
      ))}
    </div>

    <p class="etsy-note">
      All listings open on <a href="https://www.etsy.com/shop/forceofnaturepress" target="_blank" rel="noopener noreferrer">Etsy</a>.
    </p>

  </div>
</Base>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.product-card');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat;

      btns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      cards.forEach(card => {
        const show = cat === 'all' || card.dataset.category === cat;
        card.style.display = show ? '' : 'none';
      });
    });
  });
</script>

<style>
  .shop-header {
    background: var(--cream-light);
    border-bottom: 2px solid var(--border);
    padding: 2.5rem 0 1.5rem;
  }
  .shop-header h1 { margin-bottom: 0.3em; }
  .shop-header p { color: var(--brown-mid); margin: 0; }

  .shop-body { padding-top: 2rem; padding-bottom: 4rem; }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .filter-btn {
    padding: 0.45em 1em;
    border: 2px solid var(--border);
    border-radius: 999px;
    background: var(--cream-light);
    color: var(--brown);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .filter-btn:hover {
    border-color: var(--orange);
    background: rgba(200, 120, 48, 0.08);
  }
  .filter-btn.active {
    background: var(--orange);
    border-color: var(--orange);
    color: var(--cream-light);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.2rem;
  }
  .product-card {
    display: block;
    text-decoration: none;
    color: var(--brown);
    border: 2px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--cream-light);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .product-card:hover {
    border-color: var(--orange);
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
    color: var(--brown);
  }
  .product-img-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--cream-dark);
  }
  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.2s;
    display: block;
  }
  .product-card:hover .product-img-wrap img { transform: scale(1.04); }
  .product-info {
    padding: 0.7rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .product-title {
    font-weight: 700;
    font-size: 0.85rem;
    line-height: 1.3;
    color: var(--brown);
  }
  .product-price {
    font-weight: 800;
    color: var(--teal);
    font-size: 0.9rem;
  }

  .etsy-note {
    text-align: center;
    color: var(--brown-mid);
    font-size: 0.9rem;
    margin-top: 2.5rem;
  }

  @media (max-width: 600px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
  }
</style>
