---
import Base from '../../layouts/Base.astro';
import { SHOP_ITEMS, CATEGORY_LABELS, getEtsyUrl } from '../../data/shop';
import { fetchEtsyListings } from '../../lib/etsy';
import type { ShopCategory } from '../../data/shop';

let shopItems = SHOP_ITEMS;
try {
  shopItems = await fetchEtsyListings();
} catch (e) {
  console.warn('[shop] Etsy API unavailable, using static data:', e);
}

const categories = Object.entries(CATEGORY_LABELS) as [ShopCategory, string][];
---

<Base title="Shop — Force of Nature Press" description="Nature-themed stickers, keychains, earrings, linocut prints, and more. Handmade in the Pacific Northwest." fullWidth>

  <div class="shop-header">
    <div class="container">
      <h1>Shop</h1>
      <p>All products ship from the Pacific Northwest. Click any item to purchase on Etsy.</p>
    </div>
  </div>

  <div class="container shop-body">

    <!-- CONTROLS ROW -->
    <div class="controls-row">
      <div class="filter-bar" role="tablist" aria-label="Filter by category">
        <button class="filter-btn active" data-cat="all" role="tab" aria-selected="true">All</button>
        {categories.map(([cat, label]) => (
          <button class="filter-btn" data-cat={cat} role="tab" aria-selected="false">{label}</button>
        ))}
      </div>

      <div class="sort-search">
        <input
          type="search"
          id="shopSearch"
          placeholder="Search..."
          aria-label="Search products"
          class="shop-search"
        />
        <select id="shopSort" class="shop-sort" aria-label="Sort products">
          <option value="default">Sort: Default</option>
          <option value="alpha-asc">A → Z</option>
          <option value="alpha-desc">Z → A</option>
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
        </select>
        <select id="shopPerPage" class="shop-sort" aria-label="Items per page">
          <option value="20">20 per page</option>
          <option value="40">40 per page</option>
          <option value="60">60 per page</option>
          <option value="99999">All</option>
        </select>
      </div>
    </div>

    <!-- PRODUCT GRID -->
    <div class="product-grid" id="productGrid">
      {shopItems.map((item, i) => (
        <a
          href={getEtsyUrl(item)}
          target="_blank"
          rel="noopener noreferrer"
          class="product-card"
          data-category={item.category}
          data-title={item.title.toLowerCase()}
          data-price={item.price}
          data-index={i}
          aria-label={`${item.title} — $${item.price.toFixed(2)} — opens on Etsy`}
        >
          <div class="product-img-wrap">
            <img src={item.image} alt={item.title} loading="lazy" width="400" height="400" />
          </div>
          <div class="product-info">
            <span class="product-title">{item.title}</span>
            <span class="product-price">${item.price.toFixed(2)}</span>
          </div>
        </a>
      ))}
    </div>

    <p class="no-results" id="noResults" style="display:none">No products match your search.</p>

    <div class="pagination" id="pagination"></div>

    <p class="etsy-note">
      All listings open on <a href="https://www.etsy.com/shop/forceofnaturepress" target="_blank" rel="noopener noreferrer">Etsy</a>.
    </p>

  </div>
</Base>

<script>
  const grid = document.getElementById('productGrid')!;
  const noResults = document.getElementById('noResults')!;
  const paginationEl = document.getElementById('pagination')!;
  const searchInput = document.getElementById('shopSearch') as HTMLInputElement;
  const sortSelect = document.getElementById('shopSort') as HTMLSelectElement;
  const perPageSelect = document.getElementById('shopPerPage') as HTMLSelectElement;
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');

  let activeCat = 'all';
  let currentPage = 1;

  function applyFilters(resetPage = true) {
    if (resetPage) currentPage = 1;

    const query = searchInput.value.toLowerCase().trim();
    const sort = sortSelect.value;
    const perPage = Number(perPageSelect.value);

    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.product-card'));

    cards.sort((a, b) => {
      if (sort === 'alpha-asc')  return a.dataset.title!.localeCompare(b.dataset.title!);
      if (sort === 'alpha-desc') return b.dataset.title!.localeCompare(a.dataset.title!);
      if (sort === 'price-asc')  return Number(a.dataset.price) - Number(b.dataset.price);
      if (sort === 'price-desc') return Number(b.dataset.price) - Number(a.dataset.price);
      return Number(a.dataset.index) - Number(b.dataset.index);
    });

    // Re-append sorted, collect matching cards
    const matching: HTMLElement[] = [];
    cards.forEach(card => {
      grid.appendChild(card);
      const matchesCat = activeCat === 'all' || card.dataset.category === activeCat;
      const matchesSearch = !query || card.dataset.title!.includes(query);
      if (matchesCat && matchesSearch) matching.push(card);
    });

    const totalPages = Math.max(1, Math.ceil(matching.length / perPage));
    if (currentPage > totalPages) currentPage = totalPages;

    const start = (currentPage - 1) * perPage;
    const end = start + perPage;

    cards.forEach(card => { card.style.display = 'none'; });
    matching.forEach((card, i) => {
      card.style.display = (i >= start && i < end) ? '' : 'none';
    });

    noResults.style.display = matching.length === 0 ? '' : 'none';
    renderPagination(totalPages);
  }

  function renderPagination(totalPages: number) {
    paginationEl.innerHTML = '';
    if (totalPages <= 1) return;

    const prev = document.createElement('button');
    prev.className = 'page-btn' + (currentPage === 1 ? ' disabled' : '');
    prev.textContent = '←';
    prev.disabled = currentPage === 1;
    prev.addEventListener('click', () => { currentPage--; applyFilters(false); window.scrollTo({ top: 0, behavior: 'smooth' }); });
    paginationEl.appendChild(prev);

    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
      btn.textContent = String(i);
      btn.addEventListener('click', () => { currentPage = i; applyFilters(false); window.scrollTo({ top: 0, behavior: 'smooth' }); });
      paginationEl.appendChild(btn);
    }

    const next = document.createElement('button');
    next.className = 'page-btn' + (currentPage === totalPages ? ' disabled' : '');
    next.textContent = '→';
    next.disabled = currentPage === totalPages;
    next.addEventListener('click', () => { currentPage++; applyFilters(false); window.scrollTo({ top: 0, behavior: 'smooth' }); });
    paginationEl.appendChild(next);
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat!;
      filterBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      applyFilters();
    });
  });

  searchInput.addEventListener('input', applyFilters);
  sortSelect.addEventListener('change', applyFilters);
  perPageSelect.addEventListener('change', applyFilters);

  applyFilters();
</script>

<style>
  .shop-header {
    background: var(--cream-light);
    border-bottom: 2px solid var(--border);
    padding: 2.5rem 0 1.5rem;
  }
  .shop-header h1 { margin-bottom: 0.3em; }
  .shop-header p { color: var(--brown-mid); margin: 0; }

  .shop-body { padding-top: 2rem; padding-bottom: 4rem; }

  .controls-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    flex: 1;
  }

  .filter-btn {
    padding: 0.45em 1em;
    border: 2px solid var(--border);
    border-radius: 999px;
    background: var(--cream-light);
    color: var(--brown);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .filter-btn:hover {
    border-color: var(--orange);
    background: rgba(200, 120, 48, 0.08);
  }
  .filter-btn.active {
    background: var(--orange);
    border-color: var(--orange);
    color: var(--cream-light);
  }

  .sort-search {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .shop-search, .shop-sort {
    font-family: inherit;
    font-size: 0.88rem;
    color: var(--brown);
    background: var(--cream-light);
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 0.4em 0.7em;
    transition: border-color 0.15s;
  }
  .shop-search { width: 160px; }
  .shop-search:focus, .shop-sort:focus {
    outline: none;
    border-color: var(--orange);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.2rem;
  }
  .product-card {
    display: block;
    text-decoration: none;
    color: var(--brown);
    border: 2px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--cream-light);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .product-card:hover {
    border-color: var(--orange);
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
    color: var(--brown);
  }
  .product-img-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--cream-dark);
  }
  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.2s;
    display: block;
  }
  .product-card:hover .product-img-wrap img { transform: scale(1.04); }
  .product-info {
    padding: 0.7rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .product-title {
    font-weight: 700;
    font-size: 0.85rem;
    line-height: 1.3;
    color: var(--brown);
  }
  .product-price {
    font-weight: 800;
    color: var(--teal);
    font-size: 0.9rem;
  }

  .no-results {
    text-align: center;
    color: var(--brown-mid);
    font-style: italic;
    padding: 2rem 0;
  }

  .pagination {
    display: flex;
    justify-content: center;
    gap: 0.4rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .page-btn {
    min-width: 2.2rem;
    padding: 0.4em 0.7em;
    border: 2px solid var(--border);
    border-radius: 8px;
    background: var(--cream-light);
    color: var(--brown);
    font-family: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .page-btn:hover:not(.disabled) {
    border-color: var(--orange);
    background: rgba(200, 120, 48, 0.08);
  }
  .page-btn.active {
    background: var(--orange);
    border-color: var(--orange);
    color: var(--cream-light);
  }
  .page-btn.disabled {
    opacity: 0.4;
    cursor: default;
  }

  .etsy-note {
    text-align: center;
    color: var(--brown-mid);
    font-size: 0.9rem;
    margin-top: 2.5rem;
  }

  @media (max-width: 600px) {
    .product-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
    .sort-search { width: 100%; }
    .shop-search { flex: 1; }
  }
</style>
