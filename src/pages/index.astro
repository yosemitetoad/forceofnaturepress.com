---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { ETSY_SHOP_URL, SITE_DESCRIPTION } from '../consts';
import { SHOP_ITEMS, getEtsyUrl } from '../data/shop';
import { getAllShopItems, getPageContentMulti } from '../lib/db';
import { mdInline } from '../lib/markdown';

const defaultFeaturedSkus = ['4467858004', 'FLYAGRCGLD', 'PSSMKYCHN', 'RACLINO', 'BEECLOVERSTCKR', 'OTTERPRNT', 'SOCKEYEPIN', 'HRBRSLMGNT'];

let allItems = SHOP_ITEMS;
let introP1 = 'Force of Nature Press is a small, independent art shop based in the Pacific Northwest. We create nature-inspired stickers, linocut prints, keychains, earrings, and other handmade goods celebrating the beauty of the natural world.';
let introP2 = 'Every piece is designed and produced by hand with care -- from the original illustrations to the final product. Whether you\'re drawn to mossy forests, ocean creatures, or backyard bugs, there\'s something here for you.';
let featuredSkus = defaultFeaturedSkus;
let whatsNew = [
  { title: 'Play Dress Up Beetle!', text: 'Our very first browser game is live! Dress up your own beetle with hats, accessories, and more.', linkText: 'Head over to Games to try it out!', linkUrl: '/games' },
  { title: 'New Stickers & Prints', text: 'Fresh designs are hitting the shop regularly -- keep an eye out for new nature-themed goodies.', linkText: 'Browse the latest drops.', linkUrl: '/shop' },
];

try {
  const db = Astro.locals.runtime.env.DB;
  if (db) {
    const dbItems = await getAllShopItems(db);
    if (dbItems.length > 0) allItems = dbItems;

    const content = await getPageContentMulti(db, ['home_intro_p1', 'home_intro_p2', 'home_featured_skus', 'home_whats_new']);
    if (content.home_intro_p1) introP1 = content.home_intro_p1;
    if (content.home_intro_p2) introP2 = content.home_intro_p2;
    if (content.home_featured_skus) featuredSkus = content.home_featured_skus.split(',').map(s => s.trim()).filter(Boolean);
    if (content.home_whats_new) try { whatsNew = JSON.parse(content.home_whats_new); } catch {}
  }
} catch (e) {
  console.warn('[home] D1 unavailable, using static data:', e);
}

const featured = featuredSkus.map(sku => allItems.find(i => i.sku === sku)).filter(Boolean);

const introP1Html = await mdInline(introP1);
const introP2Html = await mdInline(introP2);
const whatsNewHtml = await Promise.all(whatsNew.map(async item => ({
  ...item,
  textHtml: await mdInline(item.text),
})));
---

<Base title="Force of Nature Press" description={SITE_DESCRIPTION} fullWidth>

  <div class="home-wrap">
    <div class="home-layout container">

      <!-- LEFT: About box -->
      <div class="about-box">
        <div class="about-top">
          <div class="logo-block">
            <img src="/beetleshopiconsquare.webp" alt="Force of Nature Press beetle logo" class="about-logo" />
          </div>
          <div class="about-text">
            <h1>Force of Nature Press</h1>
            <p><Fragment set:html={introP1Html} /></p>
            <p><Fragment set:html={introP2Html} /></p>
            <div class="about-links">
              <a href={ETSY_SHOP_URL} target="_blank" rel="noopener noreferrer" class="btn btn-primary">Visit the Shop on Etsy</a>
              <a href="/about" class="btn btn-outline">Learn More</a>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Carousel -->
      <div class="carousel-wrap">
        <h2>Featured Products:</h2>
        <div class="carousel" id="carousel">
          <div class="carousel-track" id="carouselTrack">
            {featured.map(item => (
              <a href={getEtsyUrl(item)} target="_blank" rel="noopener noreferrer" class="carousel-slide" data-sku={item.sku}>
                <img src={item.image} alt={item.title} loading="lazy" />
                <div class="carousel-caption">
                  <span class="carousel-title">{item.title}</span>
                  <span class="carousel-price">${item.price.toFixed(2)}</span>
                </div>
              </a>
            ))}
          </div>
          <button class="carousel-btn carousel-prev" id="carouselPrev" aria-label="Previous product"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
          <button class="carousel-btn carousel-next" id="carouselNext" aria-label="Next product"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg></button>
          <div class="carousel-dots" id="carouselDots">
            {featured.map((_, i) => (
              <button class={`carousel-dot ${i === 0 ? 'active' : ''}`} data-slide={i} aria-label={`Go to slide ${i + 1}`}></button>
            ))}
          </div>
        </div>
      </div>

      <!-- What's New — full width below -->
      <div class="whats-new">
        <h2>What's New:</h2>
        {whatsNewHtml.map(item => (
          <div class="news-item">
            <h3>{item.title}</h3>
            <p>
              <Fragment set:html={item.textHtml} />
              {item.linkUrl && <a href={item.linkUrl}>{' '}{item.linkText}</a>}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>

</Base>

<script>
  function initCarousel() {
    const track = document.getElementById('carouselTrack');
    const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
    const prev = document.getElementById('carouselPrev');
    const next = document.getElementById('carouselNext');
    if (!track || !prev || !next) return;

    const slides = track.querySelectorAll('.carousel-slide');
    const total = slides.length;
    let current = 0;
    let autoTimer: ReturnType<typeof setInterval>;

    function goTo(i: number) {
      current = ((i % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, idx) => d.classList.toggle('active', idx === current));
    }

    prev.addEventListener('click', () => { goTo(current - 1); resetAuto(); });
    next.addEventListener('click', () => { goTo(current + 1); resetAuto(); });
    dots.forEach(d => d.addEventListener('click', () => {
      goTo(Number(d.dataset.slide));
      resetAuto();
    }));

    function resetAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => goTo(current + 1), 5000);
    }

    resetAuto();
  }

function initHome() {
  initCarousel();

  // ── Analytics tracking ──
  function track(type: string, sku?: string) {
    fetch('/api/track', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ type, sku, page: '/' }),
    }).catch(() => {});
  }

  track('view');

  document.getElementById('carouselTrack')?.addEventListener('click', (e) => {
    const slide = (e.target as HTMLElement).closest('.carousel-slide') as HTMLElement | null;
    if (slide?.dataset.sku) track('click', slide.dataset.sku);
  });
}
initHome();
document.addEventListener('astro:after-swap', initHome);
</script>

<style>
  /* Full-page star background */
  .home-wrap {
    background: url('/plainstarbanner.webp') center / cover no-repeat;
    min-height: calc(100vh - 72px - 120px);
    padding: 2.5rem 0 4rem;
    margin-bottom: -4rem;
  }

  .home-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: min-content 1fr;
    gap: 2rem;
  }

  /* About box — left column */
  .about-box {
    background: rgba(240, 230, 208, 0.88);
    border-radius: 14px;
    padding: 1.5rem;
    border: 2px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .about-top {
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: space-between;
  }

  .logo-block {
    background: var(--brown);
    border-radius: 0;
    padding: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    margin: 0 auto 1rem;
  }

  .about-logo {
    width: 145px;
    height: 145px;
    border-radius: 0;
    display: block;
  }

  .about-text h1 {
    font-size: 1.6rem;
    color: var(--brown);
    margin-bottom: 0.4rem;
  }

  .about-text p {
    font-size: 0.88rem;
    color: var(--brown);
    line-height: 1.6;
    margin-bottom: 0.7em;
  }

  .about-links {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 0.3rem;
  }

  /* Carousel — right column */
  .carousel-wrap {
    display: flex;
    flex-direction: column;
    background: rgba(240, 230, 208, 0.88);
    border-radius: 14px;
    padding: 1.5rem;
    border: 2px solid var(--border);
  }

  .carousel-wrap h2 {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    color: var(--brown);
  }

  .carousel {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    background: var(--cream-dark);
  }

  .carousel-track {
    display: flex;
    transition: transform 0.4s ease;
  }

  .carousel-slide {
    min-width: 100%;
    display: block;
    text-decoration: none;
    color: var(--brown);
    position: relative;
  }

  .carousel-slide img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .carousel-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(45, 31, 14, 0.75);
    color: var(--cream-light);
    padding: 0.6rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .carousel-title {
    font-weight: 700;
    font-size: 0.9rem;
  }

  .carousel-price {
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--cream-light);
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(45, 31, 14, 0.6);
    color: var(--cream-light);
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .carousel-btn:hover { background: rgba(45, 31, 14, 0.85); }
  .carousel-prev { left: 8px; }
  .carousel-next { right: 8px; }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    padding: 0.6rem 0 0.4rem;
    background: transparent;
  }

  .carousel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--brown-mid);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.15s;
  }
  .carousel-dot.active {
    background: var(--orange);
    border-color: var(--orange);
  }

  /* What's New — spans both columns */
  .whats-new {
    grid-column: 1 / -1;
    background: rgba(240, 230, 208, 0.88);
    border-radius: 14px;
    padding: 2rem 2rem;
    border: 2px solid var(--border);
  }

  .whats-new h2 {
    font-size: 1.8rem;
    margin-bottom: 1.2rem;
    color: var(--brown);
  }

  .news-item {
    margin-bottom: 1rem;
  }
  .news-item:last-child { margin-bottom: 0; }

  .news-item h3 {
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
    color: var(--brown);
  }

  .news-item p {
    font-size: 0.9rem;
    color: var(--brown-mid);
    margin: 0;
    line-height: 1.6;
  }
  .news-item a {
    color: var(--teal);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .home-layout {
      grid-template-columns: 1fr;
    }
    .whats-new {
      grid-column: 1;
    }
  }

  @media (max-width: 600px) {
    .home-wrap {
      padding: 1.5rem 0 2.5rem;
    }
    .about-text h1 {
      font-size: 1.5rem;
    }
  }
</style>
