---
import Base from '../layouts/Base.astro';
import { ETSY_SHOP_URL, SITE_DESCRIPTION } from '../consts';
import { SHOP_ITEMS, getEtsyUrl } from '../data/shop';

const featured = SHOP_ITEMS.filter(i =>
  ['SEALSTCKR', 'LUNAMOTH', 'RACLINO', 'FLYAGRCSTCKR', 'ORCA', 'OTTERPRNT'].includes(i.sku)
);
---

<Base title="Force of Nature Press" description={SITE_DESCRIPTION} fullWidth>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <img src="/beetleshopiconsquare.png" alt="Force of Nature Press beetle logo" class="hero-logo" />
      <h1>Force of Nature Press</h1>
      <p class="hero-tagline">
        Nature-themed art, stickers, and linocut prints.<br/>Handmade in the Pacific Northwest.
      </p>
      <div class="hero-btns">
        <a href="/shop" class="btn btn-primary">Visit the Shop</a>
        <a href="/games" class="btn btn-secondary">Play Dress Up Beetle!</a>
      </div>
    </div>
  </section>

  <!-- SECTION TEASERS -->
  <section class="teasers container">
    <a href="/shop" class="teaser">
      <div class="teaser-icon">🛒</div>
      <h3>Shop</h3>
      <p>Stickers, keychains, earrings, linocut prints, and more.</p>
    </a>
    <a href="/portfolio" class="teaser">
      <div class="teaser-icon">🎨</div>
      <h3>Portfolio</h3>
      <p>Browse the full gallery of original nature illustrations.</p>
    </a>
    <a href="/blog" class="teaser">
      <div class="teaser-icon">📖</div>
      <h3>Blog</h3>
      <p>Behind the scenes, new releases, and nature notes.</p>
    </a>
    <a href="/games" class="teaser">
      <div class="teaser-icon">🎮</div>
      <h3>Games</h3>
      <p>Play Dress Up Beetle! and future interactive projects.</p>
    </a>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="featured container">
    <div class="section-title">
      <h2>Featured Products</h2>
      <p>A few favorites — <a href="/shop">see the full shop</a></p>
    </div>
    <div class="featured-grid">
      {featured.map(item => (
        <a href={getEtsyUrl(item)} target="_blank" rel="noopener noreferrer" class="product-card">
          <div class="product-img-wrap">
            <img src={item.image} alt={item.title} loading="lazy" />
          </div>
          <div class="product-info">
            <span class="product-title">{item.title}</span>
            <span class="product-price">${item.price.toFixed(2)}</span>
          </div>
        </a>
      ))}
    </div>
    <div class="featured-cta">
      <a href="/shop" class="btn btn-primary">Browse All Products</a>
      <a href={ETSY_SHOP_URL} target="_blank" rel="noopener noreferrer" class="btn btn-outline">Visit Etsy Shop</a>
    </div>
  </section>

</Base>

<style>
  .hero {
    background: var(--cream-light);
    border-bottom: 2px solid var(--border);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
  }
  .hero-inner { max-width: 600px; margin: 0 auto; }
  .hero-logo {
    width: 140px;
    height: 140px;
    border-radius: 16px;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 20px var(--shadow);
  }
  .hero h1 { font-size: 2.8rem; margin-bottom: 0.5rem; }
  .hero-tagline {
    font-size: 1.1rem;
    color: var(--brown-mid);
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .hero-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .teasers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    padding-top: 3rem;
    padding-bottom: 1rem;
  }
  .teaser {
    background: var(--cream-light);
    border: 2px solid var(--border);
    border-radius: 12px;
    padding: 1.8rem 1.4rem;
    text-decoration: none;
    color: var(--brown);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
    display: block;
  }
  .teaser:hover {
    border-color: var(--orange);
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
    color: var(--brown);
  }
  .teaser-icon { font-size: 2rem; margin-bottom: 0.6rem; }
  .teaser h3 { font-size: 1.2rem; margin-bottom: 0.4rem; color: var(--brown); }
  .teaser p { font-size: 0.9rem; color: var(--brown-mid); margin: 0; line-height: 1.5; }

  .featured { padding-top: 3rem; padding-bottom: 4rem; }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .product-card {
    display: block;
    text-decoration: none;
    color: var(--brown);
    border: 2px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--cream-light);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .product-card:hover {
    border-color: var(--orange);
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
    color: var(--brown);
  }
  .product-img-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--cream-dark);
  }
  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform 0.2s;
    display: block;
  }
  .product-card:hover .product-img-wrap img { transform: scale(1.04); }
  .product-info {
    padding: 0.8rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .product-title { font-weight: 700; font-size: 0.9rem; line-height: 1.3; }
  .product-price { font-weight: 800; color: var(--teal); white-space: nowrap; font-size: 0.95rem; }

  .featured-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .teasers { grid-template-columns: repeat(2, 1fr); }
    .featured-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .teasers { grid-template-columns: 1fr; }
    .featured-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
    .hero h1 { font-size: 2rem; }
  }
</style>
