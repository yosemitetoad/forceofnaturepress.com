---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { getAllWholesaleItems, getWholesaleCategories } from '../../../lib/db';

const db = Astro.locals.runtime.env.DB;
const [items, categories] = await Promise.all([getAllWholesaleItems(db), getWholesaleCategories(db)]);

const publishedCount = items.filter(i => i.published).length;

// Build a map for fast label lookup, and group items by effective category
const catMap = new Map(categories.map(c => [c.slug, c.label]));

const grouped = new Map<string, typeof items>();
for (const item of items) {
  const cat = item.category || 'other';
  if (!grouped.has(cat)) grouped.set(cat, []);
  grouped.get(cat)!.push(item);
}

// Categories in DB order first; uncategorized (not in DB) appended at end
const sortedCategories = [
  ...categories,
  // any item categories not yet in the categories table
  ...[...grouped.keys()]
    .filter(k => !catMap.has(k))
    .map(k => ({ slug: k, label: k, sortOrder: 999 })),
];

function getCatLabel(slug: string) {
  return catMap.get(slug) ?? slug;
}
---

<Admin title="Wholesale Catalog">
  <div class="page-header">
    <div>
      <h1>Wholesale Catalog</h1>
      <p class="item-count">{items.length} item{items.length !== 1 ? 's' : ''} total &mdash; {publishedCount} published</p>
    </div>
    <div class="header-actions">
      <a href="/admin/pages/wholesale" class="btn btn-outline">Page Content &amp; Password</a>
      <button id="syncBtn" class="btn btn-sync" type="button">Sync from Shop</button>
      <span id="syncStatus" class="sync-status"></span>
      <a href="/admin/wholesale/new" class="btn btn-primary">+ Add Item</a>
    </div>
  </div>

  <div class="top-controls">
    <p class="help-text">Check items to batch edit. Drag category headers or item rows to reorder. Only published items appear on the public <a href="/wholesale" target="_blank">/wholesale</a> page.</p>
    <div class="new-cat-wrap">
      <button id="newCatToggle" class="btn btn-outline btn-sm-action" type="button">+ New Category</button>
      <div id="newCatForm" class="new-cat-form" hidden>
        <input id="newCatLabel" type="text" placeholder="Category name..." />
        <button id="newCatSave" class="btn btn-primary btn-sm-action" type="button">Create</button>
        <button id="newCatCancel" class="btn btn-outline btn-sm-action" type="button">Cancel</button>
        <span id="newCatStatus" class="inline-status"></span>
      </div>
    </div>
  </div>

  {items.length === 0 && categories.length === 0 && (
    <div class="empty-state">
      <p>No items yet. <a href="/admin/wholesale/new">Add your first wholesale item.</a></p>
    </div>
  )}

  <div id="categoryContainer">
    {sortedCategories.map(cat => {
      const catItems = grouped.get(cat.slug) ?? [];
      return (
        <div class="category-group" data-cat={cat.slug}>
          <div class="category-header">
            <span class="cat-drag-handle" title="Drag to reorder category">⠿</span>
            <label class="select-all-label" title="Select all in category">
              <input type="checkbox" class="select-all-cb" data-cat={cat.slug} />
            </label>
            <div class="cat-name-wrap">
              <span class="category-name" data-cat={cat.slug}>{getCatLabel(cat.slug)}</span>
              <input class="category-name-input" data-cat={cat.slug} value={getCatLabel(cat.slug)} hidden />
              <button class="btn-rename" data-cat={cat.slug} title="Rename" type="button">✎</button>
              <button class="btn-rename-save" data-cat={cat.slug} type="button" hidden>Save</button>
              <button class="btn-rename-cancel" data-cat={cat.slug} type="button" hidden>Cancel</button>
              <span class="rename-status" data-cat={cat.slug}></span>
            </div>
            <span class="category-count">{catItems.length} item{catItems.length !== 1 ? 's' : ''}</span>
            <button class="btn-delete-cat" data-cat={cat.slug} data-count={catItems.length} title="Delete category" type="button">✕</button>
          </div>

          <div class="cat-desc-row" data-cat={cat.slug}>
            <span class="cat-desc-text" data-cat={cat.slug}>{cat.description || ''}</span>
            {!cat.description && <span class="cat-desc-empty">No description — </span>}
            <button class="btn-edit-desc" data-cat={cat.slug} type="button">edit description</button>
            <textarea class="cat-desc-input" data-cat={cat.slug} rows="2" hidden>{cat.description || ''}</textarea>
            <button class="btn-desc-save" data-cat={cat.slug} type="button" hidden>Save</button>
            <button class="btn-desc-cancel" data-cat={cat.slug} type="button" hidden>Cancel</button>
            <span class="desc-status" data-cat={cat.slug}></span>
          </div>

          <div class="cat-group-row" data-cat={cat.slug}>
            <span class="cat-group-label">Group:</span>
            <span class="cat-group-text" data-cat={cat.slug}>{cat.group || ''}</span>
            {!cat.group && <span class="cat-group-empty">none — </span>}
            <button class="btn-edit-group" data-cat={cat.slug} type="button">edit</button>
            <input type="text" class="cat-group-input" data-cat={cat.slug} value={cat.group || ''} placeholder="e.g. Paper Goods" hidden />
            <button class="btn-group-save" data-cat={cat.slug} type="button" hidden>Save</button>
            <button class="btn-group-cancel" data-cat={cat.slug} type="button" hidden>Cancel</button>
            <span class="group-status" data-cat={cat.slug}></span>
          </div>

          <div class="item-list" data-category={cat.slug}>
            {catItems.map(item => (
              <div class="item-row" draggable="true" data-id={item.id}>
                <label class="row-check-label">
                  <input type="checkbox" class="item-cb" data-id={item.id} data-cat={cat.slug} />
                </label>
                <span class="drag-handle" title="Drag to reorder item">⠿</span>
                <img src={item.image} alt="" class="thumb" />
                <div class="item-info">
                  <span class="item-title">{item.title}</span>
                  <span class="item-sku">{item.sku}</span>
                </div>
                <div class="item-prices">
                  <span class="price-label">Wholesale</span>
                  <span class="price-value" data-field="wholesalePrice">${item.wholesalePrice.toFixed(2)}</span>
                </div>
                <div class="item-prices">
                  <span class="price-label">RRP</span>
                  <span class="price-value" data-field="rrp">${item.rrp.toFixed(2)}</span>
                </div>
                <div class="item-prices">
                  <span class="price-label">MOQ</span>
                  <span class="price-value" data-field="moq">{item.moq}</span>
                </div>
                <button
                  class={`status-badge ${item.published ? 'published' : 'draft'}`}
                  data-id={item.id}
                  data-published={item.published ? 'true' : 'false'}
                  title="Click to toggle"
                >
                  {item.published ? 'Published' : 'Draft'}
                </button>
                <a href={`/admin/wholesale/${item.id}`} class="btn-sm btn-edit">Edit</a>
                <button class="btn-sm btn-delete" data-id={item.id}>Delete</button>
              </div>
            ))}
            {catItems.length === 0 && (
              <div class="empty-cat-row">No items — move items here or <button type="button" class="btn-delete-cat-empty" data-cat={cat.slug}>delete this category</button>.</div>
            )}
          </div>
        </div>
      );
    })}
  </div>

  {items.length > 0 && (
    <div class="list-actions">
      <button id="saveOrderBtn" class="btn btn-outline">Save Order</button>
      <span id="orderStatus" class="save-status"></span>
    </div>
  )}

  <!-- Batch edit toolbar (fixed bottom, shown when items are selected) -->
  <div id="batchToolbar" class="batch-toolbar" hidden>
    <span class="selection-label" id="selectionCount">0 selected</span>
    <div class="toolbar-fields">
      <div class="toolbar-field">
        <label>Wholesale ($)</label>
        <input type="number" id="batchWholesale" step="0.01" min="0" placeholder="—" />
      </div>
      <div class="toolbar-field">
        <label>RRP ($)</label>
        <input type="number" id="batchRrp" step="0.01" min="0" placeholder="—" />
      </div>
      <div class="toolbar-field">
        <label>MOQ</label>
        <input type="number" id="batchMoq" step="1" min="1" placeholder="—" />
      </div>
      <div class="toolbar-field">
        <label>Move to category</label>
        <select id="batchCategory">
          <option value="">— no change —</option>
          {categories.map(c => (
            <option value={c.slug}>{c.label}</option>
          ))}
        </select>
      </div>
      <button id="batchApplyBtn" class="btn btn-primary">Apply</button>
    </div>
    <div class="toolbar-publish-actions">
      <button id="batchPublishBtn" class="btn btn-toolbar-publish">Publish</button>
      <button id="batchUnpublishBtn" class="btn btn-toolbar-unpublish">Unpublish</button>
    </div>
    <button id="batchClearBtn" class="btn btn-toolbar-clear">Clear</button>
    <span id="batchStatus" class="batch-status-msg"></span>
  </div>
</Admin>

<style>
