  }
  .btn-rename { background: none; border: none; color: #a08060; cursor: pointer; font-size: 0.9rem; padding: 0.1em 0.3em; border-radius: 4px; transition: color 0.1s, background 0.1s; }
  .btn-rename:hover { color: #2d1f0e; background: rgba(0,0,0,0.06); }
