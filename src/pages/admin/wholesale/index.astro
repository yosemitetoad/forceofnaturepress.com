  .btn-edit:hover { background: #d4b896; }
  .btn-delete { background: #b44; color: #faf5ea; }
  .btn-delete:hover { background: #833; }

  .empty-state { background: #faf5ea; border: 2px solid #d4b896; border-radius: 10px; padding: 2rem; text-align: center; color: #6b4a2a; }
  .empty-state a { color: #c87830; font-weight: 700; }

  /* Category groups */
  .category-group { margin-bottom: 1.5rem; }
  .category-group.cat-dragging { opacity: 0.4; }
  .category-group.cat-drag-over { outline: 2px solid #c87830; border-radius: 8px; }

  .category-header {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.45rem 0.8rem; background: #e4d3b8; border: 2px solid #d4b896;
    border-radius: 8px 8px 0 0; border-bottom: none;
