  h1 { font-size: 1.8rem; font-weight: 800; margin: 0 0 0.15rem; }
  .item-count { font-size: 0.88rem; color: #6b4a2a; margin: 0; }
  .header-actions { display: flex; gap: 0.6rem; flex-shrink: 0; }

  .top-controls { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1.2rem; flex-wrap: wrap; }
  .help-text { font-size: 0.88rem; color: #6b4a2a; margin: 0; }
  .help-text a { color: #c87830; }

  .new-cat-wrap { display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0; }
