  .btn-rename-save { color: #3d7a6e; }
  .btn-rename-save:hover { background: rgba(61,122,110,0.1); }
  .btn-rename-cancel { color: #a08060; }
  .rename-status { font-size: 0.75rem; font-weight: 700; }

  .category-count { font-size: 0.78rem; font-weight: 700; color: #6b4a2a; flex-shrink: 0; margin-left: auto; }

  .btn-delete-cat {
    background: none; border: none; color: #c0907a; font-size: 0.85rem;
    cursor: pointer; padding: 0.1em 0.3em; border-radius: 4px; flex-shrink: 0;
    transition: color 0.1s, background 0.1s;
  }
  .btn-delete-cat:hover { color: #b44; background: rgba(180,68,68,0.08); }

  /* Category description row */
  .cat-desc-row {
    background: #f5edd8; border-left: 2px solid #d4b896; border-right: 2px solid #d4b896;
    padding: 0.4rem 0.85rem; display: flex; align-items: flex-start; gap: 0.4rem; flex-wrap: wrap;
    font-size: 0.82rem; color: #5a3e1e; line-height: 1.5;
  }
  .cat-desc-text { flex: 1; min-width: 0; }
  .cat-desc-empty { color: #a08060; font-style: italic; }
  .btn-edit-desc {
    background: none; border: none; color: #a08060; cursor: pointer; font-size: 0.78rem;
    font-family: inherit; padding: 0.05em 0.3em; border-radius: 4px; flex-shrink: 0; white-space: nowrap;
    text-decoration: underline;
  }
  .btn-edit-desc:hover { color: #2d1f0e; }
  .cat-desc-input {
    width: 100%; font-family: inherit; font-size: 0.82rem; color: #2d1f0e;
    background: #faf5ea; border: 2px solid #c87830; border-radius: 5px;
    padding: 0.35em 0.6em; resize: vertical; outline: none; line-height: 1.5;
  }
  .btn-desc-save, .btn-desc-cancel {
    background: none; border: none; font-family: inherit; font-weight: 700; font-size: 0.75rem;
    cursor: pointer; padding: 0.2em 0.5em; border-radius: 5px; flex-shrink: 0;
  }
  .btn-desc-save { color: #3d7a6e; }
  .btn-desc-save:hover { background: rgba(61,122,110,0.1); }
  .btn-desc-cancel { color: #a08060; }
  .desc-status { font-size: 0.75rem; font-weight: 700; }

  /* Category group row */
  .cat-group-row {
    background: #f0ead8; border-left: 2px solid #d4b896; border-right: 2px solid #d4b896;
    padding: 0.3rem 0.85rem; display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;
    font-size: 0.78rem; color: #5a3e1e;
  }
  .cat-group-label { font-weight: 700; color: #8b6040; flex-shrink: 0; }
  .cat-group-text { color: #3d5a4e; font-weight: 700; }
  .cat-group-empty { color: #a08060; font-style: italic; }
  .btn-edit-group {
    background: none; border: none; color: #a08060; cursor: pointer; font-size: 0.75rem;
    font-family: inherit; padding: 0.05em 0.3em; border-radius: 4px; flex-shrink: 0;
    text-decoration: underline;
  }
  .btn-edit-group:hover { color: #2d1f0e; }
  .cat-group-input {
    font-family: inherit; font-size: 0.82rem; color: #2d1f0e;
    background: #faf5ea; border: 2px solid #c87830; border-radius: 5px;
    padding: 0.25em 0.6em; outline: none; width: 220px;
  }
  .btn-group-save, .btn-group-cancel {
    background: none; border: none; font-family: inherit; font-weight: 700; font-size: 0.75rem;
    cursor: pointer; padding: 0.2em 0.5em; border-radius: 5px; flex-shrink: 0;
  }
  .btn-group-save { color: #3d7a6e; }
  .btn-group-save:hover { background: rgba(61,122,110,0.1); }
  .btn-group-cancel { color: #a08060; }
  .group-status { font-size: 0.75rem; font-weight: 700; }

  /* Item list */
  .item-list { background: #faf5ea; border: 2px solid #d4b896; border-radius: 0 0 10px 10px; overflow: hidden; }

  .item-row {
    display: flex; align-items: center; gap: 0.7rem;
    padding: 0.55rem 0.8rem; border-bottom: 1px solid #e4d3b8;
    background: #faf5ea; cursor: default; user-select: none;
    transition: background 0.1s;
  }
  .item-row:last-child { border-bottom: none; }
  .item-row.dragging { opacity: 0.4; }
  .item-row.drag-over { background: rgba(200,120,48,0.08); border-top: 2px solid #c87830; }
  .item-row.selected { background: #fff8ee; }

  .empty-cat-row { padding: 0.8rem 1rem; font-size: 0.85rem; color: #a08060; font-style: italic; }
  .btn-delete-cat-empty { background: none; border: none; color: #c87830; font-weight: 700; font-size: inherit; cursor: pointer; padding: 0; text-decoration: underline; font-style: normal; }

  .row-check-label { display: flex; align-items: center; cursor: pointer; flex-shrink: 0; }
  .row-check-label input[type="checkbox"] { width: 15px; height: 15px; accent-color: #c87830; cursor: pointer; margin: 0; }

  .drag-handle { cursor: grab; color: #a08060; font-size: 1.1rem; flex-shrink: 0; }
  .drag-handle:active { cursor: grabbing; }
  .thumb { width: 44px; height: 44px; object-fit: cover; border-radius: 6px; flex-shrink: 0; }

  .item-info { flex: 1; min-width: 0; }
  .item-title { display: block; font-weight: 700; font-size: 0.88rem; color: #2d1f0e; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .item-sku { display: block; font-size: 0.74rem; color: #a08060; }

  .item-prices { text-align: center; flex-shrink: 0; min-width: 60px; }
  .price-label { display: block; font-size: 0.66rem; font-weight: 700; color: #a08060; text-transform: uppercase; letter-spacing: 0.05em; }
  .price-value { display: block; font-size: 0.86rem; font-weight: 700; color: #2d1f0e; }

  .status-badge { flex-shrink: 0; padding: 0.25em 0.65em; border-radius: 999px; font-family: inherit; font-size: 0.73rem; font-weight: 700; cursor: pointer; border: none; }
  .status-badge.published { background: #3d7a6e; color: #faf5ea; }
  .status-badge.published:hover { background: #2d5a50; }
  .status-badge.draft { background: #e4d3b8; color: #6b4a2a; }
  .status-badge.draft:hover { background: #d4b896; }

  .list-actions { margin-top: 1rem; display: flex; align-items: center; gap: 1rem; }
  .save-status { font-size: 0.9rem; font-weight: 700; }
  .save-status.success { color: #3d7a6e; }
  .save-status.error { color: #b44; }

  /* Batch toolbar */
  .batch-toolbar {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 200;
    background: #2d1f0e; color: #faf5ea;
    padding: 0.7rem 1.5rem;
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    box-shadow: 0 -4px 20px rgba(45,31,14,0.35);
  }
  .batch-toolbar[hidden] { display: none; }
  .selection-label { font-weight: 800; font-size: 0.88rem; color: #e4d3b8; flex-shrink: 0; }
  .toolbar-fields { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; flex: 1; }
  .toolbar-field { display: flex; flex-direction: column; gap: 0.12rem; }
  .toolbar-field label { font-size: 0.66rem; font-weight: 700; color: #a08060; text-transform: uppercase; letter-spacing: 0.05em; }
  .toolbar-field input, .toolbar-field select {
    padding: 0.38em 0.6em; border: 1.5px solid #6b4a2a; border-radius: 6px;
    font-family: inherit; font-size: 0.88rem; background: #3a2810; color: #faf5ea;
  }
  .toolbar-field input { width: 105px; }
  .toolbar-field select { min-width: 150px; }
  .toolbar-field input:focus, .toolbar-field select:focus { border-color: #c87830; outline: none; }
  .toolbar-field input::placeholder { color: #6b4a2a; }
  .btn-toolbar-clear { background: none; border: 1.5px solid #6b4a2a; color: #a08060; font-family: inherit; font-weight: 700; font-size: 0.85rem; padding: 0.38em 0.9em; border-radius: 7px; cursor: pointer; }
  .btn-toolbar-clear:hover { border-color: #a08060; color: #e4d3b8; }
  .toolbar-publish-actions { display: flex; gap: 0.4rem; flex-shrink: 0; }
  .btn-toolbar-publish { background: #3d7a6e; color: #faf5ea; font-family: inherit; font-weight: 700; font-size: 0.85rem; padding: 0.38em 0.9em; border-radius: 7px; border: none; cursor: pointer; }
  .btn-toolbar-publish:hover { background: #2d5a50; }
  .btn-toolbar-unpublish { background: none; border: 1.5px solid #6b4a2a; color: #a08060; font-family: inherit; font-weight: 700; font-size: 0.85rem; padding: 0.38em 0.9em; border-radius: 7px; cursor: pointer; }
  .btn-toolbar-unpublish:hover { border-color: #a08060; color: #e4d3b8; }
  .batch-status-msg { font-size: 0.85rem; font-weight: 700; min-width: 140px; }
  .batch-status-msg.success { color: #6fd4c4; }
  .batch-status-msg.error { color: #f08080; }
</style>

<script>
  // ── Sync from shop ────────────────────────────────────────────────────────
  document.getElementById('syncBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('syncBtn') as HTMLButtonElement;
    const status = document.getElementById('syncStatus')!;
    btn.disabled = true;
    status.textContent = 'Syncing...';
    status.style.color = '#6b4a2a';
    try {
      const res = await fetch('/api/admin/wholesale', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'sync' }),
      });
      if (!res.ok) throw new Error();
      const { added } = await res.json() as { added: number };
      if (added > 0) {
        status.textContent = `Added ${added} item${added !== 1 ? 's' : ''}.`;
        status.style.color = '#3d7a6e';
        setTimeout(() => location.reload(), 1200);
      } else {
        status.textContent = 'Nothing new to sync.';
        status.style.color = '#6b4a2a';
        setTimeout(() => { status.textContent = ''; }, 3000);
      }
    } catch {
      status.textContent = 'Sync failed.';
      status.style.color = '#b44';
    }
    btn.disabled = false;
  });

  // ── Selection state ───────────────────────────────────────────────────────
  const selectedIds = new Set<number>();
  const toolbar = document.getElementById('batchToolbar')!;
  const selectionCountEl = document.getElementById('selectionCount')!;

  function updateToolbar() {
    toolbar.hidden = selectedIds.size === 0;
    selectionCountEl.textContent = `${selectedIds.size} item${selectedIds.size !== 1 ? 's' : ''} selected`;
  }

  document.querySelectorAll<HTMLInputElement>('.item-cb').forEach(cb => {
    cb.addEventListener('change', () => {
      cb.closest<HTMLElement>('.item-row')!.classList.toggle('selected', cb.checked);
      const id = Number(cb.dataset.id);
      if (cb.checked) selectedIds.add(id); else selectedIds.delete(id);
      syncSelectAll(cb.dataset.cat!);
      updateToolbar();
    });
  });

  document.querySelectorAll<HTMLInputElement>('.select-all-cb').forEach(cb => {
    cb.addEventListener('change', () => {
      document.querySelectorAll<HTMLInputElement>(`.item-cb[data-cat="${cb.dataset.cat}"]`).forEach(itemCb => {
        itemCb.checked = cb.checked;
        itemCb.closest<HTMLElement>('.item-row')!.classList.toggle('selected', cb.checked);
        const id = Number(itemCb.dataset.id);
        if (cb.checked) selectedIds.add(id); else selectedIds.delete(id);
      });
      updateToolbar();
    });
  });

  function syncSelectAll(cat: string) {
    const all = Array.from(document.querySelectorAll<HTMLInputElement>(`.item-cb[data-cat="${cat}"]`));
    const allCb = document.querySelector<HTMLInputElement>(`.select-all-cb[data-cat="${cat}"]`);
    if (!allCb) return;
    const checked = all.filter(c => c.checked).length;
    allCb.checked = checked === all.length && all.length > 0;
    allCb.indeterminate = checked > 0 && checked < all.length;
  }

  function clearSelection() {
    document.querySelectorAll<HTMLInputElement>('.item-cb, .select-all-cb').forEach(cb => {
      cb.checked = false;
      (cb as HTMLInputElement).indeterminate = false;
    });
    document.querySelectorAll<HTMLElement>('.item-row').forEach(r => r.classList.remove('selected'));
    selectedIds.clear();
    updateToolbar();
    ['batchWholesale','batchRrp','batchMoq'].forEach(id => (document.getElementById(id) as HTMLInputElement).value = '');
    (document.getElementById('batchCategory') as HTMLSelectElement).value = '';
  }

  document.getElementById('batchClearBtn')!.addEventListener('click', clearSelection);

  // ── Batch publish / unpublish ─────────────────────────────────────────────
  async function batchSetPublished(published: boolean) {
    const statusEl = document.getElementById('batchStatus')!;
    const body = { action: 'batch-update', ids: [...selectedIds], published };
    statusEl.textContent = published ? 'Publishing...' : 'Unpublishing...';
    statusEl.className = 'batch-status-msg';
    try {
      const res = await fetch('/api/admin/wholesale', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error();
      selectedIds.forEach(id => {
        const badge = document.querySelector<HTMLElement>(`.status-badge[data-id="${id}"]`);
        if (!badge) return;
        badge.dataset.published = published.toString();
        badge.textContent = published ? 'Published' : 'Draft';
        badge.className = `status-badge ${published ? 'published' : 'draft'}`;
      });
      statusEl.textContent = `${published ? 'Published' : 'Unpublished'} ${selectedIds.size} item${selectedIds.size !== 1 ? 's' : ''}.`;
      statusEl.className = 'batch-status-msg success';
    } catch {
      statusEl.textContent = 'Error updating.';
      statusEl.className = 'batch-status-msg error';
    }
    setTimeout(() => { statusEl.textContent = ''; statusEl.className = 'batch-status-msg'; }, 4000);
  }

  document.getElementById('batchPublishBtn')!.addEventListener('click', () => batchSetPublished(true));
  document.getElementById('batchUnpublishBtn')!.addEventListener('click', () => batchSetPublished(false));

  // ── Batch apply ───────────────────────────────────────────────────────────
  document.getElementById('batchApplyBtn')!.addEventListener('click', async () => {
    const applyBtn = document.getElementById('batchApplyBtn') as HTMLButtonElement;
    const statusEl = document.getElementById('batchStatus')!;
    const wInput = document.getElementById('batchWholesale') as HTMLInputElement;
    const rInput = document.getElementById('batchRrp') as HTMLInputElement;
    const mInput = document.getElementById('batchMoq') as HTMLInputElement;
    const catSel = document.getElementById('batchCategory') as HTMLSelectElement;

    const body: Record<string, unknown> = { action: 'batch-update', ids: [...selectedIds] };
    let hasField = false;
    if (wInput.value.trim()) { body.wholesalePrice = Number(wInput.value); hasField = true; }
    if (rInput.value.trim()) { body.rrp = Number(rInput.value); hasField = true; }
    if (mInput.value.trim()) { body.moq = Number(mInput.value); hasField = true; }
    if (catSel.value) { body.category = catSel.value; hasField = true; }

    if (!hasField) {
      statusEl.textContent = 'Enter at least one value.';
      statusEl.className = 'batch-status-msg error';
      setTimeout(() => { statusEl.textContent = ''; statusEl.className = 'batch-status-msg'; }, 3000);
      return;
    }

    applyBtn.disabled = true;
    statusEl.textContent = 'Applying...';
    statusEl.className = 'batch-status-msg';

    try {
      const res = await fetch('/api/admin/wholesale', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) throw new Error();

      if (catSel.value) {
        // Moving items to another category requires DOM restructure — just reload
        location.reload();
        return;
      }

      // Update prices in place
      selectedIds.forEach(id => {
        const row = document.querySelector<HTMLElement>(`.item-row[data-id="${id}"]`);
        if (!row) return;
        if (wInput.value.trim()) row.querySelector<HTMLElement>('[data-field="wholesalePrice"]')!.textContent = `$${Number(wInput.value).toFixed(2)}`;
        if (rInput.value.trim()) row.querySelector<HTMLElement>('[data-field="rrp"]')!.textContent = `$${Number(rInput.value).toFixed(2)}`;
        if (mInput.value.trim()) row.querySelector<HTMLElement>('[data-field="moq"]')!.textContent = String(Number(mInput.value));
      });

      statusEl.textContent = `Applied to ${selectedIds.size} item${selectedIds.size !== 1 ? 's' : ''}.`;
      statusEl.className = 'batch-status-msg success';
      wInput.value = ''; rInput.value = ''; mInput.value = '';
    } catch {
      statusEl.textContent = 'Error applying.';
      statusEl.className = 'batch-status-msg error';
    }
    applyBtn.disabled = false;
    setTimeout(() => { statusEl.textContent = ''; statusEl.className = 'batch-status-msg'; }, 4000);
  });

  // ── New category form ─────────────────────────────────────────────────────
  const newCatToggle = document.getElementById('newCatToggle') as HTMLButtonElement;
  const newCatForm = document.getElementById('newCatForm')!;
  const newCatLabel = document.getElementById('newCatLabel') as HTMLInputElement;
  const newCatStatus = document.getElementById('newCatStatus')!;

  newCatToggle.addEventListener('click', () => {
    newCatForm.hidden = !newCatForm.hidden;
    if (!newCatForm.hidden) newCatLabel.focus();
  });
  document.getElementById('newCatCancel')!.addEventListener('click', () => {
    newCatForm.hidden = true;
    newCatLabel.value = '';
    newCatStatus.textContent = '';
  });

  async function createCategory() {
    const label = newCatLabel.value.trim();
    if (!label) return;
    const saveBtn = document.getElementById('newCatSave') as HTMLButtonElement;
    saveBtn.disabled = true;
    newCatStatus.textContent = 'Creating...';
    newCatStatus.style.color = '#6b4a2a';
    try {
      const res = await fetch('/api/admin/wholesale', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'create-category', label }),
      });
      if (!res.ok) throw new Error();
      location.reload();
    } catch {
      newCatStatus.textContent = 'Error.';
      newCatStatus.style.color = '#b44';
    }
    saveBtn.disabled = false;
  }

  document.getElementById('newCatSave')!.addEventListener('click', createCategory);
  newCatLabel.addEventListener('keydown', e => { if (e.key === 'Enter') createCategory(); });

  // ── Category rename ────────────────────────────────────────────────────────
  function cancelRename(cat: string) {
    const nameEl = document.querySelector<HTMLElement>(`.category-name[data-cat="${cat}"]`)!;
    const input = document.querySelector<HTMLInputElement>(`.category-name-input[data-cat="${cat}"]`)!;
    input.value = nameEl.textContent ?? '';
    input.hidden = true; nameEl.hidden = false;
    document.querySelector<HTMLElement>(`.btn-rename[data-cat="${cat}"]`)!.hidden = false;
    document.querySelector<HTMLElement>(`.btn-rename-save[data-cat="${cat}"]`)!.hidden = true;
    document.querySelector<HTMLElement>(`.btn-rename-cancel[data-cat="${cat}"]`)!.hidden = true;
    document.querySelector<HTMLElement>(`.rename-status[data-cat="${cat}"]`)!.textContent = '';
  }

  async function saveRename(cat: string) {
    const input = document.querySelector<HTMLInputElement>(`.category-name-input[data-cat="${cat}"]`)!;
    const nameEl = document.querySelector<HTMLElement>(`.category-name[data-cat="${cat}"]`)!;
    const statusEl = document.querySelector<HTMLElement>(`.rename-status[data-cat="${cat}"]`)!;
    const saveBtn = document.querySelector<HTMLButtonElement>(`.btn-rename-save[data-cat="${cat}"]`)!;
    const newLabel = input.value.trim();
    if (!newLabel) { cancelRename(cat); return; }
    saveBtn.disabled = true;
    statusEl.textContent = 'Saving...'; statusEl.style.color = '#6b4a2a';
    try {
      const res = await fetch('/api/admin/wholesale', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'update-category-label', slug: cat, label: newLabel }),
      });
      if (!res.ok) throw new Error();
      nameEl.textContent = newLabel;
      statusEl.textContent = 'Saved.'; statusEl.style.color = '#3d7a6e';
      setTimeout(() => { statusEl.textContent = ''; }, 2000);
      input.hidden = true; nameEl.hidden = false;
      document.querySelector<HTMLElement>(`.btn-rename[data-cat="${cat}"]`)!.hidden = false;
      document.querySelector<HTMLElement>(`.btn-rename-save[data-cat="${cat}"]`)!.hidden = true;
      document.querySelector<HTMLElement>(`.btn-rename-cancel[data-cat="${cat}"]`)!.hidden = true;
      // Also update the "Move to category" dropdown option
      const opt = document.querySelector<HTMLOptionElement>(`#batchCategory option[value="${cat}"]`);
      if (opt) opt.textContent = newLabel;
    } catch {
      statusEl.textContent = 'Error.'; statusEl.style.color = '#b44';
    }
    saveBtn.disabled = false;
  }

  document.querySelectorAll<HTMLButtonElement>('.btn-rename').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat!;
      document.querySelector<HTMLElement>(`.category-name[data-cat="${cat}"]`)!.hidden = true;
      btn.hidden = true;
      const input = document.querySelector<HTMLInputElement>(`.category-name-input[data-cat="${cat}"]`)!;
      input.hidden = false; input.focus(); input.select();
      document.querySelector<HTMLElement>(`.btn-rename-save[data-cat="${cat}"]`)!.hidden = false;
      document.querySelector<HTMLElement>(`.btn-rename-cancel[data-cat="${cat}"]`)!.hidden = false;
    });
  });
  document.querySelectorAll<HTMLButtonElement>('.btn-rename-save').forEach(btn => btn.addEventListener('click', () => saveRename(btn.dataset.cat!)));
  document.querySelectorAll<HTMLButtonElement>('.btn-rename-cancel').forEach(btn => btn.addEventListener('click', () => cancelRename(btn.dataset.cat!)));
  document.querySelectorAll<HTMLInputElement>('.category-name-input').forEach(input => {
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter') saveRename(input.dataset.cat!);
      if (e.key === 'Escape') cancelRename(input.dataset.cat!);
    });
  });

  // ── Delete category ────────────────────────────────────────────────────────
  async function deleteCategory(slug: string, itemCount: number) {
    if (itemCount > 0) {
      alert(`Move or delete the ${itemCount} item${itemCount !== 1 ? 's' : ''} in this category first.`);
      return;
    }
    if (!confirm('Delete this category?')) return;
    const res = await fetch('/api/admin/wholesale', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'delete-category', slug }),
    });
    if (res.ok) {
      document.querySelector<HTMLElement>(`.category-group[data-cat="${slug}"]`)?.remove();
      const opt = document.querySelector<HTMLOptionElement>(`#batchCategory option[value="${slug}"]`);
      opt?.remove();
    } else alert('Error deleting category.');
  }

  document.querySelectorAll<HTMLButtonElement>('.btn-delete-cat, .btn-delete-cat-empty').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat!;
      const group = document.querySelector<HTMLElement>(`.category-group[data-cat="${cat}"]`);
      const count = group ? group.querySelectorAll('.item-row').length : 0;
      deleteCategory(cat, count);
    });
  });

  // ── Drag: categories + items (single unified handler) ────────────────────
  const container = document.getElementById('categoryContainer')!;
  let catDragEl: HTMLElement | null = null;
  let itemDragEl: HTMLElement | null = null;

  container.addEventListener('dragstart', (e) => {
    const target = e.target as HTMLElement;

    // Never drag when interacting with a text field
    if (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA') {
      e.preventDefault();
      return;
    }

    // Item row drag (takes priority — item rows are inside category groups)
    const itemRow = target.closest<HTMLElement>('.item-row');
    if (itemRow) {
      itemDragEl = itemRow;
      setTimeout(() => itemDragEl!.classList.add('dragging'), 0);
      return;
    }

    // Category drag — only when draggable was set by the handle's mousedown
    const catGroup = target.closest<HTMLElement>('.category-group');
    if (catGroup) {
      if (!catGroup.draggable) { e.preventDefault(); return; }
      catDragEl = catGroup;
      setTimeout(() => catDragEl!.classList.add('cat-dragging'), 0);
    }
  });

  // Enable drag on the category group only when grabbing the handle
  document.querySelectorAll<HTMLElement>('.cat-drag-handle').forEach(handle => {
    handle.addEventListener('mousedown', () => {
      handle.closest<HTMLElement>('.category-group')!.draggable = true;
    });
  });
  // Reset if the user releases without dragging
  document.addEventListener('mouseup', () => {
    container.querySelectorAll<HTMLElement>('.category-group').forEach(g => g.draggable = false);
  });

  container.addEventListener('dragend', () => {
    catDragEl?.classList.remove('cat-dragging');
    itemDragEl?.classList.remove('dragging');
    container.querySelectorAll('.cat-drag-over').forEach(el => el.classList.remove('cat-drag-over'));
    container.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
    container.querySelectorAll<HTMLElement>('.category-group').forEach(g => g.draggable = false);
    catDragEl = null;
    itemDragEl = null;
  });

  container.addEventListener('dragover', (e) => {
    e.preventDefault();

    if (catDragEl) {
      const target = (e.target as HTMLElement).closest<HTMLElement>('.category-group');
      container.querySelectorAll('.cat-drag-over').forEach(el => el.classList.remove('cat-drag-over'));
      if (target && target !== catDragEl) {
        const rect = target.getBoundingClientRect();
        if (e.clientY < rect.top + rect.height / 2) container.insertBefore(catDragEl, target);
        else target.after(catDragEl);
        target.classList.add('cat-drag-over');
      }
    } else if (itemDragEl) {
      const targetRow = (e.target as HTMLElement).closest<HTMLElement>('.item-row');
      const srcList = itemDragEl.closest<HTMLElement>('.item-list')!;
      srcList.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
      if (targetRow && targetRow !== itemDragEl && targetRow.closest('.item-list') === srcList) {
        const rect = targetRow.getBoundingClientRect();
        if (e.clientY < rect.top + rect.height / 2) srcList.insertBefore(itemDragEl, targetRow);
        else targetRow.after(itemDragEl);
        targetRow.classList.add('drag-over');
      }
    }
  });

  container.addEventListener('drop', (e) => {
    e.preventDefault();
    container.querySelectorAll('.cat-drag-over, .drag-over').forEach(el => el.classList.remove('cat-drag-over', 'drag-over'));
  });

  // ── Save order (items + categories) ───────────────────────────────────────
  document.getElementById('saveOrderBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('saveOrderBtn') as HTMLButtonElement;
    const status = document.getElementById('orderStatus')!;
    btn.disabled = true;
    status.textContent = 'Saving...';
    status.className = 'save-status';

    const itemIds = Array.from(container.querySelectorAll<HTMLElement>('.item-row')).map(r => Number(r.dataset.id));
    const catSlugs = Array.from(container.querySelectorAll<HTMLElement>('.category-group')).map(g => g.dataset.cat!);

    try {
      const [r1, r2] = await Promise.all([
        fetch('/api/admin/wholesale', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'reorder', ids: itemIds }) }),
        fetch('/api/admin/wholesale', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'reorder-categories', slugs: catSlugs }) }),
      ]);
      if (!r1.ok || !r2.ok) throw new Error();
      status.textContent = 'Order saved!';
      status.className = 'save-status success';
    } catch {
      status.textContent = 'Error saving.';
      status.className = 'save-status error';
    }
    btn.disabled = false;
    setTimeout(() => { status.textContent = ''; }, 3000);
  });

  // ── Toggle published ───────────────────────────────────────────────────────
  container.addEventListener('click', async (e) => {
    const badge = (e.target as HTMLElement).closest<HTMLElement>('.status-badge');
    if (!badge) return;
    const id = Number(badge.dataset.id);
    const published = badge.dataset.published === 'true';
    const res = await fetch(`/api/admin/wholesale/${id}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ published: !published }),
    });
    if (res.ok) {
      badge.dataset.published = (!published).toString();
      badge.textContent = !published ? 'Published' : 'Draft';
      badge.className = `status-badge ${!published ? 'published' : 'draft'}`;
    }
  });

  // ── Category description edit ─────────────────────────────────────────────
  function showDescEdit(cat: string) {
    const row = document.querySelector<HTMLElement>(`.cat-desc-row[data-cat="${cat}"]`)!;
    row.querySelector<HTMLElement>('.cat-desc-text')!.hidden = true;
    const emptyEl = row.querySelector<HTMLElement>('.cat-desc-empty');
    if (emptyEl) emptyEl.hidden = true;
    row.querySelector<HTMLElement>('.btn-edit-desc')!.hidden = true;
    const ta = row.querySelector<HTMLTextAreaElement>('.cat-desc-input')!;
    ta.hidden = false; ta.focus();
    row.querySelector<HTMLElement>('.btn-desc-save')!.hidden = false;
    row.querySelector<HTMLElement>('.btn-desc-cancel')!.hidden = false;
  }

  function hideDescEdit(cat: string) {
    const row = document.querySelector<HTMLElement>(`.cat-desc-row[data-cat="${cat}"]`)!;
    row.querySelector<HTMLElement>('.cat-desc-text')!.hidden = false;
    row.querySelector<HTMLElement>('.cat-desc-input')!.hidden = true;
    row.querySelector<HTMLElement>('.btn-desc-save')!.hidden = true;
    row.querySelector<HTMLElement>('.btn-desc-cancel')!.hidden = true;
    row.querySelector<HTMLElement>('.desc-status')!.textContent = '';
  }

  async function saveDescription(cat: string) {
    const row = document.querySelector<HTMLElement>(`.cat-desc-row[data-cat="${cat}"]`)!;
    const ta = row.querySelector<HTMLTextAreaElement>('.cat-desc-input')!;
    const textEl = row.querySelector<HTMLElement>('.cat-desc-text')!;
    const statusEl = row.querySelector<HTMLElement>('.desc-status')!;
    const saveBtn = row.querySelector<HTMLButtonElement>('.btn-desc-save')!;
    const newDesc = ta.value.trim();
    saveBtn.disabled = true;
    statusEl.textContent = 'Saving...'; statusEl.style.color = '#6b4a2a';
    try {
      const res = await fetch('/api/admin/wholesale', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'update-category-description', slug: cat, description: newDesc }),
      });
      if (!res.ok) throw new Error();
      textEl.textContent = newDesc;
      ta.value = newDesc;
      const emptyEl = row.querySelector<HTMLElement>('.cat-desc-empty');
      if (emptyEl) emptyEl.hidden = !!newDesc;
      statusEl.textContent = 'Saved.'; statusEl.style.color = '#3d7a6e';
      setTimeout(() => { statusEl.textContent = ''; }, 2000);
      hideDescEdit(cat);
      textEl.hidden = false;
    } catch {
      statusEl.textContent = 'Error.'; statusEl.style.color = '#b44';
    }
    saveBtn.disabled = false;
  }

  document.querySelectorAll<HTMLButtonElement>('.btn-edit-desc').forEach(btn => {
    btn.addEventListener('click', () => showDescEdit(btn.dataset.cat!));
  });
  document.querySelectorAll<HTMLButtonElement>('.btn-desc-save').forEach(btn => {
    btn.addEventListener('click', () => saveDescription(btn.dataset.cat!));
  });
  document.querySelectorAll<HTMLButtonElement>('.btn-desc-cancel').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat!;
      const row = document.querySelector<HTMLElement>(`.cat-desc-row[data-cat="${cat}"]`)!;
      const ta = row.querySelector<HTMLTextAreaElement>('.cat-desc-input')!;
      const textEl = row.querySelector<HTMLElement>('.cat-desc-text')!;
      ta.value = textEl.textContent ?? '';
      hideDescEdit(cat);
    });
  });
  document.querySelectorAll<HTMLTextAreaElement>('.cat-desc-input').forEach(ta => {
    ta.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        const cat = ta.dataset.cat!;
        ta.value = document.querySelector<HTMLElement>(`.cat-desc-text[data-cat="${cat}"]`)?.textContent ?? '';
        hideDescEdit(cat);
      }
    });
  });

  // ── Category group editing ─────────────────────────────────────────────────
  function showGroupEdit(cat: string) {
    const row = document.querySelector<HTMLElement>(`.cat-group-row[data-cat="${cat}"]`)!;
    row.querySelector<HTMLElement>('.cat-group-text')!.hidden = true;
    row.querySelector<HTMLElement>('.cat-group-empty')?.setAttribute('hidden', '');
    row.querySelector<HTMLElement>('.btn-edit-group')!.hidden = true;
    row.querySelector<HTMLElement>('.cat-group-input')!.hidden = false;
    row.querySelector<HTMLElement>('.btn-group-save')!.hidden = false;
    row.querySelector<HTMLElement>('.btn-group-cancel')!.hidden = false;
    row.querySelector<HTMLInputElement>('.cat-group-input')!.focus();
  }
  function hideGroupEdit(cat: string) {
    const row = document.querySelector<HTMLElement>(`.cat-group-row[data-cat="${cat}"]`)!;
    const currentGroup = row.querySelector<HTMLElement>('.cat-group-text')!.textContent ?? '';
    row.querySelector<HTMLElement>('.cat-group-text')!.hidden = false;
    if (!currentGroup) row.querySelector<HTMLElement>('.cat-group-empty')?.removeAttribute('hidden');
    row.querySelector<HTMLElement>('.btn-edit-group')!.hidden = false;
    row.querySelector<HTMLElement>('.cat-group-input')!.hidden = true;
    row.querySelector<HTMLElement>('.btn-group-save')!.hidden = true;
    row.querySelector<HTMLElement>('.btn-group-cancel')!.hidden = true;
  }
  async function saveGroup(cat: string) {
    const row = document.querySelector<HTMLElement>(`.cat-group-row[data-cat="${cat}"]`)!;
    const input = row.querySelector<HTMLInputElement>('.cat-group-input')!;
    const status = row.querySelector<HTMLElement>('.group-status')!;
    const newGroup = input.value.trim();
    const saveBtn = row.querySelector<HTMLButtonElement>('.btn-group-save')!;
    saveBtn.disabled = true;
    try {
      const res = await fetch('/api/admin/wholesale', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'update-category-group', slug: cat, group: newGroup }),
      });
      if (!res.ok) throw new Error();
      const textEl = row.querySelector<HTMLElement>('.cat-group-text')!;
      const emptyEl = row.querySelector<HTMLElement>('.cat-group-empty');
      textEl.textContent = newGroup;
      if (emptyEl) emptyEl.hidden = !!newGroup;
      status.textContent = 'Saved!'; status.style.color = '#3d7a6e';
      setTimeout(() => { status.textContent = ''; }, 2000);
      hideGroupEdit(cat);
    } catch {
      status.textContent = 'Error'; status.style.color = '#b44';
    }
    saveBtn.disabled = false;
  }
  document.querySelectorAll<HTMLButtonElement>('.btn-edit-group').forEach(btn => {
    btn.addEventListener('click', () => showGroupEdit(btn.dataset.cat!));
  });
  document.querySelectorAll<HTMLButtonElement>('.btn-group-save').forEach(btn => {
    btn.addEventListener('click', () => saveGroup(btn.dataset.cat!));
  });
  document.querySelectorAll<HTMLButtonElement>('.btn-group-cancel').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.cat!;
      const row = document.querySelector<HTMLElement>(`.cat-group-row[data-cat="${cat}"]`)!;
      row.querySelector<HTMLInputElement>('.cat-group-input')!.value =
        row.querySelector<HTMLElement>('.cat-group-text')!.textContent ?? '';
      hideGroupEdit(cat);
    });
  });
  document.querySelectorAll<HTMLInputElement>('.cat-group-input').forEach(input => {
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter') saveGroup(input.dataset.cat!);
      if (e.key === 'Escape') {
        input.value = document.querySelector<HTMLElement>(`.cat-group-text[data-cat="${input.dataset.cat}"]`)?.textContent ?? '';
        hideGroupEdit(input.dataset.cat!);
      }
    });
  });

  // ── Delete item ────────────────────────────────────────────────────────────
  container.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.btn-delete');
    if (!btn) return;
    if (!confirm('Delete this item? This cannot be undone.')) return;
    const id = Number(btn.dataset.id);
    const res = await fetch(`/api/admin/wholesale/${id}`, { method: 'DELETE' });
    if (res.ok) btn.closest('.item-row')?.remove();
    else alert('Error deleting item.');
  });
</script>
