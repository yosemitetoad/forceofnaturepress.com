---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { getPageContentMulti } from '../../../lib/db';

const db = Astro.locals.runtime.env.DB;
const content = await getPageContentMulti(db, ['wholesale_terms', 'wholesale_contact_intro', 'wholesale_contact_email', 'wholesale_form_url', 'wholesale_catalog_intro', 'wholesale_under_construction']);

const terms = content.wholesale_terms ?? '';
const catalogIntro = content.wholesale_catalog_intro ?? '';
const contactIntro = content.wholesale_contact_intro ?? '';
const contactEmail = content.wholesale_contact_email ?? '';
const formUrl = content.wholesale_form_url ?? '';
const underConstruction = content.wholesale_under_construction === '1';
---

<Admin title="Wholesale Page Content">
  <div class="page-header">
    <h1>Wholesale Page</h1>
    <div class="header-actions">
      <a href="/admin/pages" class="btn btn-outline">&larr; All Pages</a>
      <a href="/admin/wholesale" class="btn btn-outline">Catalog Items</a>
      <a href="/admin/pages/wholesale-form" class="btn btn-outline">Order Form</a>
    </div>
  </div>

  <div class="status-bar" id="status-bar" data-enabled={underConstruction ? 'true' : 'false'}>
    <div class="status-info">
      <span class="status-label">Wholesale Page</span>
      <span class="status-text" id="status-text">
        {underConstruction ? 'Under Construction — visitors see a coming soon message' : 'Live — wholesale page is visible to everyone'}
      </span>
    </div>
    <button class="btn status-btn" id="status-toggle" data-enabled={underConstruction ? 'true' : 'false'}>
      {underConstruction ? 'Take Live' : 'Enable Under Construction'}
    </button>
  </div>

  <form id="contentForm">
    <section class="editor-section">
      <h2>Terms &amp; Conditions</h2>
      <p class="help-text">Shown at the top of the wholesale page. Supports markdown: <code>**bold**</code>, <code>*italic*</code>, <code>[link](url)</code>. Leave a blank line between paragraphs to create a paragraph break.</p>
      <div class="field">
        <textarea name="wholesale_terms" rows="10">{terms}</textarea>
      </div>
    </section>

    <section class="editor-section">
      <h2>Catalog Intro</h2>
      <p class="help-text">Optional paragraph shown below the Catalog heading, above the product categories.</p>
      <div class="field">
        <textarea name="wholesale_catalog_intro" rows="4">{catalogIntro}</textarea>
      </div>
    </section>

    <section class="editor-section">
      <h2>Contact Section</h2>
      <div class="field">
        <label>Intro text</label>
        <p class="help-text">Appears above the contact form.</p>
        <textarea name="wholesale_contact_intro" rows="3">{contactIntro}</textarea>
      </div>
      <div class="field">
        <label>Contact email address</label>
        <p class="help-text">Displayed as a mailto link. Leave blank to hide.</p>
        <input type="email" name="wholesale_contact_email" value={contactEmail} placeholder="e.g. hello@example.com" />
      </div>
      <div class="field">
        <label>Contact form URL (Formspree)</label>
        <p class="help-text">The form <code>action</code> URL. Leave blank to hide the form entirely.</p>
        <input type="url" name="wholesale_form_url" value={formUrl} placeholder="https://formspree.io/f/..." />
      </div>
    </section>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary" id="saveBtn">Save Changes</button>
      <span id="saveStatus" class="save-status"></span>
    </div>
  </form>
</Admin>

<style>
  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  h1 { font-size: 1.8rem; font-weight: 800; margin: 0; }
  h2 { font-size: 1.3rem; font-weight: 800; margin: 0 0 0.8rem; color: #2d1f0e; }
  .header-actions { display: flex; gap: 0.6rem; }

  .btn { display: inline-block; padding: 0.55em 1.2em; border-radius: 8px; font-family: inherit; font-weight: 700; font-size: 0.9rem; text-decoration: none; cursor: pointer; border: none; }
  .btn-primary { background: #c87830; color: #faf5ea; }
  .btn-primary:hover { background: #a05e18; }
  .btn-outline { background: transparent; color: #2d1f0e; border: 2px solid #d4b896; }
  .btn-outline:hover { background: #e4d3b8; }

  /* Under construction toggle bar */
  .status-bar {
    display: flex; align-items: center; justify-content: space-between;
    background: #faf5ea; border: 2px solid #d4b896; border-radius: 10px;
    padding: 1rem 1.5rem; margin-bottom: 1.5rem; gap: 1rem;
  }
  .status-bar[data-enabled='true'] { background: #fff3cd; border-color: #e0b840; }
  .status-info { display: flex; flex-direction: column; gap: 0.2rem; }
  .status-label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; color: #6b4a2a; }
  .status-text { font-size: 0.95rem; font-weight: 700; color: #2d1f0e; }
  .status-btn { white-space: nowrap; }
  .status-btn[data-enabled='false'] { background: #6b4a2a; color: #faf5ea; }
  .status-btn[data-enabled='false']:hover { background: #4a2f12; }
  .status-btn[data-enabled='true'] { background: #3d7a6e; color: #faf5ea; }
  .status-btn[data-enabled='true']:hover { background: #2a5a50; }

  .editor-section { background: #faf5ea; border: 2px solid #d4b896; border-radius: 10px; padding: 1.5rem; margin-bottom: 1.5rem; }

  .field { margin-bottom: 0; }
  .field + .field { margin-top: 1rem; }
  .field textarea {
    width: 100%; padding: 0.6em 0.8em; border: 2px solid #d4b896; border-radius: 8px;
    font-family: inherit; font-size: 0.9rem; background: #f0e6d0; color: #2d1f0e;
    box-sizing: border-box; resize: vertical;
  }
  .field textarea:focus { border-color: #c87830; outline: none; }
  .field label { display: block; font-weight: 700; font-size: 0.85rem; color: #6b4a2a; margin-bottom: 0.2rem; }
  .field input[type="email"], .field input[type="url"] {
    width: 100%; padding: 0.6em 0.8em; border: 2px solid #d4b896; border-radius: 8px;
    font-family: inherit; font-size: 0.9rem; background: #f0e6d0; color: #2d1f0e;
    box-sizing: border-box;
  }
  .field input[type="email"]:focus, .field input[type="url"]:focus { border-color: #c87830; outline: none; }
  .help-text { font-size: 0.85rem; color: #6b4a2a; margin: 0 0 0.6rem; line-height: 1.5; }
  .help-text code { background: #e4d3b8; padding: 1px 5px; border-radius: 3px; font-size: 0.85em; }

  .form-actions { display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem; }
  .save-status { font-size: 0.9rem; font-weight: 700; display: block; margin-top: 0.5rem; min-height: 1.3em; }
  .save-status.success { color: #3d7a6e; }
  .save-status.error { color: #b44; }
</style>

<script>
  const contentForm = document.getElementById('contentForm') as HTMLFormElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const saveStatus = document.getElementById('saveStatus')!;

  contentForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving...';
    saveStatus.className = 'save-status';

    const updates: Record<string, string> = {};
    const data = new FormData(contentForm);
    for (const [key, value] of data.entries()) updates[key] = String(value);

    try {
      const res = await fetch('/api/admin/pages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates }),
      });
      if (!res.ok) throw new Error();
      saveStatus.textContent = 'Saved!';
      saveStatus.className = 'save-status success';
    } catch {
      saveStatus.textContent = 'Error saving.';
      saveStatus.className = 'save-status error';
    }
    saveBtn.disabled = false;
    setTimeout(() => { saveStatus.textContent = ''; }, 3000);
  });

  // Under construction toggle
  const bar = document.getElementById('status-bar')!;
  const btn = document.getElementById('status-toggle') as HTMLButtonElement;
  const statusText = document.getElementById('status-text')!;

  btn.addEventListener('click', async () => {
    const current = btn.dataset.enabled === 'true';
    const next = !current;
    btn.disabled = true;
    try {
      const res = await fetch('/api/admin/pages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates: { wholesale_under_construction: next ? '1' : '0' } }),
      });
      if (!res.ok) throw new Error();
      const enabled = String(next);
      btn.dataset.enabled = enabled;
      bar.dataset.enabled = enabled;
      btn.textContent = next ? 'Take Live' : 'Enable Under Construction';
      statusText.textContent = next
        ? 'Under Construction — visitors see a coming soon message'
        : 'Live — wholesale page is visible to everyone';
    } catch {
      alert('Failed to update status. Please try again.');
    }
    btn.disabled = false;
  });
</script>
