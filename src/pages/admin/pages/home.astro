---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { getPageContentMulti, getAllShopItems, getActiveWhatsNewItems, getArchivedWhatsNewItems } from '../../../lib/db';

const db = Astro.locals.runtime.env.DB;
const content = await getPageContentMulti(db, [
  'home_intro_p1', 'home_intro_p2', 'home_featured_skus'
]);
const allItems = await getAllShopItems(db);
const activeNews = await getActiveWhatsNewItems(db);
const archivedNews = await getArchivedWhatsNewItems(db);

const introP1 = content.home_intro_p1 ?? '';
const introP2 = content.home_intro_p2 ?? '';
const featuredSkus = (content.home_featured_skus ?? '').split(',').map(s => s.trim()).filter(Boolean);
---

<Admin title="Home Page Content">
  <div class="page-header">
    <h1>Home Page</h1>
    <a href="/admin/pages" class="btn btn-outline">&larr; All Pages</a>
  </div>

  <form id="homeForm">
    <!-- Intro Text -->
    <section class="editor-section">
      <h2>Intro Box</h2>
      <p class="help-text">Supports basic markdown: <code>**bold**</code>, <code>*italic*</code>, <code>[link text](url)</code>.</p>
      <div class="field">
        <label for="intro_p1">Paragraph 1</label>
        <textarea id="intro_p1" name="home_intro_p1" rows="3">{introP1}</textarea>
      </div>
      <div class="field">
        <label for="intro_p2">Paragraph 2</label>
        <textarea id="intro_p2" name="home_intro_p2" rows="3">{introP2}</textarea>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="editor-section">
      <h2>Featured Products</h2>
      <p class="help-text">Select which products appear in the carousel. Drag to reorder.</p>
      <div class="featured-picker">
        <div class="featured-selected" id="featuredList">
          {featuredSkus.map(sku => {
            const item = allItems.find(i => i.sku === sku);
            return item ? (
              <div class="featured-chip" data-sku={sku}>
                <img src={item.image} alt="" class="chip-thumb" />
                <span>{item.title}</span>
                <button type="button" class="chip-remove" data-sku={sku}>&times;</button>
              </div>
            ) : null;
          })}
        </div>
        <div class="add-featured">
          <select id="addFeaturedSelect">
            <option value="">+ Add product...</option>
            {allItems.map(item => (
              <option value={item.sku} data-image={item.image}>{item.title} ({item.sku})</option>
            ))}
          </select>
        </div>
      </div>
      <input type="hidden" id="featuredSkusInput" name="home_featured_skus" value={featuredSkus.join(',')} />
    </section>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary" id="saveBtn">Save Changes</button>
      <span id="saveStatus" class="save-status"></span>
    </div>
  </form>

  <!-- What's New (managed separately from main form) -->
  <section class="editor-section" id="whatsNewSection">
    <h2>What's New</h2>
    <p class="help-text">Supports basic markdown in the text field: <code>**bold**</code>, <code>*italic*</code>, <code>[link text](url)</code>. Each item saves individually. Drag the handle to reorder — order saves automatically on drop.</p>

    <div id="whatsNewItems">
      {activeNews.map((item) => (
        <div class="news-editor" data-id={item.id}>
          <div class="news-editor-header">
            <span class="news-drag-handle" title="Drag to reorder">⠿</span>
            <div class="news-meta">
              Created: {new Date(item.createdAt + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              {item.createdAt !== item.updatedAt && (
                <> &middot; Edited: {new Date(item.updatedAt + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</>
              )}
            </div>
            <div class="news-header-actions">
              <button type="button" class="btn-sm btn-save-item" data-id={item.id}>Save</button>
              <button type="button" class="btn-sm btn-archive-item" data-id={item.id}>Archive</button>
            </div>
          </div>
          <div class="field">
            <label>Title</label>
            <input type="text" class="news-title" value={item.title} />
          </div>
          <div class="field">
            <label>Text</label>
            <textarea class="news-text" rows="2">{item.text}</textarea>
          </div>
          <div class="field-row">
            <div class="field">
              <label>Link Text</label>
              <input type="text" class="news-link-text" value={item.linkText} />
            </div>
            <div class="field">
              <label>Link URL</label>
              <input type="text" class="news-link-url" value={item.linkUrl} />
            </div>
          </div>
          <div class="news-item-status"></div>
        </div>
      ))}
    </div>

    <button type="button" id="addNewsItem" class="btn btn-outline">+ Add News Item</button>

    {archivedNews.length > 0 && (
      <details class="archive-section">
        <summary>Archive ({archivedNews.length} item{archivedNews.length !== 1 ? 's' : ''})</summary>
        <div class="archive-list">
          {archivedNews.map((item) => (
            <div class="archived-item" data-id={item.id}>
              <div class="archived-item-info">
                <strong>{item.title || '(untitled)'}</strong>
                <span class="archived-meta">
                  Archived: {new Date((item.archivedAt ?? item.updatedAt) + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  &nbsp;&middot;&nbsp;
                  Created: {new Date(item.createdAt + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
                {item.text && <p class="archived-text">{item.text}</p>}
              </div>
              <div class="archived-item-actions">
                <button type="button" class="btn-sm btn-restore-item" data-id={item.id}>Restore</button>
                <button type="button" class="btn-sm btn-delete-item" data-id={item.id}>Delete</button>
              </div>
              <div class="archived-item-status"></div>
            </div>
          ))}
        </div>
      </details>
    )}
    {archivedNews.length === 0 && (
      <details class="archive-section" id="archiveSection">
        <summary>Archive (0 items)</summary>
        <div class="archive-list" id="archiveList"></div>
      </details>
    )}
  </section>
</Admin>

<style>
  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  h1 { font-size: 1.8rem; font-weight: 800; margin: 0; }
  h2 { font-size: 1.3rem; font-weight: 800; margin: 0 0 0.8rem; color: #2d1f0e; }

  .btn { display: inline-block; padding: 0.55em 1.2em; border-radius: 8px; font-family: inherit; font-weight: 700; font-size: 0.9rem; text-decoration: none; cursor: pointer; border: none; }
  .btn-primary { background: #c87830; color: #faf5ea; }
  .btn-primary:hover { background: #a05e18; }
  .btn-outline { background: transparent; color: #2d1f0e; border: 2px solid #d4b896; }
  .btn-outline:hover { background: #e4d3b8; }
  .btn-sm { display: inline-block; padding: 0.3em 0.7em; border-radius: 6px; font-family: inherit; font-weight: 700; font-size: 0.8rem; cursor: pointer; border: none; }
  .btn-delete { background: #b44; color: #faf5ea; }
  .btn-delete:hover { background: #833; }

  .editor-section {
    background: #faf5ea;
    border: 2px solid #d4b896;
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .field { margin-bottom: 1rem; }
  .field:last-child { margin-bottom: 0; }
  .field label { display: block; font-weight: 700; font-size: 0.88rem; color: #2d1f0e; margin-bottom: 0.3rem; }
  .field input, .field textarea, .field select {
    width: 100%; padding: 0.55em 0.8em; border: 2px solid #d4b896; border-radius: 8px;
    font-family: inherit; font-size: 0.9rem; background: #f0e6d0; color: #2d1f0e; box-sizing: border-box;
  }
  .field input:focus, .field textarea:focus, .field select:focus { border-color: #c87830; outline: none; }
  .field textarea { resize: vertical; }

  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .help-text { font-size: 0.85rem; color: #6b4a2a; margin: -0.4rem 0 0.8rem; line-height: 1.5; }
  .help-text code { background: #e4d3b8; padding: 1px 5px; border-radius: 3px; font-size: 0.85em; }

  /* Featured products */
  .featured-selected { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.8rem; min-height: 40px; }
  .featured-chip {
    display: flex; align-items: center; gap: 0.4rem; background: #e4d3b8; border-radius: 8px;
    padding: 0.3rem 0.6rem; font-size: 0.85rem; font-weight: 700; cursor: grab;
  }
  .featured-chip:active { cursor: grabbing; }
  .chip-thumb { width: 28px; height: 28px; object-fit: cover; border-radius: 4px; }
  .chip-remove { background: none; border: none; font-size: 1.1rem; cursor: pointer; color: #b44; padding: 0 0.2rem; font-weight: 700; }
  .add-featured select {
    padding: 0.5em 0.8em; border: 2px solid #d4b896; border-radius: 8px;
    font-family: inherit; font-size: 0.9rem; background: #f0e6d0; color: #2d1f0e;
  }

  /* What's New section */
  #whatsNewSection { margin-top: 1.5rem; }

  /* News items */
  .news-editor {
    background: #f0e6d0; border: 1px solid #d4b896; border-radius: 8px;
    padding: 1rem; margin-bottom: 0.8rem; cursor: default;
  }
  .news-editor.dragging { opacity: 0.4; }
  .news-editor-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.8rem; flex-wrap: wrap; }
  .news-drag-handle { cursor: grab; color: #a08060; font-size: 1.1rem; padding: 0 0.2rem; user-select: none; flex-shrink: 0; }
  .news-drag-handle:active { cursor: grabbing; }
  .news-meta { font-size: 0.78rem; color: #7a5a38; flex: 1; }
  .news-header-actions { display: flex; gap: 0.4rem; margin-left: auto; }
  .btn-save-item { background: #c87830; color: #faf5ea; }
  .btn-save-item:hover { background: #a05e18; }
  .btn-archive-item { background: #888; color: #faf5ea; }
  .btn-archive-item:hover { background: #666; }
  .news-item-status { font-size: 0.8rem; font-weight: 700; min-height: 1em; margin-top: 0.3rem; }
  .news-item-status.success { color: #3d7a6e; }
  .news-item-status.error { color: #b44; }

  /* Archive section */
  .archive-section { margin-top: 1rem; }
  .archive-section summary {
    cursor: pointer; font-weight: 700; font-size: 0.9rem; color: #6b4a2a;
    padding: 0.4rem 0; user-select: none;
  }
  .archive-section summary:hover { color: #2d1f0e; }
  .archive-list { margin-top: 0.8rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .archived-item {
    background: #e8dcc8; border: 1px solid #c8a878; border-radius: 8px;
    padding: 0.8rem 1rem; display: flex; align-items: flex-start; gap: 1rem;
  }
  .archived-item-info { flex: 1; min-width: 0; }
  .archived-item-info strong { font-size: 0.9rem; color: #2d1f0e; }
  .archived-meta { display: block; font-size: 0.78rem; color: #7a5a38; margin-top: 0.15rem; }
  .archived-text { font-size: 0.82rem; color: #5a3e1e; margin: 0.3rem 0 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .archived-item-actions { display: flex; flex-direction: column; gap: 0.35rem; flex-shrink: 0; }
  .btn-restore-item { background: #5b7b6d; color: #faf5ea; }
  .btn-restore-item:hover { background: #3d5a4e; }
  .btn-delete-item { background: #b44; color: #faf5ea; }
  .btn-delete-item:hover { background: #833; }
  .archived-item-status { font-size: 0.78rem; font-weight: 700; min-height: 1em; }

  .form-actions { display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem; }
  .save-status { font-size: 0.9rem; font-weight: 700; }
  .save-status.success { color: #3d7a6e; }
  .save-status.error { color: #b44; }
</style>

<script>
  const form = document.getElementById('homeForm') as HTMLFormElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const saveStatus = document.getElementById('saveStatus')!;
  const featuredList = document.getElementById('featuredList')!;
  const featuredInput = document.getElementById('featuredSkusInput') as HTMLInputElement;
  const addSelect = document.getElementById('addFeaturedSelect') as HTMLSelectElement;

  // ── Featured products ──
  function updateFeaturedInput() {
    const chips = featuredList.querySelectorAll('.featured-chip');
    const skus = Array.from(chips).map(c => (c as HTMLElement).dataset.sku);
    featuredInput.value = skus.join(',');
  }

  featuredList.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.chip-remove') as HTMLElement;
    if (btn) {
      btn.closest('.featured-chip')?.remove();
      updateFeaturedInput();
    }
  });

  addSelect.addEventListener('change', () => {
    const sku = addSelect.value;
    if (!sku) return;
    if (featuredList.querySelector(`[data-sku="${sku}"]`)) { addSelect.value = ''; return; }

    const opt = addSelect.selectedOptions[0];
    const chip = document.createElement('div');
    chip.className = 'featured-chip';
    chip.dataset.sku = sku;
    chip.draggable = true;
    chip.innerHTML = `
      <img src="${opt.dataset.image}" alt="" class="chip-thumb" />
      <span>${opt.textContent?.split(' (')[0]}</span>
      <button type="button" class="chip-remove" data-sku="${sku}">&times;</button>
    `;
    featuredList.appendChild(chip);
    addSelect.value = '';
    updateFeaturedInput();
  });

  // Drag to reorder featured chips
  let dragEl: HTMLElement | null = null;
  featuredList.addEventListener('dragstart', (e) => {
    dragEl = (e.target as HTMLElement).closest('.featured-chip') as HTMLElement;
    if (dragEl) dragEl.style.opacity = '0.4';
  });
  featuredList.addEventListener('dragend', () => {
    if (dragEl) dragEl.style.opacity = '1';
    dragEl = null;
  });
  featuredList.addEventListener('dragover', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('.featured-chip') as HTMLElement;
    if (target && target !== dragEl) {
      const rect = target.getBoundingClientRect();
      const mid = rect.left + rect.width / 2;
      if (e.clientX < mid) {
        featuredList.insertBefore(dragEl!, target);
      } else {
        target.after(dragEl!);
      }
    }
  });
  featuredList.addEventListener('drop', (e) => {
    e.preventDefault();
    updateFeaturedInput();
  });

  // Make existing chips draggable
  featuredList.querySelectorAll('.featured-chip').forEach(c => (c as HTMLElement).draggable = true);

  // ── What's New drag-to-reorder ──
  const newsContainer = document.getElementById('whatsNewItems')!;
  let newsDragEl: HTMLElement | null = null;

  newsContainer.addEventListener('mousedown', (e) => {
    const handle = (e.target as HTMLElement).closest('.news-drag-handle');
    if (handle) {
      const row = handle.closest('.news-editor') as HTMLElement;
      if (row) row.draggable = true;
    }
  });

  newsContainer.addEventListener('dragstart', (e) => {
    newsDragEl = (e.target as HTMLElement).closest('.news-editor') as HTMLElement;
    if (newsDragEl) setTimeout(() => newsDragEl!.classList.add('dragging'), 0);
  });
  newsContainer.addEventListener('dragend', async () => {
    if (newsDragEl) {
      newsDragEl.classList.remove('dragging');
      newsDragEl.draggable = false;
    }
    newsDragEl = null;
    // Auto-save order
    const ids = Array.from(newsContainer.querySelectorAll('.news-editor'))
      .map(el => Number((el as HTMLElement).dataset.id))
      .filter(Boolean);
    if (ids.length > 0) {
      await fetch('/api/admin/whats-new', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'reorder', ids }),
      });
    }
  });
  newsContainer.addEventListener('dragover', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('.news-editor') as HTMLElement;
    if (target && target !== newsDragEl) {
      const rect = target.getBoundingClientRect();
      if (e.clientY < rect.top + rect.height / 2) {
        newsContainer.insertBefore(newsDragEl!, target);
      } else {
        target.after(newsDragEl!);
      }
    }
  });
  newsContainer.addEventListener('drop', (e) => { e.preventDefault(); });

  // ── Add new item ──
  document.getElementById('addNewsItem')?.addEventListener('click', async () => {
    const res = await fetch('/api/admin/whats-new', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title: '', text: '', linkText: '', linkUrl: '' }),
    });
    if (!res.ok) return;
    const { id, createdAt } = await res.json() as { id: number; createdAt: string; updatedAt: string };

    const fmtDate = (iso: string) => new Date(iso + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

    const div = document.createElement('div');
    div.className = 'news-editor';
    div.dataset.id = String(id);
    div.innerHTML = `
      <div class="news-editor-header">
        <span class="news-drag-handle" title="Drag to reorder">⠿</span>
        <div class="news-meta">Created: ${fmtDate(createdAt)}</div>
        <div class="news-header-actions">
          <button type="button" class="btn-sm btn-save-item" data-id="${id}">Save</button>
          <button type="button" class="btn-sm btn-archive-item" data-id="${id}">Archive</button>
        </div>
      </div>
      <div class="field"><label>Title</label><input type="text" class="news-title" value="" /></div>
      <div class="field"><label>Text</label><textarea class="news-text" rows="2"></textarea></div>
      <div class="field-row">
        <div class="field"><label>Link Text</label><input type="text" class="news-link-text" value="" /></div>
        <div class="field"><label>Link URL</label><input type="text" class="news-link-url" value="" /></div>
      </div>
      <div class="news-item-status"></div>
    `;
    newsContainer.appendChild(div);
    (div.querySelector('.news-title') as HTMLInputElement)?.focus();
  });

  // ── Save individual item ──
  async function saveNewsItem(card: HTMLElement) {
    const id = Number(card.dataset.id);
    const status = card.querySelector('.news-item-status') as HTMLElement;
    const btn = card.querySelector('.btn-save-item') as HTMLButtonElement;
    btn.disabled = true;
    status.textContent = 'Saving...';
    status.className = 'news-item-status';

    const title = (card.querySelector('.news-title') as HTMLInputElement).value;
    const text = (card.querySelector('.news-text') as HTMLTextAreaElement).value;
    const linkText = (card.querySelector('.news-link-text') as HTMLInputElement).value;
    const linkUrl = (card.querySelector('.news-link-url') as HTMLInputElement).value;

    try {
      const res = await fetch(`/api/admin/whats-new/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, text, linkText, linkUrl }),
      });
      if (!res.ok) throw new Error();
      const { updatedAt } = await res.json() as { updatedAt: string };
      // Update meta line
      const meta = card.querySelector('.news-meta') as HTMLElement;
      const createdText = meta.textContent?.split('·')[0]?.trim() ?? '';
      const editedDate = new Date(updatedAt + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
      meta.textContent = `${createdText} · Edited: ${editedDate}`;
      status.textContent = 'Saved!';
      status.className = 'news-item-status success';
    } catch {
      status.textContent = 'Error saving.';
      status.className = 'news-item-status error';
    }
    btn.disabled = false;
    setTimeout(() => { status.textContent = ''; }, 3000);
  }

  // ── Archive item ──
  async function archiveNewsItem(card: HTMLElement) {
    const id = Number(card.dataset.id);
    if (!confirm('Archive this item? You can restore it from the archive below.')) return;

    const res = await fetch(`/api/admin/whats-new/${id}`, { method: 'DELETE' });
    if (!res.ok) { alert('Error archiving item.'); return; }

    const title = (card.querySelector('.news-title') as HTMLInputElement)?.value || '(untitled)';
    const text = (card.querySelector('.news-text') as HTMLTextAreaElement)?.value || '';
    const now = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    const createdText = (card.querySelector('.news-meta') as HTMLElement)?.textContent?.split('·')[0]?.trim() ?? '';

    card.remove();

    // Add to archive UI
    const archiveSection = document.querySelector('.archive-section') as HTMLDetailsElement;
    const archiveList = archiveSection?.querySelector('.archive-list') as HTMLElement;
    if (!archiveSection || !archiveList) { location.reload(); return; }

    // Update summary count
    const summary = archiveSection.querySelector('summary')!;
    const current = parseInt(summary.textContent?.match(/\d+/)?.[0] ?? '0');
    summary.textContent = `Archive (${current + 1} item${current + 1 !== 1 ? 's' : ''})`;

    const div = document.createElement('div');
    div.className = 'archived-item';
    div.dataset.id = String(id);
    div.innerHTML = `
      <div class="archived-item-info">
        <strong>${title}</strong>
        <span class="archived-meta">Archived: ${now} &nbsp;&middot;&nbsp; ${createdText}</span>
        ${text ? `<p class="archived-text">${text}</p>` : ''}
      </div>
      <div class="archived-item-actions">
        <button type="button" class="btn-sm btn-restore-item" data-id="${id}">Restore</button>
        <button type="button" class="btn-sm btn-delete-item" data-id="${id}">Delete</button>
      </div>
      <div class="archived-item-status"></div>
    `;
    archiveList.prepend(div);
    archiveSection.open = true;
  }

  // ── Restore item ──
  async function restoreNewsItem(archivedCard: HTMLElement) {
    const id = Number(archivedCard.dataset.id);
    const res = await fetch(`/api/admin/whats-new/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'restore' }),
    });
    if (!res.ok) { alert('Error restoring item.'); return; }
    // Reload to get fresh timestamps and correct placement
    location.reload();
  }

  // ── Permanently delete archived item ──
  async function deleteNewsItem(archivedCard: HTMLElement) {
    const id = Number(archivedCard.dataset.id);
    if (!confirm('Permanently delete this item? This cannot be undone.')) return;

    const res = await fetch(`/api/admin/whats-new/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'delete' }),
    });
    if (!res.ok) { alert('Error deleting item.'); return; }

    archivedCard.remove();
    const archiveSection = document.querySelector('.archive-section') as HTMLDetailsElement;
    const summary = archiveSection?.querySelector('summary');
    if (summary) {
      const current = parseInt(summary.textContent?.match(/\d+/)?.[0] ?? '1');
      const next = Math.max(0, current - 1);
      summary.textContent = `Archive (${next} item${next !== 1 ? 's' : ''})`;
    }
  }

  // ── Event delegation for item buttons ──
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    const saveBtn2 = target.closest('.btn-save-item') as HTMLElement | null;
    if (saveBtn2) {
      const card = saveBtn2.closest('.news-editor') as HTMLElement;
      if (card) saveNewsItem(card);
      return;
    }

    const archiveBtn = target.closest('.btn-archive-item') as HTMLElement | null;
    if (archiveBtn) {
      const card = archiveBtn.closest('.news-editor') as HTMLElement;
      if (card) archiveNewsItem(card);
      return;
    }

    const restoreBtn = target.closest('.btn-restore-item') as HTMLElement | null;
    if (restoreBtn) {
      const card = restoreBtn.closest('.archived-item') as HTMLElement;
      if (card) restoreNewsItem(card);
      return;
    }

    const deleteBtn = target.closest('.btn-delete-item') as HTMLElement | null;
    if (deleteBtn) {
      const card = deleteBtn.closest('.archived-item') as HTMLElement;
      if (card) deleteNewsItem(card);
      return;
    }
  });

  // ── Save main form (intro + featured products only) ──
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving...';
    saveStatus.className = 'save-status';

    const updates: Record<string, string> = {};
    const formData = new FormData(form);
    for (const [key, value] of formData.entries()) {
      updates[key] = String(value);
    }

    try {
      const res = await fetch('/api/admin/pages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates }),
      });
      if (res.ok) {
        saveStatus.textContent = 'Saved!';
        saveStatus.className = 'save-status success';
      } else {
        throw new Error('Save failed');
      }
    } catch {
      saveStatus.textContent = 'Error saving. Please try again.';
      saveStatus.className = 'save-status error';
    }
    saveBtn.disabled = false;
    setTimeout(() => { saveStatus.textContent = ''; }, 3000);
  });
</script>
