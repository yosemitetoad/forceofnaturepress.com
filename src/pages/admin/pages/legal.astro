---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { getPageContentMulti } from '../../../lib/db';

const db = Astro.locals.runtime.env.DB;
const content = await getPageContentMulti(db, ['privacy_content', 'terms_content']);

const privacy = content.privacy_content ?? '';
const terms = content.terms_content ?? '';
---

<Admin title="Legal Pages">
  <div class="page-header">
    <h1>Legal Pages</h1>
    <a href="/admin/pages" class="btn btn-outline">&larr; All Pages</a>
  </div>

  <form id="legalForm">
    <section class="editor-section">
      <div class="section-header">
        <h2>Privacy Policy</h2>
        <a href="/privacy" target="_blank" class="btn-sm btn-view">View Page</a>
      </div>
      <p class="help-text">Edit using Markdown. Use <code>{`{EMAIL_LINK}`}</code> to insert your email as a clickable link. <code>## Heading</code>, <code>**bold**</code>, <code>- list item</code>, and <code>[link text](url)</code> all work. The page title and "Last updated" line are added automatically.</p>
      <div class="field">
        <textarea id="privacyContent" name="privacy_content" rows="16">{privacy}</textarea>
      </div>
    </section>

    <section class="editor-section">
      <div class="section-header">
        <h2>Terms of Service</h2>
        <a href="/terms" target="_blank" class="btn-sm btn-view">View Page</a>
      </div>
      <p class="help-text">Edit using Markdown. Use <code>{`{EMAIL_LINK}`}</code> to insert your email as a clickable link.</p>
      <div class="field">
        <textarea id="termsContent" name="terms_content" rows="16">{terms}</textarea>
      </div>
    </section>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary" id="saveBtn">Save Changes</button>
      <span id="saveStatus" class="save-status"></span>
    </div>
  </form>
</Admin>

<style>
  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  h1 { font-size: 1.8rem; font-weight: 800; margin: 0; }
  h2 { font-size: 1.3rem; font-weight: 800; margin: 0; color: #2d1f0e; }

  .btn { display: inline-block; padding: 0.55em 1.2em; border-radius: 8px; font-family: inherit; font-weight: 700; font-size: 0.9rem; text-decoration: none; cursor: pointer; border: none; }
  .btn-primary { background: #c87830; color: #faf5ea; }
  .btn-primary:hover { background: #a05e18; }
  .btn-outline { background: transparent; color: #2d1f0e; border: 2px solid #d4b896; }
  .btn-outline:hover { background: #e4d3b8; }
  .btn-sm { display: inline-block; padding: 0.3em 0.7em; border-radius: 6px; font-family: inherit; font-weight: 700; font-size: 0.8rem; text-decoration: none; cursor: pointer; border: none; }
  .btn-view { background: #3d7a6e; color: #faf5ea; }
  .btn-view:hover { background: #2a5a50; }

  .editor-section { background: #faf5ea; border: 2px solid #d4b896; border-radius: 10px; padding: 1.5rem; margin-bottom: 1.5rem; }
  .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem; }
  .help-text { font-size: 0.85rem; color: #6b4a2a; margin: -0.4rem 0 1rem; line-height: 1.5; }
  .help-text code { background: #e4d3b8; padding: 1px 5px; border-radius: 3px; font-size: 0.85em; }

  .field { margin-bottom: 0; }
  .field textarea {
    width: 100%; padding: 0.55em 0.8em; border: 2px solid #d4b896; border-radius: 8px;
    font-family: 'Atkinson', monospace; font-size: 0.85rem; background: #f0e6d0; color: #2d1f0e;
    box-sizing: border-box; resize: vertical; line-height: 1.6;
  }
  .field textarea:focus { border-color: #c87830; outline: none; }

  .form-actions { display: flex; align-items: center; gap: 1rem; }
  .save-status { font-size: 0.9rem; font-weight: 700; }
  .save-status.success { color: #3d7a6e; }
  .save-status.error { color: #b44; }
</style>

<script>
  const form = document.getElementById('legalForm') as HTMLFormElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const saveStatus = document.getElementById('saveStatus')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving...';
    saveStatus.className = 'save-status';

    const formData = new FormData(form);
    const updates: Record<string, string> = {};
    for (const [key, value] of formData.entries()) updates[key] = String(value);

    try {
      const res = await fetch('/api/admin/pages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates }),
      });
      if (res.ok) { saveStatus.textContent = 'Saved!'; saveStatus.className = 'save-status success'; }
      else throw new Error();
    } catch { saveStatus.textContent = 'Error saving.'; saveStatus.className = 'save-status error'; }
    saveBtn.disabled = false;
    setTimeout(() => { saveStatus.textContent = ''; }, 3000);
  });
</script>
