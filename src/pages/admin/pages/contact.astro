---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { getPageContentMulti } from '../../../lib/db';

const db = Astro.locals.runtime.env.DB;
const content = await getPageContentMulti(db, ['contact_header', 'contact_subheader', 'contact_cards']);

const header = content.contact_header ?? 'Get in Touch';
const subheader = content.contact_subheader ?? '';
let cards: { key: string; description: string }[] = [];
try { cards = JSON.parse(content.contact_cards ?? '[]'); } catch {}
---

<Admin title="Contact Page">
  <div class="page-header">
    <h1>Contact Page</h1>
    <a href="/admin/pages" class="btn btn-outline">&larr; All Pages</a>
  </div>

  <form id="contactForm">
    <section class="editor-section">
      <h2>Page Header</h2>
      <div class="field">
        <label for="contact_header">Title</label>
        <input type="text" id="contact_header" name="contact_header" value={header} />
      </div>
      <div class="field">
        <label for="contact_subheader">Subtitle</label>
        <input type="text" id="contact_subheader" name="contact_subheader" value={subheader} />
      </div>
    </section>

    <section class="editor-section">
      <h2>Contact Cards</h2>
      <p class="help-text">Edit the description text on each contact card. Supports basic markdown: <code>**bold**</code>, <code>*italic*</code>, <code>[link text](url)</code>. The card titles, icons, and links are managed in site config.</p>
      <div id="card-list">
        {cards.map(card => (
          <div class="card-field" data-key={card.key}>
            <div class="card-header">
              <span class="card-label">{card.key.charAt(0).toUpperCase() + card.key.slice(1)}</span>
              <div class="card-controls">
                <button type="button" class="move-btn move-up" title="Move up">▲</button>
                <button type="button" class="move-btn move-down" title="Move down">▼</button>
              </div>
            </div>
            <div class="field">
              <label>Description</label>
              <textarea class="card-desc" rows="2">{card.description}</textarea>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary" id="saveBtn">Save Changes</button>
      <span id="saveStatus" class="save-status"></span>
    </div>
  </form>
</Admin>

<style>
  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  h1 { font-size: 1.8rem; font-weight: 800; margin: 0; }
  h2 { font-size: 1.3rem; font-weight: 800; margin: 0 0 0.8rem; color: #2d1f0e; }

  .btn { display: inline-block; padding: 0.55em 1.2em; border-radius: 8px; font-family: inherit; font-weight: 700; font-size: 0.9rem; text-decoration: none; cursor: pointer; border: none; }
  .btn-primary { background: #c87830; color: #faf5ea; }
  .btn-primary:hover { background: #a05e18; }
  .btn-outline { background: transparent; color: #2d1f0e; border: 2px solid #d4b896; }
  .btn-outline:hover { background: #e4d3b8; }

  .editor-section { background: #faf5ea; border: 2px solid #d4b896; border-radius: 10px; padding: 1.5rem; margin-bottom: 1.5rem; }
  .help-text { font-size: 0.85rem; color: #6b4a2a; margin: -0.4rem 0 1rem; line-height: 1.5; }
  .help-text code { background: #e4d3b8; padding: 1px 5px; border-radius: 3px; font-size: 0.85em; }

  .field { margin-bottom: 1rem; }
  .field:last-child { margin-bottom: 0; }
  .field label { display: block; font-weight: 700; font-size: 0.88rem; color: #2d1f0e; margin-bottom: 0.3rem; }
  .field input, .field textarea {
    width: 100%; padding: 0.55em 0.8em; border: 2px solid #d4b896; border-radius: 8px;
    font-family: inherit; font-size: 0.9rem; background: #f0e6d0; color: #2d1f0e; box-sizing: border-box;
  }
  .field input:focus, .field textarea:focus { border-color: #c87830; outline: none; }
  .field textarea { resize: vertical; }

  .card-field { background: #f0e6d0; border: 1px solid #d4b896; border-radius: 8px; padding: 1rem; margin-bottom: 0.8rem; }
  .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem; }
  .card-label { font-weight: 800; font-size: 0.9rem; color: #2d1f0e; }
  .card-controls { display: flex; gap: 0.3rem; }
  .move-btn {
    background: #d4b896; border: none; border-radius: 5px; width: 28px; height: 28px;
    font-size: 0.7rem; cursor: pointer; color: #2d1f0e; line-height: 1;
    transition: background 0.15s;
  }
  .move-btn:hover { background: #c87830; color: #faf5ea; }
  .move-btn:disabled { opacity: 0.3; cursor: default; }

  .form-actions { display: flex; align-items: center; gap: 1rem; }
  .save-status { font-size: 0.9rem; font-weight: 700; }
  .save-status.success { color: #3d7a6e; }
  .save-status.error { color: #b44; }
</style>

<script>
  function updateMoveButtons() {
    const cards = document.querySelectorAll<HTMLElement>('.card-field');
    cards.forEach((card, i) => {
      card.querySelector<HTMLButtonElement>('.move-up')!.disabled = i === 0;
      card.querySelector<HTMLButtonElement>('.move-down')!.disabled = i === cards.length - 1;
    });
  }

  document.getElementById('card-list')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.move-btn') as HTMLElement | null;
    if (!btn) return;
    const card = btn.closest<HTMLElement>('.card-field')!;
    const list = card.parentElement!;
    if (btn.classList.contains('move-up') && card.previousElementSibling) {
      list.insertBefore(card, card.previousElementSibling);
    } else if (btn.classList.contains('move-down') && card.nextElementSibling) {
      list.insertBefore(card.nextElementSibling, card);
    }
    updateMoveButtons();
  });

  updateMoveButtons();

  const form = document.getElementById('contactForm') as HTMLFormElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const saveStatus = document.getElementById('saveStatus')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving...';
    saveStatus.className = 'save-status';

    const formData = new FormData(form);
    const updates: Record<string, string> = {};
    for (const [key, value] of formData.entries()) {
      updates[key] = String(value);
    }

    // Collect card descriptions
    const cards: { key: string; description: string }[] = [];
    document.querySelectorAll('.card-field').forEach(el => {
      cards.push({
        key: (el as HTMLElement).dataset.key!,
        description: (el.querySelector('.card-desc') as HTMLTextAreaElement).value,
      });
    });
    updates.contact_cards = JSON.stringify(cards);

    try {
      const res = await fetch('/api/admin/pages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates }),
      });
      if (res.ok) { saveStatus.textContent = 'Saved!'; saveStatus.className = 'save-status success'; }
      else throw new Error();
    } catch { saveStatus.textContent = 'Error saving.'; saveStatus.className = 'save-status error'; }
    saveBtn.disabled = false;
    setTimeout(() => { saveStatus.textContent = ''; }, 3000);
  });
</script>
