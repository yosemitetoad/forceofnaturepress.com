---
export const prerender = false;

import Admin from '../../layouts/Admin.astro';
import { getAllComments } from '../../lib/db';

const db = Astro.locals.runtime.env.DB;
const comments = await getAllComments(db);
---

<Admin title="Comment Moderation">
  <div class="page-header">
    <h1>Comments</h1>
    <span class="count">{comments.length} total</span>
  </div>

  {comments.length === 0 ? (
    <p class="empty">No comments yet.</p>
  ) : (
    <div class="comment-list">
      {comments.map(c => (
        <div class:list={['comment-card', { pending: !c.approved }]} data-id={c.id}>
          <div class="comment-meta">
            <span class="author">{c.authorName}</span>
            <span class="post-title">on <strong>{c.postTitle ?? `Post #${c.postId}`}</strong></span>
            <span class="date">{new Date(c.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' })}</span>
            <span class:list={['badge', { approved: c.approved, pending: !c.approved }]}>
              {c.approved ? 'Approved' : 'Pending'}
            </span>
          </div>
          <p class="comment-body">{c.content}</p>
          <div class="comment-actions">
            {!c.approved && (
              <button class="approve-btn" data-id={c.id}>Approve</button>
            )}
            <button class="delete-btn" data-id={c.id}>Delete</button>
          </div>
        </div>
      ))}
    </div>
  )}
</Admin>

<style>
  .page-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; }
  h1 { font-size: 1.8rem; font-weight: 800; margin: 0; }
  .count { color: #8b7355; font-size: 0.9rem; }

  .empty { color: #8b7355; font-style: italic; }

  .comment-list { display: flex; flex-direction: column; gap: 1rem; }
  .comment-card {
    background: #faf5ea; border: 2px solid #d4b896; border-radius: 10px; padding: 1rem 1.2rem;
  }
  .comment-card.pending { border-left: 4px solid #c87830; }
  .comment-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; font-size: 0.85rem; }
  .author { font-weight: 800; }
  .post-title { color: #8b7355; }
  .date { color: #8b7355; }
  .badge {
    font-size: 0.72rem; font-weight: 800; padding: 0.15em 0.6em; border-radius: 10px;
  }
  .badge.approved { background: #5b7b6d; color: #faf5ea; }
  .badge.pending { background: #c87830; color: #faf5ea; }
  .comment-body { font-size: 0.92rem; line-height: 1.6; margin: 0 0 0.8rem; white-space: pre-wrap; }
  .comment-actions { display: flex; gap: 0.5rem; }
  .approve-btn {
    background: #5b7b6d; color: #faf5ea; border: none; padding: 0.4em 1em;
    border-radius: 6px; font-family: inherit; font-weight: 700; font-size: 0.82rem; cursor: pointer;
  }
  .approve-btn:hover { background: #3d5a4e; }
  .delete-btn {
    background: #b44; color: #faf5ea; border: none; padding: 0.4em 1em;
    border-radius: 6px; font-family: inherit; font-weight: 700; font-size: 0.82rem; cursor: pointer;
  }
  .delete-btn:hover { background: #833; }
</style>

<script>
  document.querySelectorAll('.approve-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.id;
      try {
        const res = await fetch(`/api/admin/comments/${id}`, { method: 'PUT' });
        if (!res.ok) throw new Error();
        const card = (btn as HTMLElement).closest('.comment-card') as HTMLElement;
        card.classList.remove('pending');
        const badge = card.querySelector('.badge') as HTMLElement;
        badge.textContent = 'Approved';
        badge.className = 'badge approved';
        (btn as HTMLElement).remove();
      } catch {
        alert('Failed to approve comment');
      }
    });
  });

  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete this comment?')) return;
      const id = (btn as HTMLElement).dataset.id;
      try {
        const res = await fetch(`/api/admin/comments/${id}`, { method: 'DELETE' });
        if (!res.ok) throw new Error();
        const card = (btn as HTMLElement).closest('.comment-card') as HTMLElement;
        card.style.opacity = '0.3';
        setTimeout(() => card.remove(), 300);
      } catch {
        alert('Failed to delete comment');
      }
    });
  });
</script>
