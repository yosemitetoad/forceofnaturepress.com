---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { getAllShopItems } from '../../../lib/db';
import { CATEGORY_LABELS, getEtsyUrl } from '../../../data/shop';

const db = Astro.locals.runtime.env.DB;
const items = await getAllShopItems(db);

const categories = Object.entries(CATEGORY_LABELS);
const activeCategory = Astro.url.searchParams.get('category') ?? 'all';
---

<Admin title="Shop Items">
  <div class="page-header">
    <h1>Shop Items ({items.length})</h1>
    <a href="/admin/shop/new" class="btn btn-primary">+ Add Item</a>
  </div>

  <div class="controls">
    <input type="search" id="search" placeholder="Search items..." class="search-input" />
    <select id="category-filter" class="control-select">
      <option value="all" selected={activeCategory === 'all'}>All Categories</option>
      {categories.map(([value, label]) => (
        <option value={value} selected={value === activeCategory}>{label}</option>
      ))}
    </select>
    <select id="sort-select" class="control-select">
      <option value="default">Sort: Default</option>
      <option value="title-asc">Title: A-Z</option>
      <option value="title-desc">Title: Z-A</option>
      <option value="price-asc">Price: Low-High</option>
      <option value="price-desc">Price: High-Low</option>
      <option value="category">Category</option>
    </select>
    <span id="result-count" class="result-count"></span>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Image</th>
          <th>Title</th>
          <th>SKU</th>
          <th>Category</th>
          <th>Price</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="item-tbody">
        {items.map((item) => (
          <tr data-title={item.title.toLowerCase()} data-sku={item.sku.toLowerCase()} data-category={item.category} data-price={item.price}>
            <td><img src={item.image} alt="" class="thumb" /></td>
            <td class="title-cell">{item.title}</td>
            <td><code>{item.sku}</code></td>
            <td>{CATEGORY_LABELS[item.category] ?? item.category}</td>
            <td>${item.price.toFixed(2)}</td>
            <td class="actions-cell">
              <a href={`/admin/shop/${item.sku}`} class="btn-sm btn-edit">Edit</a>
              <button class="btn-sm btn-delete" data-sku={item.sku} data-title={item.title}>Delete</button>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p id="no-results" class="no-results" style="display:none">No items match your filters.</p>
</Admin>

<style>
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  h1 { font-size: 1.8rem; font-weight: 800; margin: 0; }
  .btn { display: inline-block; padding: 0.55em 1.2em; border-radius: 8px; font-family: inherit; font-weight: 700; font-size: 0.9rem; text-decoration: none; cursor: pointer; border: none; }
  .btn-primary { background: #c87830; color: #faf5ea; }
  .btn-primary:hover { background: #a05e18; }

  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  .search-input {
    padding: 0.5em 0.8em;
    border: 2px solid #d4b896;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.9rem;
    background: #faf5ea;
    color: #2d1f0e;
    width: 220px;
  }
  .search-input:focus { border-color: #c87830; outline: none; }
  .control-select {
    padding: 0.5em 0.8em;
    border: 2px solid #d4b896;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.9rem;
    background: #faf5ea;
    color: #2d1f0e;
  }
  .control-select:focus { border-color: #c87830; outline: none; }
  .result-count {
    font-size: 0.85rem;
    color: #6b4a2a;
    font-weight: 700;
    margin-left: auto;
  }

  .table-wrap {
    background: #faf5ea;
    border: 2px solid #d4b896;
    border-radius: 10px;
    overflow: hidden;
  }
  table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  thead { background: #2d1f0e; color: #faf5ea; }
  th { padding: 0.7rem 0.8rem; text-align: left; font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.03em; }
  td { padding: 0.6rem 0.8rem; border-bottom: 1px solid #e4d3b8; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover { background: rgba(200, 120, 48, 0.05); }
  .thumb { width: 48px; height: 48px; object-fit: cover; border-radius: 6px; }
  .title-cell { font-weight: 700; max-width: 280px; }
  code { background: #e4d3b8; padding: 2px 6px; border-radius: 4px; font-size: 0.8rem; }
  .actions-cell { white-space: nowrap; }
  .btn-sm {
    display: inline-block;
    padding: 0.3em 0.7em;
    border-radius: 6px;
    font-family: inherit;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    cursor: pointer;
    border: none;
  }
  .btn-edit { background: #3d7a6e; color: #faf5ea; }
  .btn-edit:hover { background: #2a5a50; }
  .btn-delete { background: #b44; color: #faf5ea; }
  .btn-delete:hover { background: #833; }
  .no-results {
    text-align: center;
    color: #6b4a2a;
    font-style: italic;
    padding: 1.5rem 0;
  }
</style>

<script>
  const search = document.getElementById('search') as HTMLInputElement;
  const catFilter = document.getElementById('category-filter') as HTMLSelectElement;
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const tbody = document.getElementById('item-tbody')!;
  const noResults = document.getElementById('no-results')!;
  const resultCount = document.getElementById('result-count')!;

  function applyFilters() {
    const query = search.value.toLowerCase().trim();
    const cat = catFilter.value;
    const sort = sortSelect.value;

    const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr'));

    // Sort
    rows.sort((a, b) => {
      if (sort === 'title-asc') return a.dataset.title!.localeCompare(b.dataset.title!);
      if (sort === 'title-desc') return b.dataset.title!.localeCompare(a.dataset.title!);
      if (sort === 'price-asc') return Number(a.dataset.price) - Number(b.dataset.price);
      if (sort === 'price-desc') return Number(b.dataset.price) - Number(a.dataset.price);
      if (sort === 'category') return a.dataset.category!.localeCompare(b.dataset.category!);
      return 0;
    });

    let visible = 0;
    rows.forEach(row => {
      tbody.appendChild(row);
      const matchesCat = cat === 'all' || row.dataset.category === cat;
      const matchesSearch = !query || row.dataset.title!.includes(query) || row.dataset.sku!.includes(query);
      const show = matchesCat && matchesSearch;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults.style.display = visible === 0 ? '' : 'none';
    resultCount.textContent = `${visible} of ${rows.length} items`;
  }

  search.addEventListener('input', applyFilters);
  catFilter.addEventListener('change', applyFilters);
  sortSelect.addEventListener('change', applyFilters);

  // Delete handlers
  document.querySelectorAll('.btn-delete').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const sku = (btn as HTMLElement).dataset.sku;
      const title = (btn as HTMLElement).dataset.title;
      if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;

      const res = await fetch(`/api/admin/shop/${sku}`, { method: 'DELETE' });
      if (res.ok) {
        (btn as HTMLElement).closest('tr')?.remove();
        applyFilters();
      } else {
        alert('Failed to delete item.');
      }
    });
  });

  // Initialize
  applyFilters();
</script>
