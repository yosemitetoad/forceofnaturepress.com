---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import { getAllShopItems, getShopCategories } from '../../../lib/db';
import { CATEGORY_LABELS } from '../../../data/shop';

const db = Astro.locals.runtime.env.DB;
const items = await getAllShopItems(db);

let categories: {slug: string, label: string}[] = Object.entries(CATEGORY_LABELS).map(([slug, label]) => ({ slug, label }));
try {
  const dbCats = await getShopCategories(db);
  if (dbCats.length > 0) categories = dbCats;
} catch {}
---

<Admin title="Reorder Shop Items">
  <div class="page-header">
    <h1>Reorder Shop Items</h1>
    <a href="/admin/shop" class="btn btn-outline">&larr; Back to Shop</a>
  </div>
  <p class="help-text">Drag items to set the default display order on the shop page. Use the category filter to focus on one category, or reorder everything together to intersperse categories. Hit Save Order when done.</p>

  <div class="controls">
    <select id="catFilter" class="control-select">
      <option value="all">All Categories</option>
      {categories.map(({ slug, label }) => (
        <option value={slug}>{label}</option>
      ))}
    </select>
    <span id="visibleCount" class="result-count"></span>
    <button id="saveBtn" class="btn btn-primary">Save Order</button>
    <span id="saveStatus" class="save-status"></span>
  </div>

  <div id="reorderList" class="reorder-list">
    {items.map(item => {
      const catLabel = categories.find(c => c.slug === item.category)?.label ?? item.category;
      return (
        <div class="reorder-row" draggable="true" data-sku={item.sku} data-category={item.category}>
          <span class="drag-handle" title="Drag to reorder">⠿</span>
          <img src={item.image} alt="" class="thumb" />
          <span class="item-title">{item.title}</span>
          <span class="cat-badge">{catLabel}</span>
        </div>
      );
    })}
  </div>
  <p id="noResults" class="no-results" style="display:none">No items in this category.</p>
</Admin>

<style>
  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.8rem; }
  h1 { font-size: 1.8rem; font-weight: 800; margin: 0; }

  .btn { display: inline-block; padding: 0.55em 1.2em; border-radius: 8px; font-family: inherit; font-weight: 700; font-size: 0.9rem; text-decoration: none; cursor: pointer; border: none; }
  .btn-primary { background: #c87830; color: #faf5ea; }
  .btn-primary:hover { background: #a05e18; }
  .btn-primary:disabled { opacity: 0.6; cursor: default; }
  .btn-outline { background: transparent; color: #2d1f0e; border: 2px solid #d4b896; }
  .btn-outline:hover { background: #e4d3b8; }

  .help-text { font-size: 0.88rem; color: #6b4a2a; margin: 0 0 1rem; line-height: 1.5; }

  .controls { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .control-select {
    padding: 0.5em 0.8em; border: 2px solid #d4b896; border-radius: 8px;
    font-family: inherit; font-size: 0.9rem; background: #faf5ea; color: #2d1f0e;
  }
  .control-select:focus { border-color: #c87830; outline: none; }
  .result-count { font-size: 0.85rem; color: #6b4a2a; font-weight: 700; }
  .save-status { font-size: 0.9rem; font-weight: 700; }
  .save-status.success { color: #3d7a6e; }
  .save-status.error { color: #b44; }

  .reorder-list {
    background: #faf5ea;
    border: 2px solid #d4b896;
    border-radius: 10px;
    overflow: hidden;
  }

  .reorder-row {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.5rem 0.8rem;
    border-bottom: 1px solid #e4d3b8;
    background: #faf5ea;
    cursor: default;
    user-select: none;
    transition: background 0.1s;
  }
  .reorder-row:last-child { border-bottom: none; }
  .reorder-row.dragging { opacity: 0.4; }
  .reorder-row.drag-over { background: rgba(200, 120, 48, 0.1); border-top: 2px solid #c87830; }
  .reorder-row[style*="display: none"] { display: none !important; }

  .drag-handle { cursor: grab; color: #a08060; font-size: 1.2rem; padding: 0 0.2rem; flex-shrink: 0; }
  .drag-handle:active { cursor: grabbing; }
  .thumb { width: 44px; height: 44px; object-fit: cover; border-radius: 6px; flex-shrink: 0; }
  .item-title { flex: 1; font-weight: 700; font-size: 0.9rem; color: #2d1f0e; }
  .cat-badge {
    font-size: 0.75rem; font-weight: 700; padding: 0.2em 0.6em;
    background: #e4d3b8; color: #6b4a2a; border-radius: 999px; flex-shrink: 0;
  }

  .no-results { text-align: center; color: #6b4a2a; font-style: italic; padding: 1.5rem 0; }
</style>

<script>
  const list = document.getElementById('reorderList')!;
  const catFilter = document.getElementById('catFilter') as HTMLSelectElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const saveStatus = document.getElementById('saveStatus')!;
  const visibleCount = document.getElementById('visibleCount')!;
  const noResults = document.getElementById('noResults')!;

  let dragEl: HTMLElement | null = null;

  // ── Drag-to-reorder ──
  list.addEventListener('dragstart', (e) => {
    dragEl = (e.target as HTMLElement).closest('.reorder-row') as HTMLElement;
    if (dragEl) setTimeout(() => dragEl!.classList.add('dragging'), 0);
  });
  list.addEventListener('dragend', () => {
    dragEl?.classList.remove('dragging');
    list.querySelectorAll('.reorder-row').forEach(r => r.classList.remove('drag-over'));
    dragEl = null;
  });
  list.addEventListener('dragover', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('.reorder-row') as HTMLElement;
    list.querySelectorAll('.reorder-row').forEach(r => r.classList.remove('drag-over'));
    if (target && target !== dragEl) {
      const rect = target.getBoundingClientRect();
      if (e.clientY < rect.top + rect.height / 2) {
        list.insertBefore(dragEl!, target);
      } else {
        target.after(dragEl!);
      }
      target.classList.add('drag-over');
    }
  });
  list.addEventListener('drop', (e) => {
    e.preventDefault();
    list.querySelectorAll('.reorder-row').forEach(r => r.classList.remove('drag-over'));
  });

  // ── Category filter ──
  function applyFilter() {
    const cat = catFilter.value;
    const rows = Array.from(list.querySelectorAll<HTMLElement>('.reorder-row'));
    let visible = 0;
    rows.forEach(row => {
      const show = cat === 'all' || row.dataset.category === cat;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    visibleCount.textContent = cat === 'all' ? `${visible} items` : `${visible} items in this category`;
    noResults.style.display = visible === 0 ? '' : 'none';
  }
  catFilter.addEventListener('change', applyFilter);
  applyFilter();

  // ── Save ──
  saveBtn.addEventListener('click', async () => {
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving...';
    saveStatus.className = 'save-status';

    // Collect all SKUs in current DOM order (all rows, not just visible)
    const allSkus = Array.from(list.querySelectorAll<HTMLElement>('.reorder-row'))
      .map(r => r.dataset.sku!);

    try {
      const res = await fetch('/api/admin/shop/reorder', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ skus: allSkus }),
      });
      if (res.ok) {
        saveStatus.textContent = 'Order saved!';
        saveStatus.className = 'save-status success';
      } else {
        throw new Error();
      }
    } catch {
      saveStatus.textContent = 'Error saving. Try again.';
      saveStatus.className = 'save-status error';
    }

    saveBtn.disabled = false;
    setTimeout(() => { saveStatus.textContent = ''; }, 3000);
  });
</script>
