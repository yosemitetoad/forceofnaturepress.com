---
export const prerender = false;
import Admin from '../../layouts/Admin.astro';
import { getAllRedirects } from '../../lib/db';

const db = Astro.locals.runtime.env.DB;
const redirects = await getAllRedirects(db);
---

<Admin title="Redirects">
  <h1>Redirects</h1>
  <p class="subtitle">When a URL on your site changes, add a redirect here so old links still work. Takes effect immediately — no redeploy needed.</p>

  <div class="add-box">
    <h2>Add Redirect</h2>
    <form id="add-form">
      <div class="add-row">
        <div class="add-field">
          <label for="from-path">From</label>
          <input type="text" id="from-path" placeholder="/old-url" required />
        </div>
        <div class="arrow">→</div>
        <div class="add-field">
          <label for="to-path">To</label>
          <input type="text" id="to-path" placeholder="/new-url" required />
        </div>
        <button type="submit" class="btn btn-primary" id="add-btn">Add</button>
      </div>
      <div id="add-status" class="status hidden"></div>
    </form>
  </div>

  <div class="list-box">
    <h2>Active Redirects</h2>
    <div id="redirect-list">
      {redirects.length === 0
        ? <p class="empty">No redirects yet.</p>
        : (
          <table class="redirect-table">
            <thead>
              <tr>
                <th>From</th>
                <th>To</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="redirect-tbody">
              {redirects.map(r => (
                <tr data-id={r.id}>
                  <td class="path from-path">{r.fromPath}</td>
                  <td class="path">{r.toPath}</td>
                  <td class="actions">
                    <button class="btn btn-danger delete-btn" data-id={r.id}>Delete</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )
      }
    </div>
  </div>
</Admin>

<style>
  h1 { font-size: 2rem; font-weight: 800; margin-bottom: 0.25rem; }
  h2 { font-size: 1.2rem; font-weight: 800; margin: 0 0 1rem; }
  .subtitle { color: #6b4a2a; margin: 0 0 2rem; font-size: 0.95rem; }

  .add-box, .list-box {
    background: #faf5ea;
    border: 2px solid #d4b896;
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    max-width: 800px;
  }

  .add-row {
    display: flex;
    align-items: flex-end;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .add-field { display: flex; flex-direction: column; gap: 0.3rem; flex: 1; min-width: 160px; }
  .add-field label { font-weight: 700; font-size: 0.85rem; color: #6b4a2a; }
  .add-field input {
    padding: 0.5em 0.8em; border: 2px solid #d4b896; border-radius: 8px;
    font-family: inherit; font-size: 0.9rem; background: #f0e6d0; color: #2d1f0e;
  }
  .add-field input:focus { border-color: #c87830; outline: none; }

  .arrow { font-size: 1.3rem; color: #6b4a2a; padding-bottom: 0.3rem; }

  .btn {
    padding: 0.5em 1.2em; border-radius: 8px; font-family: inherit;
    font-weight: 700; font-size: 0.9rem; cursor: pointer; border: none;
    transition: background 0.15s; white-space: nowrap;
  }
  .btn-primary { background: #c87830; color: #faf5ea; }
  .btn-primary:hover:not(:disabled) { background: #a05e18; }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn-danger { background: #b44; color: white; font-size: 0.8rem; padding: 0.3em 0.8em; }
  .btn-danger:hover { background: #833; }

  .status { margin-top: 0.8rem; padding: 0.5rem 0.9rem; border-radius: 8px; font-weight: 700; font-size: 0.88rem; }
  .status.hidden { display: none; }
  .status.success { background: #e8f5e9; border: 2px solid #4caf50; color: #2e7d32; }
  .status.error { background: #fdecea; border: 2px solid #b44; color: #b44; }

  .empty { color: #6b4a2a; font-style: italic; margin: 0; }

  .redirect-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
  .redirect-table th {
    text-align: left; padding: 0.5rem 0.6rem; border-bottom: 2px solid #d4b896;
    font-weight: 800; color: #6b4a2a; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .redirect-table td { padding: 0.6rem; border-bottom: 1px solid #e4d3b8; vertical-align: middle; }
  .redirect-table tr:last-child td { border-bottom: none; }
  .path { font-family: monospace; font-size: 0.88rem; word-break: break-all; }
  .from-path { color: #6b4a2a; }
  .actions { text-align: right; white-space: nowrap; }
</style>

<script>
  const addForm = document.getElementById('add-form') as HTMLFormElement;
  const fromInput = document.getElementById('from-path') as HTMLInputElement;
  const toInput = document.getElementById('to-path') as HTMLInputElement;
  const addBtn = document.getElementById('add-btn') as HTMLButtonElement;
  const addStatus = document.getElementById('add-status')!;
  const listEl = document.getElementById('redirect-list')!;

  function showStatus(msg: string, type: 'success' | 'error') {
    addStatus.textContent = msg;
    addStatus.className = `status ${type}`;
    setTimeout(() => { addStatus.className = 'status hidden'; }, 3000);
  }

  function makeRow(r: { id: number; fromPath: string; toPath: string }): HTMLTableRowElement {
    const tr = document.createElement('tr');
    tr.dataset.id = String(r.id);
    tr.innerHTML = `
      <td class="path from-path">${r.fromPath}</td>
      <td class="path">${r.toPath}</td>
      <td class="actions"><button class="btn btn-danger delete-btn" data-id="${r.id}">Delete</button></td>
    `;
    return tr;
  }

  function ensureTable() {
    let table = listEl.querySelector('table');
    if (!table) {
      listEl.innerHTML = `
        <table class="redirect-table">
          <thead><tr><th>From</th><th>To</th><th></th></tr></thead>
          <tbody id="redirect-tbody"></tbody>
        </table>
      `;
    }
    return listEl.querySelector<HTMLTableSectionElement>('#redirect-tbody')!;
  }

  addForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fromPath = fromInput.value.trim();
    const toPath = toInput.value.trim();
    if (!fromPath.startsWith('/')) {
      showStatus('From path must start with /', 'error');
      return;
    }

    addBtn.disabled = true;
    try {
      const res = await fetch('/api/admin/redirects', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ fromPath, toPath }),
      });
      const data = await res.json();
      if (res.ok) {
        // Fetch the new ID by reloading the list
        const listRes = await fetch('/api/admin/redirects');
        const listData = await listRes.json();
        const newEntry = listData.redirects.find((r: any) => r.fromPath === fromPath);
        if (newEntry) {
          const tbody = ensureTable();
          tbody.prepend(makeRow(newEntry));
        }
        addForm.reset();
        showStatus('Redirect added.', 'success');
      } else {
        showStatus(data.error || 'Failed to add redirect.', 'error');
      }
    } catch {
      showStatus('Failed to add redirect.', 'error');
    }
    addBtn.disabled = false;
  });

  listEl.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.delete-btn') as HTMLElement | null;
    if (!btn) return;
    const id = Number(btn.dataset.id);
    if (!confirm('Delete this redirect?')) return;

    const res = await fetch('/api/admin/redirects', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id }),
    });
    if (res.ok) {
      const row = listEl.querySelector<HTMLTableRowElement>(`tr[data-id="${id}"]`);
      row?.remove();
      const tbody = listEl.querySelector('tbody');
      if (tbody && tbody.children.length === 0) {
        listEl.innerHTML = '<p class="empty">No redirects yet.</p>';
      }
    }
  });
</script>
