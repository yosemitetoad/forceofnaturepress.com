---
export const prerender = false;

import Admin from '../../../layouts/Admin.astro';
import BlogEditor from '../../../components/BlogEditor.astro';
---

<Admin title="New Blog Post">
  <div class="page-header">
    <h1>New Post</h1>
    <a href="/admin/blog" class="back-link">Back to Posts</a>
  </div>

  <form id="postForm" class="post-form">
    <div class="form-row">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" required placeholder="Your post title" />
    </div>

    <div class="form-row">
      <label for="slug">URL Slug</label>
      <input type="text" id="slug" name="slug" required placeholder="your-post-title" pattern="[a-z0-9\-]+" />
      <span class="hint">Lowercase letters, numbers, and hyphens only. This becomes the URL.</span>
    </div>

    <div class="form-row">
      <label for="author">Author</label>
      <input type="text" id="author" name="author" value="Riley" placeholder="Author name" />
    </div>

    <div class="form-row">
      <label for="coverImage">Cover Image <span class="optional">(optional)</span></label>
      <div class="upload-row">
        <input type="url" id="coverImage" name="coverImage" placeholder="Image URL or upload below" style="flex:1" />
        <label class="upload-btn">
          Upload
          <input type="file" id="coverUpload" accept="image/*" hidden />
        </label>
      </div>
      <div id="uploadProgress" class="upload-progress" style="display:none">Uploading...</div>
      <div id="coverPreview" class="cover-preview" style="display:none">
        <img id="coverImg" src="" alt="Cover preview" />
      </div>
    </div>

    <div class="form-row">
      <label>Post Content</label>
      <BlogEditor />
    </div>

    <div class="form-row">
      <label for="excerpt">Excerpt / Summary <span class="optional">(optional)</span></label>
      <textarea id="excerpt" name="excerpt" rows="2" placeholder="A brief summary shown in post listings..."></textarea>
    </div>

    <div class="form-row">
      <label for="tags">Tags <span class="optional">(optional)</span></label>
      <input type="text" id="tags" name="tags" placeholder="nature, art, stickers — separate with commas" />
      <span class="hint">Comma-separated labels for organizing and filtering posts.</span>
    </div>

    <div class="form-actions">
      <label class="publish-toggle">
        <input type="checkbox" id="published" name="published" />
        <span>Publish immediately</span>
      </label>
      <div class="action-buttons">
        <button type="button" id="previewBtn" class="preview-btn">Preview</button>
        <button type="submit" class="save-btn" id="saveBtn">Save Draft</button>
      </div>
    </div>
  </form>

  <!-- Preview modal -->
  <div id="previewOverlay" class="preview-overlay" style="display:none">
    <div class="preview-modal">
      <div class="preview-header">
        <span>Preview</span>
        <button type="button" id="previewClose" class="preview-close">&times;</button>
      </div>
      <div class="preview-body" id="previewBody"></div>
    </div>
  </div>
</Admin>

<style>
  .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  h1 { font-size: 1.8rem; font-weight: 800; margin: 0; }
  .back-link { color: #3d7a6e; font-weight: 700; font-size: 0.9rem; }

  .post-form { display: flex; flex-direction: column; gap: 1.2rem; }
  .form-row { display: flex; flex-direction: column; gap: 0.3rem; }
  .form-row label { font-weight: 800; font-size: 0.9rem; }
  .optional { font-weight: 400; color: #8b7355; }
  .hint { font-size: 0.75rem; color: #8b7355; }

  input[type="text"], input[type="url"], textarea {
    font-family: inherit; font-size: 0.95rem; padding: 0.6em 0.8em;
    border: 2px solid #d4b896; border-radius: 8px; background: #faf5ea;
  }
  input:focus, textarea:focus { outline: none; border-color: #c87830; }
  #title { font-size: 1.3rem; font-weight: 700; }

  .upload-row { display: flex; gap: 0.5rem; align-items: center; }
  .upload-btn {
    background: #c87830; color: #faf5ea; padding: 0.6em 1.1em; border-radius: 8px;
    font-family: inherit; font-weight: 700; font-size: 0.9rem; cursor: pointer; white-space: nowrap;
  }
  .upload-btn:hover { background: #a05e18; }
  .upload-progress { font-size: 0.85rem; color: #c87830; font-weight: 700; margin-top: 0.3rem; }
  .cover-preview { margin-top: 0.5rem; }
  .cover-preview img { max-width: 300px; max-height: 160px; border-radius: 8px; object-fit: cover; border: 2px solid #d4b896; }

  .form-actions {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem; background: #faf5ea; border: 2px solid #d4b896; border-radius: 10px;
  }
  .publish-toggle { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; font-size: 0.9rem; cursor: pointer; }
  .publish-toggle input { width: 18px; height: 18px; accent-color: #5b7b6d; }
  .save-btn {
    background: #5b7b6d; color: #faf5ea; border: none; padding: 0.6em 1.5em;
    border-radius: 8px; font-family: inherit; font-weight: 800; font-size: 0.95rem; cursor: pointer;
  }
  .save-btn:hover { background: #3d5a4e; }
  .save-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .preview-btn {
    background: #c87830; color: #faf5ea; border: none; padding: 0.6em 1.5em;
    border-radius: 8px; font-family: inherit; font-weight: 800; font-size: 0.95rem; cursor: pointer;
  }
  .preview-btn:hover { background: #a05e18; }

  .preview-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.5); z-index: 1000;
    display: flex; align-items: flex-start; justify-content: center;
    padding: 2rem; overflow-y: auto;
  }
  .preview-modal {
    background: #faf5ea; border-radius: 12px; width: 780px; max-width: 100%;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3); overflow: hidden;
  }
  .preview-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.8rem 1.2rem; background: #2d1f0e; color: #faf5ea;
    font-weight: 800; font-size: 0.95rem;
  }
  .preview-close {
    background: none; border: none; color: #e4d3b8; font-size: 1.5rem;
    cursor: pointer; line-height: 1;
  }
  .preview-close:hover { color: #faf5ea; }
  .preview-body {
    padding: 2rem 2.5rem; line-height: 1.7; font-size: 0.95rem;
  }
  .preview-body .preview-title { font-size: 1.8rem; font-weight: 800; margin: 0 0 0.2rem; }
  .preview-body .preview-author { font-size: 1rem; color: #8b7355; margin: 0 0 0.3rem; font-style: italic; }
  .preview-body .preview-date { font-size: 0.85rem; color: #8b7355; margin-bottom: 1rem; }
  .preview-body .preview-cover { max-width: 100%; border-radius: 10px; margin-bottom: 1.5rem; }
  .preview-body .preview-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 1rem; }
  .preview-body .preview-tag {
    font-size: 0.75rem; background: #e8d5b7; padding: 0.2em 0.6em;
    border-radius: 10px; font-weight: 700; color: #6b4a2a;
  }
  .preview-body hr { border: none; border-top: 1px solid #d4b896; margin: 1rem 0; }
  .preview-body .preview-content h2 { font-size: 1.4rem; margin: 1.5em 0 0.5em; }
  .preview-body .preview-content h3 { font-size: 1.15rem; margin: 1.2em 0 0.4em; }
  .preview-body .preview-content p { margin: 0 0 1em; line-height: 1.7; }
  .preview-body .preview-content blockquote {
    border-left: 4px solid #c87830; margin: 1em 0; padding: 0.5em 1.2em;
    background: rgba(200,120,48,0.06); color: #6b4a2a; font-style: italic;
  }
  .preview-body .preview-content img { max-width: 100%; border-radius: 8px; margin: 1em 0; }
  .preview-body .preview-content a { color: #3d7a6e; }
  .preview-body .preview-content ul, .preview-body .preview-content ol { margin: 0.5em 0; padding-left: 1.5em; }
</style>

<script>
  // Auto-generate slug from title
  const titleEl = document.getElementById('title') as HTMLInputElement;
  const slugEl = document.getElementById('slug') as HTMLInputElement;
  let slugEdited = false;

  slugEl.addEventListener('input', () => { slugEdited = true; });
  titleEl.addEventListener('input', () => {
    if (!slugEdited) {
      slugEl.value = titleEl.value
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
    }
  });

  // Cover image preview + upload
  const coverInput = document.getElementById('coverImage') as HTMLInputElement;
  const coverPreview = document.getElementById('coverPreview') as HTMLElement;
  const coverImg = document.getElementById('coverImg') as HTMLImageElement;
  const coverUpload = document.getElementById('coverUpload') as HTMLInputElement;
  const uploadProgress = document.getElementById('uploadProgress') as HTMLElement;

  coverInput.addEventListener('input', () => {
    if (coverInput.value) { coverImg.src = coverInput.value; coverPreview.style.display = 'block'; }
    else { coverPreview.style.display = 'none'; }
  });

  coverUpload.addEventListener('change', async () => {
    const file = coverUpload.files?.[0];
    if (!file) return;
    uploadProgress.style.display = 'block';
    uploadProgress.textContent = 'Uploading...';
    try {
      const form = new FormData();
      form.append('file', file);
      const res = await fetch('/api/admin/upload', { method: 'POST', body: form });
      if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Upload failed'); }
      const { url } = await res.json();
      coverInput.value = url;
      coverImg.src = url;
      coverPreview.style.display = 'block';
      uploadProgress.textContent = 'Uploaded!';
      setTimeout(() => { uploadProgress.style.display = 'none'; }, 2000);
    } catch (err: any) {
      uploadProgress.textContent = err.message;
      setTimeout(() => { uploadProgress.style.display = 'none'; }, 3000);
    }
    coverUpload.value = '';
  });

  // Published toggle
  const publishedCheckbox = document.getElementById('published') as HTMLInputElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  publishedCheckbox.addEventListener('change', () => {
    saveBtn.textContent = publishedCheckbox.checked ? 'Publish' : 'Save Draft';
  });

  // Submit
  document.getElementById('postForm')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    const content = document.getElementById('editor')!.innerHTML;
    const tagsRaw = (document.getElementById('tags') as HTMLInputElement).value;
    const tags = tagsRaw.split(',').map(t => t.trim()).filter(Boolean);

    const body = {
      title: titleEl.value,
      slug: slugEl.value,
      content,
      excerpt: (document.getElementById('excerpt') as HTMLTextAreaElement).value,
      coverImage: coverInput.value || undefined,
      published: publishedCheckbox.checked,
      tags,
      author: (document.getElementById('author') as HTMLInputElement).value || 'Riley',
    };

    try {
      const res = await fetch('/api/admin/blog', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (!res.ok) { const err = await res.json(); throw new Error(err.error || 'Failed to save'); }
      const { id } = await res.json();
      window.location.href = `/admin/blog/${id}`;
    } catch (err: any) {
      alert(err.message);
      saveBtn.disabled = false;
      saveBtn.textContent = publishedCheckbox.checked ? 'Publish' : 'Save Draft';
    }
  });

  // Preview
  const previewOverlay = document.getElementById('previewOverlay') as HTMLElement;
  const previewBody = document.getElementById('previewBody') as HTMLElement;

  document.getElementById('previewBtn')!.addEventListener('click', () => {
    const title = titleEl.value || 'Untitled Post';
    const coverImage = coverInput.value;
    const content = document.getElementById('editor')!.innerHTML;
    const tagsRaw = (document.getElementById('tags') as HTMLInputElement).value;
    const tags = tagsRaw.split(',').map(t => t.trim()).filter(Boolean);
    const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

    const author = (document.getElementById('author') as HTMLInputElement).value;
    let html = `<h1 class="preview-title">${title}</h1>`;
    if (author) html += `<p class="preview-author">by ${author}</p>`;
    html += `<div class="preview-date">${today}</div>`;
    if (coverImage) html += `<img class="preview-cover" src="${coverImage}" alt="" />`;
    if (tags.length) html += `<div class="preview-tags">${tags.map(t => `<span class="preview-tag">${t}</span>`).join('')}</div>`;
    html += `<hr>`;
    html += `<div class="preview-content">${content}</div>`;

    previewBody.innerHTML = html;
    previewOverlay.style.display = 'flex';
  });

  document.getElementById('previewClose')!.addEventListener('click', () => {
    previewOverlay.style.display = 'none';
  });
  previewOverlay.addEventListener('click', (e) => {
    if (e.target === previewOverlay) previewOverlay.style.display = 'none';
  });
</script>
