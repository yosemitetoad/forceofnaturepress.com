---
export const prerender = false;
import { getPageContentMulti } from '../lib/db';
import { mdInline, md } from '../lib/markdown';

const db = Astro.locals.runtime?.env?.DB;
const content = db ? await getPageContentMulti(db, [
  'under_construction_heading',
  'under_construction_subtitle',
  'under_construction_message',
  'under_construction_image',
]) : {};
const heading = content['under_construction_heading'] || 'Under Construction';
const subtitle = await mdInline(content['under_construction_subtitle'] || "We're tending to the garden. Check back soon!");
const message = await md(content['under_construction_message'] || "Force of Nature Press is currently being updated. We'll be back shortly.");
const image = content['under_construction_image'] || '/beetleshopiconsquare.webp';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Be Right Back — Force of Nature Press</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="page">
    <div class="card">
      {image && <img src={image} alt="Force of Nature Press" class="logo" width="80" height="80" />}
      <h1>{heading}</h1>
      <p class="subtitle" set:html={subtitle} />
      <div class="message" set:html={message} />
    </div>
  </div>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    padding: 0;
    font-family: 'Nunito', sans-serif;
    background: url('/plainstarbanner.webp') center / cover no-repeat fixed;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }

  .page {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .card {
    background: rgba(240, 230, 208, 0.92);
    border: 2px solid #d4b896;
    border-radius: 12px;
    padding: 4rem 5rem;
    text-align: center;
    max-width: 560px;
    width: 100%;
  }

  .logo {
    border-radius: 0;
    margin-bottom: 1.5rem;
  }

  .message a { color: #3d7a6e; }
  .message a:hover { color: #2a5a50; }
  .subtitle a { color: #3d7a6e; }
  .subtitle a:hover { color: #2a5a50; }

  h1 {
    font-size: 2.4rem;
    color: #c87830;
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }

  .subtitle {
    font-size: 1.15rem;
    font-weight: 800;
    color: #6b4a2a;
    margin: 0 0 1rem;
  }

  .message {
    font-size: 1rem;
    color: #8b6240;
    margin: 0;
    line-height: 1.6;
  }
  .message p { margin: 0 0 0.8em; }
  .message p:last-child { margin: 0; }

  @media (max-width: 600px) {
    .card { padding: 2.5rem 1.5rem; }
    h1 { font-size: 1.8rem; }
  }
</style>
