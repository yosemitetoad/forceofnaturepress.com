---
import { INSTAGRAM_URL, PINTEREST_URL } from '../consts';
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <p class="footer-copy">&copy; {year} Riley Briggs / Force of Nature Press. All rights reserved.</p>

    <div class="footer-right">
    <nav class="footer-socials" aria-label="Social links">
      <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer" aria-label="Instagram" title="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162S8.597 18.324 12 18.324s6.162-2.759 6.162-6.162S15.403 5.838 12 5.838zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
      <a href={PINTEREST_URL} target="_blank" rel="noopener noreferrer" aria-label="Pinterest" title="Pinterest">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
        </svg>
      </a>
      <a href="/newsletter" aria-label="Newsletter Sign-up" title="Newsletter Sign-up">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
      </a>
    </nav>

    <span class="footer-divider"></span>
    <nav class="footer-links">
      <a href="/privacy">Privacy Policy</a>
      <span class="footer-sep">&middot;</span>
      <a href="/terms">Terms of Service</a>
    </nav>
    </div>
  </div>
</footer>

<style is:global>
  footer {
    background: var(--brown);
    margin-top: 4rem;
    border-top: 1px solid rgba(228, 211, 184, 0.2);
    padding: 0.8rem 1.5rem;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }
  .footer-copy {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(228, 211, 184, 0.6);
  }
  .footer-right {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }
  .footer-divider {
    display: block;
    width: 1px;
    height: 1.2em;
    background: rgba(228, 211, 184, 0.3);
  }
  .footer-socials {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .footer-socials a {
    color: rgba(228, 211, 184, 0.6);
    display: flex;
    align-items: center;
    transition: color 0.15s, opacity 0.15s;
    opacity: 0.6;
  }
  .footer-socials a:hover {
    opacity: 1;
  }
  .social-img {
    width: 20px;
    height: 20px;
    object-fit: contain;
    display: block;
  }
  .footer-links {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  .footer-links a {
    font-size: 0.8rem;
    color: rgba(228, 211, 184, 0.6);
    text-decoration: none;
  }
  .footer-links a:hover {
    color: rgba(228, 211, 184, 0.9);
  }
  .footer-sep {
    color: rgba(228, 211, 184, 0.6);
    font-size: 1.2rem;
  }
  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      gap: 0.6rem;
      text-align: center;
    }
    .footer-right {
      flex-direction: column;
      gap: 0.5rem;
    }
    .footer-divider { display: none; }
  }
</style>
