---
import { ETSY_SHOP_URL, INSTAGRAM_URL, EMAIL } from '../consts';
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/beetleshopiconsquare.png" alt="Force of Nature Press" class="footer-logo" />
      <div>
        <p class="footer-name">Force of Nature Press</p>
        <p class="footer-tagline">Handmade in the Pacific Northwest</p>
      </div>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/shop">Shop</a>
      <a href="/portfolio">Portfolio</a>
      <a href="/blog">Blog</a>
      <a href="/games">Games</a>
      <a href="/about">About</a>
    </nav>

    <div class="footer-links">
      <a href={ETSY_SHOP_URL} target="_blank" rel="noopener noreferrer">
        <!-- cart icon -->
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        Etsy Shop
      </a>
      <a href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer">
        <!-- instagram icon -->
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        @forceofnature.press
      </a>
      <a href={`mailto:${EMAIL}`}>
        <!-- mail icon -->
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        {EMAIL}
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {year} Riley Briggs / Force of Nature Press. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    background: var(--brown);
    color: var(--cream-dark);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .footer-logo {
    width: 52px;
    height: 52px;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .footer-name {
    font-weight: 800;
    font-size: 1rem;
    color: var(--cream-light);
    margin: 0;
    line-height: 1.3;
  }
  .footer-tagline {
    font-size: 0.8rem;
    color: var(--cream-dark);
    margin: 0.2em 0 0 0;
    font-style: italic;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: center;
  }
  .footer-nav a {
    color: var(--cream-dark);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--orange); }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-end;
  }
  .footer-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--cream-dark);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s;
  }
  .footer-links a:hover { color: var(--orange); }

  .footer-bottom {
    border-top: 1px solid rgba(228, 211, 184, 0.2);
    text-align: center;
    padding: 1rem 1.5rem;
  }
  .footer-bottom p {
    margin: 0;
    font-size: 0.8rem;
    color: rgba(228, 211, 184, 0.6);
  }

  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-brand { justify-content: center; }
    .footer-nav { flex-direction: row; flex-wrap: wrap; justify-content: center; gap: 0.6rem 1.2rem; }
    .footer-links { align-items: center; }
  }
</style>
