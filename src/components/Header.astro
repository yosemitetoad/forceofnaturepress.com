---
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? currentPath === '/' : currentPath.startsWith(path);
---

<header>
  <div class="header-inner">
    <nav class="nav-left" aria-label="Main navigation left">
      <a href="/shop" class:list={['nav-link', { active: isActive('/shop') }]}>Shop</a>
      <a href="/portfolio" class:list={['nav-link', { active: isActive('/portfolio') }]}>Art</a>
      <a href="/games" class:list={['nav-link', { active: isActive('/games') }]}>Games</a>
    </nav>

    <a href="/" class="logo-link" aria-label="Force of Nature Press home">
      <img src="/beetleshopsticker.png" alt={SITE_TITLE} class="logo-img" />
    </a>

    <nav class="nav-right" aria-label="Main navigation right">
      <a href="/about" class:list={['nav-link', { active: isActive('/about') }]}>About</a>
      <a href="/blog" class:list={['nav-link', { active: isActive('/blog') }]}>Blog</a>
      <a href="/contact" class:list={['nav-link', { active: isActive('/contact') }]}>Contact</a>
    </nav>

    <button class="mobile-menu-btn" id="menuBtn" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-nav" id="mobileNav" aria-hidden="true">
    <a href="/shop" class:list={['mobile-link', { active: isActive('/shop') }]}>Shop</a>
    <a href="/portfolio" class:list={['mobile-link', { active: isActive('/portfolio') }]}>Art</a>
    <a href="/games" class:list={['mobile-link', { active: isActive('/games') }]}>Games</a>
    <a href="/about" class:list={['mobile-link', { active: isActive('/about') }]}>About</a>
    <a href="/blog" class:list={['mobile-link', { active: isActive('/blog') }]}>Blog</a>
    <a href="/contact" class:list={['mobile-link', { active: isActive('/contact') }]}>Contact</a>
  </nav>
</header>

<script>
  const btn = document.getElementById('menuBtn');
  const nav = document.getElementById('mobileNav');
  btn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
    nav?.setAttribute('aria-hidden', String(!open));
  });
</script>

<style>
  header {
    background: var(--cream-light);
    border-bottom: 2px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 80px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
  }

  .nav-left {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.2rem;
  }

  .nav-right {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.2rem;
  }

  .logo-link {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    transition: transform 0.2s;
  }
  .logo-link:hover .logo-img {
    transform: scale(1.07);
  }

  .nav-link {
    padding: 0.4em 0.8em;
    color: var(--brown);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .nav-link:hover {
    background: var(--cream-dark);
    color: var(--brown);
  }
  .nav-link.active {
    color: var(--orange);
    background: rgba(200, 120, 48, 0.1);
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 6px;
    position: absolute;
    right: 1.5rem;
  }
  .mobile-menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--brown);
    border-radius: 2px;
    transition: 0.2s;
  }
  .mobile-menu-btn:hover { background: var(--cream-dark); }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 0.5rem 1.5rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--cream-light);
  }
  .mobile-nav.open { display: flex; }

  .mobile-link {
    padding: 0.6em 0.5em;
    color: var(--brown);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.05rem;
    border-radius: 6px;
  }
  .mobile-link:hover { background: var(--cream-dark); color: var(--brown); }
  .mobile-link.active { color: var(--orange); }

  @media (max-width: 720px) {
    .nav-left, .nav-right { display: none; }
    .mobile-menu-btn { display: flex; }
    .header-inner {
      grid-template-columns: 1fr auto 1fr;
      position: relative;
    }
  }
</style>
