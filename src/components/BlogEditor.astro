---
interface Props {
  content?: string;
}
const { content = '' } = Astro.props;
---

<div class="editor-wrap">
  <div class="editor-toolbar" id="editorToolbar">
    <!-- Undo / Redo -->
    <button type="button" data-cmd="undo" title="Undo">&#8630;</button>
    <button type="button" data-cmd="redo" title="Redo">&#8631;</button>
    <span class="toolbar-sep"></span>

    <!-- Font family -->
    <div class="font-picker-wrap">
      <button type="button" id="fontPickerBtn" class="font-picker-btn" title="Font">
        <span id="fontPickerLabel">Font</span>
        <span class="font-arrow">&#9662;</span>
      </button>
      <div id="fontPickerDropdown" class="font-picker-dropdown" style="display:none">
        <div class="font-search-row">
          <input type="text" id="fontSearchInput" placeholder="Search fonts..." class="font-search" />
        </div>
        <div id="fontList" class="font-list"></div>
        <div class="font-add-row">
          <button type="button" id="addFontBtn" class="font-add-btn">+ Google Fonts</button>
          <button type="button" id="addAdobeFontBtn" class="font-add-btn adobe">+ Adobe Fonts</button>
        </div>
      </div>
    </div>

    <!-- Font size (numeric input) -->
    <div class="size-input-wrap">
      <button type="button" id="sizeDown" class="size-step" title="Decrease size">&#8722;</button>
      <input type="text" id="sizeInput" class="size-input" value="16" title="Font size in px" />
      <button type="button" id="sizeUp" class="size-step" title="Increase size">+</button>
    </div>
    <span class="toolbar-sep"></span>

    <!-- Basic formatting -->
    <button type="button" data-cmd="bold" title="Bold"><b>B</b></button>
    <button type="button" data-cmd="italic" title="Italic"><i>I</i></button>
    <button type="button" data-cmd="underline" title="Underline"><u>U</u></button>
    <button type="button" data-cmd="strikeThrough" title="Strikethrough"><s>S</s></button>
    <span class="toolbar-sep"></span>

    <!-- Text color -->
    <label class="color-wrap" title="Text Color">
      <span class="color-label" id="colorLabel">A</span>
      <span class="color-bar" id="colorBar"></span>
      <input type="color" id="textColor" value="#2d1f0e" />
    </label>
    <!-- Highlight -->
    <label class="color-wrap" title="Highlight">
      <span class="highlight-label" id="highlightLabel" style="background:#ffeb3b">A</span>
      <input type="color" id="highlightColor" value="#ffeb3b" />
    </label>
    <span class="toolbar-sep"></span>

    <!-- Headings / Paragraph -->
    <button type="button" data-cmd="formatBlock" data-val="h2" title="Heading">H2</button>
    <button type="button" data-cmd="formatBlock" data-val="h3" title="Subheading">H3</button>
    <button type="button" data-cmd="formatBlock" data-val="p" title="Paragraph">P</button>
    <span class="toolbar-sep"></span>

    <!-- Alignment -->
    <button type="button" data-cmd="justifyLeft" title="Align Left">&#8676;</button>
    <button type="button" data-cmd="justifyCenter" title="Center">&#8596;</button>
    <button type="button" data-cmd="justifyRight" title="Align Right">&#8677;</button>
    <span class="toolbar-sep"></span>

    <!-- Lists -->
    <button type="button" data-cmd="insertUnorderedList" title="Bullet List">&#8226; List</button>
    <button type="button" data-cmd="insertOrderedList" title="Numbered List">1. List</button>
    <span class="toolbar-sep"></span>

    <!-- Link -->
    <button type="button" id="linkBtn" title="Insert Link">Link</button>
    <!-- Image -->
    <span class="img-menu-wrap">
      <button type="button" id="imgBtn" title="Insert Image">Image</button>
      <div id="imgMenu" class="img-menu" style="display:none">
        <button type="button" id="imgUploadChoice">Upload from computer</button>
        <button type="button" id="imgUrlChoice">Paste a URL</button>
      </div>
    </span>
    <span class="toolbar-sep"></span>

    <!-- Quote / Clear -->
    <button type="button" data-cmd="formatBlock" data-val="blockquote" title="Quote">Quote</button>
    <button type="button" data-cmd="removeFormat" title="Clear Formatting">Clear</button>
  </div>
  <div id="editor" class="editor" contenteditable="true" set:html={content}></div>
</div>

<!-- Google Fonts browser modal -->
<div id="fontBrowserOverlay" class="font-browser-overlay" style="display:none">
  <div class="font-browser">
    <div class="font-browser-header">
      <h3>Browse Google Fonts</h3>
      <button type="button" id="fontBrowserClose" class="font-browser-close">&times;</button>
    </div>
    <input type="text" id="fontBrowserSearch" placeholder="Search Google Fonts..." class="font-browser-search" />
    <div id="fontBrowserList" class="font-browser-list"></div>
  </div>
</div>

<!-- Adobe Fonts modal -->
<div id="adobeFontOverlay" class="font-browser-overlay" style="display:none">
  <div class="font-browser">
    <div class="font-browser-header">
      <h3>Adobe Fonts</h3>
      <button type="button" id="adobeFontClose" class="font-browser-close">&times;</button>
    </div>
    <div class="adobe-setup">
      <div class="adobe-step">
        <div class="adobe-step-num">1</div>
        <div class="adobe-step-text">
          <p>Go to <strong>fonts.adobe.com</strong>, find the fonts you want, and add them to a <strong>Web Project</strong>.</p>
        </div>
      </div>
      <div class="adobe-step">
        <div class="adobe-step-num">2</div>
        <div class="adobe-step-text">
          <p>Paste your Typekit <strong>Project ID</strong> below (it looks like <code>abc1def</code>).</p>
          <div class="adobe-id-row">
            <input type="text" id="adobeProjectId" placeholder="e.g. abc1def" class="adobe-id-input" />
            <button type="button" id="adobeProjectSave" class="adobe-id-save">Save</button>
          </div>
          <div id="adobeProjectStatus" class="adobe-status"></div>
        </div>
      </div>
      <div class="adobe-step">
        <div class="adobe-step-num">3</div>
        <div class="adobe-step-text">
          <p>Type the <strong>font name</strong> exactly as shown in your Adobe web project and click Add.</p>
          <div class="adobe-id-row">
            <input type="text" id="adobeFontName" placeholder='e.g. Futura PT' class="adobe-id-input" />
            <button type="button" id="adobeFontAdd" class="adobe-id-save">Add</button>
          </div>
          <div id="adobeFontStatus" class="adobe-status"></div>
        </div>
      </div>
      <div id="adobeFontsList" class="adobe-fonts-list"></div>
    </div>
  </div>
</div>

<style>
  .editor-wrap { margin: 0; }

  .editor-toolbar {
    display: flex; flex-wrap: wrap; gap: 0.25rem; padding: 0.4rem;
    background: #2d1f0e; border-radius: 8px 8px 0 0; border: 2px solid #2d1f0e;
    align-items: center;
  }
  .editor-toolbar button {
    background: transparent; border: none; color: #e4d3b8; padding: 0.3em 0.6em;
    border-radius: 4px; font-family: inherit; font-size: 0.8rem; font-weight: 700; cursor: pointer;
  }
  .editor-toolbar button:hover { background: #6b4a2a; color: #faf5ea; }
  .toolbar-sep { width: 1px; background: #6b4a2a; margin: 0 0.15rem; align-self: stretch; }

  /* Font picker */
  .font-picker-wrap { position: relative; }
  .font-picker-btn {
    display: flex; align-items: center; gap: 0.3em;
    background: #6b4a2a !important; border: none; border-radius: 4px;
    padding: 0.25em 0.5em; color: #e4d3b8; font-size: 0.78rem; font-weight: 700;
    cursor: pointer; max-width: 150px; min-width: 80px;
  }
  .font-picker-btn:hover { background: #8b6a3a !important; }
  .font-arrow { font-size: 0.6rem; margin-left: auto; }
  #fontPickerLabel { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .font-picker-dropdown {
    position: absolute; top: 100%; left: 0; z-index: 20; margin-top: 0.3rem;
    background: #2d1f0e; border: 2px solid #6b4a2a; border-radius: 8px;
    width: 260px; max-height: 360px; display: flex; flex-direction: column;
    overflow: hidden;
  }
  .font-search-row { padding: 0.5rem; }
  .font-search {
    width: 100%; padding: 0.4em 0.6em; border: 1px solid #6b4a2a; border-radius: 4px;
    background: #4a3420; color: #faf5ea; font-family: inherit; font-size: 0.8rem;
    outline: none;
  }
  .font-search:focus { border-color: #c87830; }
  .font-list {
    flex: 1; overflow-y: auto; padding: 0 0.3rem 0.3rem;
    max-height: 240px;
  }
  .font-list-item {
    display: block; width: 100%; text-align: left; padding: 0.45em 0.6em;
    background: transparent; border: none; color: #e4d3b8; border-radius: 4px;
    font-size: 0.88rem; cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .font-list-item:hover { background: #6b4a2a; color: #faf5ea; }
  .font-add-row { padding: 0.4rem 0.5rem; border-top: 1px solid #6b4a2a; display: flex; gap: 0.3rem; }
  .font-add-btn {
    flex: 1; text-align: center; padding: 0.5em;
    background: #c87830 !important; color: #faf5ea !important; border: none; border-radius: 4px;
    font-family: inherit; font-size: 0.75rem; font-weight: 800; cursor: pointer;
  }
  .font-add-btn:hover { background: #a05e18 !important; }
  .font-add-btn.adobe { background: #eb1000 !important; }
  .font-add-btn.adobe:hover { background: #c00d00 !important; }

  /* Size input */
  .size-input-wrap {
    display: flex; align-items: center; gap: 0;
    background: #6b4a2a; border-radius: 4px; overflow: hidden;
  }
  .size-step {
    background: transparent !important; border: none; color: #e4d3b8; padding: 0.25em 0.4em;
    font-size: 0.8rem; font-weight: 800; cursor: pointer; line-height: 1;
  }
  .size-step:hover { background: #8b6a3a !important; }
  .size-input {
    width: 36px; text-align: center; border: none; background: transparent;
    color: #faf5ea; font-family: inherit; font-size: 0.78rem; font-weight: 700;
    padding: 0.25em 0; outline: none;
  }

  /* Text color - visible on dark toolbar */
  .color-wrap {
    display: flex; flex-direction: column; align-items: center; cursor: pointer; position: relative;
    padding: 0.2em 0.4em; border-radius: 4px; gap: 1px;
  }
  .color-wrap:hover { background: #6b4a2a; }
  .color-wrap input[type="color"] {
    position: absolute; opacity: 0; width: 100%; height: 100%;
    top: 0; left: 0; cursor: pointer; border: none; padding: 0;
  }
  .color-label {
    font-weight: 800; font-size: 0.85rem; pointer-events: none;
    color: #e4d3b8;
  }
  .color-bar {
    width: 14px; height: 3px; pointer-events: none;
    background: #e4d3b8; border-radius: 1px;
  }
  .highlight-label {
    font-weight: 800; font-size: 0.85rem; pointer-events: none;
    padding: 0 0.15em; border-radius: 2px; color: #2d1f0e;
  }

  .img-menu-wrap { position: relative; }
  .img-menu {
    position: absolute; top: 100%; left: 0; z-index: 10; margin-top: 0.3rem;
    background: #2d1f0e; border: 2px solid #6b4a2a; border-radius: 6px;
    overflow: hidden; min-width: 180px;
  }
  .img-menu button {
    display: block; width: 100%; text-align: left; padding: 0.5em 0.8em;
    background: transparent; border: none; color: #e4d3b8;
    font-family: inherit; font-size: 0.8rem; font-weight: 700; cursor: pointer;
  }
  .img-menu button:hover { background: #6b4a2a; color: #faf5ea; }

  .editor {
    min-height: 350px; padding: 1rem; background: #faf5ea; border: 2px solid #d4b896;
    border-top: none; border-radius: 0 0 8px 8px; font-size: 0.95rem; line-height: 1.7;
    outline: none;
  }
  .editor:focus { border-color: #c87830; }
  .editor :global(h2) { font-size: 1.4rem; font-weight: 800; margin: 0.8em 0 0.3em; }
  .editor :global(h3) { font-size: 1.15rem; font-weight: 800; margin: 0.6em 0 0.3em; }
  .editor :global(p) { margin: 0 0 0.6em; }
  .editor :global(blockquote) {
    border-left: 4px solid #c87830; margin: 0.6em 0; padding: 0.4em 1em;
    background: rgba(200, 120, 48, 0.06); color: #6b4a2a; font-style: italic;
  }
  .editor :global(a) { color: #3d7a6e; }
  .editor :global(img) { max-width: 100%; border-radius: 6px; margin: 0.5em 0; }
  .editor :global(ul), .editor :global(ol) { margin: 0.3em 0; padding-left: 1.5em; }

  /* Google Fonts browser modal */
  .font-browser-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.5); z-index: 1000;
    display: flex; align-items: center; justify-content: center;
  }
  .font-browser {
    background: #faf5ea; border-radius: 12px; width: 520px; max-width: 90vw;
    max-height: 80vh; display: flex; flex-direction: column;
    box-shadow: 0 8px 32px rgba(0,0,0,0.3); overflow: hidden;
  }
  .font-browser-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.2rem; border-bottom: 2px solid #d4b896;
  }
  .font-browser-header h3 { margin: 0; font-size: 1.1rem; font-weight: 800; color: #2d1f0e; }
  .font-browser-close {
    background: none; border: none; font-size: 1.5rem; color: #8b7355;
    cursor: pointer; padding: 0; line-height: 1;
  }
  .font-browser-close:hover { color: #2d1f0e; }
  .font-browser-search {
    margin: 0.8rem 1.2rem; padding: 0.6em 0.8em; border: 2px solid #d4b896;
    border-radius: 8px; font-family: inherit; font-size: 0.9rem; background: #fff;
    outline: none;
  }
  .font-browser-search:focus { border-color: #c87830; }
  .font-browser-list {
    flex: 1; overflow-y: auto; padding: 0 0.8rem 0.8rem;
  }
  .font-browser-item {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.6em 0.8em; border-radius: 6px; cursor: pointer;
    transition: background 0.1s;
  }
  .font-browser-item:hover { background: #e8d5b7; }
  .font-browser-item-name { font-size: 1rem; color: #2d1f0e; }
  .font-browser-item-preview { font-size: 0.85rem; color: #8b7355; }
  .font-browser-item-add {
    background: #5b7b6d; color: #faf5ea; border: none; padding: 0.3em 0.8em;
    border-radius: 6px; font-family: inherit; font-weight: 700; font-size: 0.78rem;
    cursor: pointer; white-space: nowrap;
  }
  .font-browser-item-add:hover { background: #3d5a4e; }
  .font-browser-item-add.added {
    background: #d4b896; color: #6b4a2a; cursor: default;
  }

  /* Adobe Fonts modal */
  .adobe-setup { padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 1rem; overflow-y: auto; }
  .adobe-step { display: flex; gap: 0.8rem; }
  .adobe-step-num {
    width: 28px; height: 28px; flex-shrink: 0;
    background: #5b7b6d; color: #faf5ea; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 0.85rem; margin-top: 0.1rem;
  }
  .adobe-step-text { flex: 1; }
  .adobe-step-text p { margin: 0 0 0.5rem; font-size: 0.88rem; line-height: 1.5; color: #2d1f0e; }
  .adobe-step-text code {
    background: #e8d5b7; padding: 0.1em 0.4em; border-radius: 4px;
    font-size: 0.85em; color: #6b4a2a;
  }
  .adobe-id-row { display: flex; gap: 0.4rem; }
  .adobe-id-input {
    flex: 1; padding: 0.5em 0.7em; border: 2px solid #d4b896; border-radius: 6px;
    font-family: inherit; font-size: 0.88rem; background: #fff; outline: none;
  }
  .adobe-id-input:focus { border-color: #c87830; }
  .adobe-id-save {
    background: #5b7b6d; color: #faf5ea; border: none; padding: 0.5em 1em;
    border-radius: 6px; font-family: inherit; font-weight: 800; font-size: 0.85rem;
    cursor: pointer; white-space: nowrap;
  }
  .adobe-id-save:hover { background: #3d5a4e; }
  .adobe-status { font-size: 0.82rem; margin-top: 0.4rem; font-weight: 700; }
  .adobe-status.ok { color: #5b7b6d; }
  .adobe-status.err { color: #b44; }
  .adobe-fonts-list { display: flex; flex-wrap: wrap; gap: 0.4rem; padding-top: 0.5rem; }
  .adobe-font-tag {
    display: flex; align-items: center; gap: 0.3rem;
    background: #e8d5b7; border-radius: 16px; padding: 0.3em 0.5em 0.3em 0.8em;
    font-size: 0.82rem; font-weight: 700; color: #2d1f0e;
  }
  .adobe-font-remove {
    background: none; border: none; color: #8b7355; cursor: pointer;
    font-size: 1rem; line-height: 1; padding: 0 0.2em;
  }
  .adobe-font-remove:hover { color: #b44; }
</style>

<script>
  // ── Upload helper ──
  async function uploadFile(file: File): Promise<string> {
    const form = new FormData();
    form.append('file', file);
    const res = await fetch('/api/admin/upload', { method: 'POST', body: form });
    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.error || 'Upload failed');
    }
    const { url } = await res.json();
    return url;
  }

  const editor = document.getElementById('editor')!;

  // ── Prevent toolbar from stealing editor focus/selection ──
  const toolbar = document.getElementById('editorToolbar')!;
  toolbar.addEventListener('mousedown', (e) => {
    // Allow focus only on actual text inputs (search, size input)
    const tag = (e.target as HTMLElement).tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA') return;
    e.preventDefault();
  });

  // ── Save/restore selection for dropdowns that need it ──
  let savedRange: Range | null = null;
  function saveSelection() {
    const sel = window.getSelection();
    if (sel && sel.rangeCount > 0) {
      savedRange = sel.getRangeAt(0).cloneRange();
    }
  }
  function restoreSelection() {
    if (savedRange) {
      const sel = window.getSelection();
      sel?.removeAllRanges();
      sel?.addRange(savedRange);
    }
  }

  // ── Simple command buttons ──
  document.querySelectorAll('#editorToolbar button[data-cmd]').forEach(btn => {
    btn.addEventListener('click', () => {
      const cmd = (btn as HTMLElement).dataset.cmd!;
      const val = (btn as HTMLElement).dataset.val || '';
      document.execCommand(cmd, false, val);
      editor.focus();
    });
  });

  // ── Font system ──
  const DEFAULT_FONTS = [
    'Nunito', 'Lora', 'Merriweather', 'Open Sans',
    'Playfair Display', 'Roboto', 'Source Serif 4', 'PT Serif'
  ];

  // Load saved custom fonts from localStorage
  function getSavedFonts(): string[] {
    try {
      return JSON.parse(localStorage.getItem('blogEditorFonts') || '[]');
    } catch { return []; }
  }
  function saveFonts(fonts: string[]) {
    localStorage.setItem('blogEditorFonts', JSON.stringify(fonts));
  }

  let customFonts = getSavedFonts();
  let allFonts = [...DEFAULT_FONTS, ...customFonts];
  const loadedFontUrls = new Set<string>();

  // Load a Google Font dynamically
  function loadGoogleFont(fontName: string) {
    const family = fontName.replace(/ /g, '+');
    const url = `https://fonts.googleapis.com/css2?family=${family}:ital,wght@0,400;0,700;1,400&display=swap`;
    if (loadedFontUrls.has(url)) return;
    loadedFontUrls.add(url);
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = url;
    document.head.appendChild(link);
  }

  // Load all current fonts
  allFonts.forEach(f => loadGoogleFont(f));

  // Font picker dropdown
  const fontPickerBtn = document.getElementById('fontPickerBtn')!;
  const fontPickerLabel = document.getElementById('fontPickerLabel')!;
  const fontPickerDropdown = document.getElementById('fontPickerDropdown')!;
  const fontSearchInput = document.getElementById('fontSearchInput') as HTMLInputElement;
  const fontList = document.getElementById('fontList')!;

  function renderFontList(filter = '') {
    fontList.innerHTML = '';
    const q = filter.toLowerCase();
    const filtered = allFonts.filter(f => !q || f.toLowerCase().includes(q));
    for (const font of filtered) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'font-list-item';
      btn.textContent = font;
      btn.style.fontFamily = `'${font}', sans-serif`;
      btn.addEventListener('mousedown', (e) => e.preventDefault());
      btn.addEventListener('click', () => {
        restoreSelection();
        document.execCommand('fontName', false, font);
        fontPickerLabel.textContent = font;
        fontPickerLabel.style.fontFamily = `'${font}', sans-serif`;
        fontPickerDropdown.style.display = 'none';
      });
      fontList.appendChild(btn);
    }
    if (filtered.length === 0) {
      const empty = document.createElement('div');
      empty.style.cssText = 'padding:0.6em;color:#8b7355;font-size:0.8rem;text-align:center;';
      empty.textContent = 'No matching fonts';
      fontList.appendChild(empty);
    }
  }
  renderFontList();

  fontPickerBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = fontPickerDropdown.style.display !== 'none';
    if (!isOpen) saveSelection();
    fontPickerDropdown.style.display = isOpen ? 'none' : 'flex';
    if (!isOpen) {
      fontSearchInput.value = '';
      renderFontList();
      // Focus search without losing editor selection (mousedown preventDefault handles this)
      fontSearchInput.focus();
    }
  });

  fontSearchInput.addEventListener('input', () => {
    renderFontList(fontSearchInput.value);
  });
  fontSearchInput.addEventListener('click', (e) => e.stopPropagation());
  fontPickerDropdown.addEventListener('click', (e) => e.stopPropagation());

  function addCustomFont(fontName: string) {
    if (allFonts.includes(fontName)) return;
    customFonts.push(fontName);
    allFonts.push(fontName);
    saveFonts(customFonts);
    loadGoogleFont(fontName);
    renderFontList(fontSearchInput.value);
  }

  // ── Google Fonts browser ──
  const overlay = document.getElementById('fontBrowserOverlay')!;
  const browserSearch = document.getElementById('fontBrowserSearch') as HTMLInputElement;
  const browserList = document.getElementById('fontBrowserList')!;
  let googleFontsCache: string[] = [];

  // Popular Google Fonts (sorted by popularity)
  googleFontsCache = [
    'Roboto','Open Sans','Noto Sans','Montserrat','Lato','Poppins','Roboto Condensed',
    'Inter','Oswald','Roboto Mono','Raleway','Nunito','Ubuntu','Roboto Slab','Nunito Sans',
    'Playfair Display','Merriweather','PT Sans','Rubik','Lora','Noto Sans JP','Mukta',
    'Work Sans','Fira Sans','Barlow','Quicksand','Mulish','Noto Serif','Titillium Web',
