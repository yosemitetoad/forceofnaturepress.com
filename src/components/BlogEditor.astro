  ];

  document.getElementById('addFontBtn')!.addEventListener('click', (e) => {
    e.stopPropagation();
    fontPickerDropdown.style.display = 'none';
    overlay.style.display = 'flex';
    browserSearch.value = '';
    browserSearch.focus();
    renderBrowserList('');
  });

  document.getElementById('fontBrowserClose')!.addEventListener('click', () => {
    overlay.style.display = 'none';
  });
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.style.display = 'none';
  });

  browserSearch.addEventListener('input', () => {
    renderBrowserList(browserSearch.value);
  });

  function renderBrowserList(filter: string) {
    browserList.innerHTML = '';
    const q = filter.toLowerCase();
    const filtered = googleFontsCache.filter(f => !q || f.toLowerCase().includes(q)).slice(0, 80);

    for (const fontName of filtered) {
      const row = document.createElement('div');
      row.className = 'font-browser-item';

      const nameSpan = document.createElement('span');
      nameSpan.className = 'font-browser-item-name';
      nameSpan.textContent = fontName;

      // Lazy-load font for preview on hover
      let fontLoaded = false;
      row.addEventListener('mouseenter', () => {
        if (!fontLoaded) {
          loadGoogleFont(fontName);
          fontLoaded = true;
        }
        nameSpan.style.fontFamily = `'${fontName}', sans-serif`;
      });

      const addBtn = document.createElement('button');
      addBtn.type = 'button';
      const isAdded = allFonts.includes(fontName);
      addBtn.className = 'font-browser-item-add' + (isAdded ? ' added' : '');
      addBtn.textContent = isAdded ? 'Added' : 'Add';

      if (!isAdded) {
        addBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          addCustomFont(fontName);
          addBtn.textContent = 'Added';
          addBtn.classList.add('added');
        });
      }

      row.appendChild(nameSpan);
      row.appendChild(addBtn);
      browserList.appendChild(row);
    }

    if (filtered.length === 0) {
      const empty = document.createElement('div');
      empty.style.cssText = 'padding:1rem;text-align:center;color:#8b7355;';
      empty.textContent = 'No fonts found';
      browserList.appendChild(empty);
    }
  }

  // ── Adobe Fonts ──
  const adobeOverlay = document.getElementById('adobeFontOverlay')!;
  const adobeProjectInput = document.getElementById('adobeProjectId') as HTMLInputElement;
  const adobeProjectStatus = document.getElementById('adobeProjectStatus')!;
  const adobeFontNameInput = document.getElementById('adobeFontName') as HTMLInputElement;
  const adobeFontStatus = document.getElementById('adobeFontStatus')!;
  const adobeFontsList = document.getElementById('adobeFontsList')!;

  // Load saved Adobe project ID and fonts
  function getAdobeProjectId(): string { return localStorage.getItem('adobeProjectId') || ''; }
  function getAdobeFonts(): string[] {
    try { return JSON.parse(localStorage.getItem('adobeFonts') || '[]'); } catch { return []; }
  }
  function saveAdobeFonts(fonts: string[]) { localStorage.setItem('adobeFonts', JSON.stringify(fonts)); }

  let adobeFonts = getAdobeFonts();
  let currentAdobeProjectId = getAdobeProjectId();

  // Load the Typekit CSS if we have a project ID
  function loadTypekitCSS(projectId: string) {
    if (!projectId) return;
    const existingLink = document.querySelector(`link[href*="use.typekit.net/${projectId}"]`);
    if (existingLink) return;
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = `https://use.typekit.net/${projectId}.css`;
    document.head.appendChild(link);
  }

  if (currentAdobeProjectId) {
    loadTypekitCSS(currentAdobeProjectId);
  }

  // Add saved Adobe fonts to the font list
  adobeFonts.forEach(f => {
    if (!allFonts.includes(f)) {
      allFonts.push(f);
    }
  });
  renderFontList();

  function renderAdobeFontTags() {
    adobeFontsList.innerHTML = '';
    for (const font of adobeFonts) {
      const tag = document.createElement('span');
      tag.className = 'adobe-font-tag';
      tag.innerHTML = `<span style="font-family:'${font}',sans-serif">${font}</span>`;
      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'adobe-font-remove';
      removeBtn.innerHTML = '&times;';
      removeBtn.addEventListener('click', () => {
        adobeFonts = adobeFonts.filter(f => f !== font);
        allFonts = allFonts.filter(f => f !== font);
        saveAdobeFonts(adobeFonts);
        renderAdobeFontTags();
        renderFontList();
      });
      tag.appendChild(removeBtn);
      adobeFontsList.appendChild(tag);
    }
  }

  document.getElementById('addAdobeFontBtn')!.addEventListener('click', (e) => {
    e.stopPropagation();
    fontPickerDropdown.style.display = 'none';
    adobeOverlay.style.display = 'flex';
    adobeProjectInput.value = currentAdobeProjectId;
    adobeProjectStatus.textContent = currentAdobeProjectId ? 'Project loaded.' : '';
    adobeProjectStatus.className = currentAdobeProjectId ? 'adobe-status ok' : 'adobe-status';
    adobeFontStatus.textContent = '';
    renderAdobeFontTags();
  });

  document.getElementById('adobeFontClose')!.addEventListener('click', () => {
    adobeOverlay.style.display = 'none';
  });
  adobeOverlay.addEventListener('click', (e) => {
    if (e.target === adobeOverlay) adobeOverlay.style.display = 'none';
  });

  document.getElementById('adobeProjectSave')!.addEventListener('click', () => {
    const id = adobeProjectInput.value.trim();
    if (!id) {
      adobeProjectStatus.textContent = 'Please enter a project ID.';
      adobeProjectStatus.className = 'adobe-status err';
      return;
    }
    currentAdobeProjectId = id;
    localStorage.setItem('adobeProjectId', id);
    loadTypekitCSS(id);
    adobeProjectStatus.textContent = 'Project saved and loaded!';
    adobeProjectStatus.className = 'adobe-status ok';
  });

  document.getElementById('adobeFontAdd')!.addEventListener('click', () => {
    const name = adobeFontNameInput.value.trim();
    if (!name) {
      adobeFontStatus.textContent = 'Please enter a font name.';
      adobeFontStatus.className = 'adobe-status err';
      return;
    }
    if (!currentAdobeProjectId) {
      adobeFontStatus.textContent = 'Save your project ID first (step 2).';
      adobeFontStatus.className = 'adobe-status err';
      return;
    }
    if (adobeFonts.includes(name)) {
      adobeFontStatus.textContent = `${name} is already added.`;
      adobeFontStatus.className = 'adobe-status err';
      return;
    }
    adobeFonts.push(name);
    saveAdobeFonts(adobeFonts);
    if (!allFonts.includes(name)) {
      allFonts.push(name);
    }
    renderFontList();
    renderAdobeFontTags();
    adobeFontNameInput.value = '';
    adobeFontStatus.textContent = `${name} added!`;
    adobeFontStatus.className = 'adobe-status ok';
  });

  adobeFontNameInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      (document.getElementById('adobeFontAdd') as HTMLElement).click();
    }
  });

  // ── Font size (numeric, px-based) ──
  const sizeInput = document.getElementById('sizeInput') as HTMLInputElement;

  function applyFontSize(px: number) {
    px = Math.max(8, Math.min(144, px));
    sizeInput.value = String(px);
    restoreSelection();
    // Use fontSize 7 as a marker, then replace the generated <font> tag with a span
    document.execCommand('fontSize', false, '7');
    const fontEls = editor.querySelectorAll('font[size="7"]');
    const newSpans: HTMLElement[] = [];
    fontEls.forEach(el => {
      const span = document.createElement('span');
      span.style.fontSize = px + 'px';
      span.innerHTML = el.innerHTML;
      el.replaceWith(span);
      newSpans.push(span);
    });
    // Re-select the replaced content so subsequent changes still work
    if (newSpans.length > 0) {
      const sel = window.getSelection();
      if (sel) {
        sel.removeAllRanges();
        const range = document.createRange();
        range.setStartBefore(newSpans[0]);
        range.setEndAfter(newSpans[newSpans.length - 1]);
        sel.addRange(range);
        savedRange = range.cloneRange();
      }
    }
  }

  // When the size input is focused via click, save the editor selection first
  sizeInput.addEventListener('mousedown', () => { saveSelection(); });
  sizeInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      const val = parseInt(sizeInput.value, 10);
      if (!isNaN(val)) applyFontSize(val);
    }
    if (e.key === 'ArrowUp') { e.preventDefault(); applyFontSize((parseInt(sizeInput.value,10)||16)+1); }
    if (e.key === 'ArrowDown') { e.preventDefault(); applyFontSize((parseInt(sizeInput.value,10)||16)-1); }
  });
  sizeInput.addEventListener('blur', () => {
    // Don't auto-apply on blur -- user may just be clicking elsewhere
  });
  document.getElementById('sizeDown')!.addEventListener('click', () => {
    applyFontSize((parseInt(sizeInput.value,10)||16) - 2);
  });
  document.getElementById('sizeUp')!.addEventListener('click', () => {
    applyFontSize((parseInt(sizeInput.value,10)||16) + 2);
  });

  // Update size input when cursor moves
  editor.addEventListener('keyup', updateSizeFromSelection);
  editor.addEventListener('mouseup', updateSizeFromSelection);
  function updateSizeFromSelection() {
    const sel = window.getSelection();
    if (!sel || sel.rangeCount === 0) return;
    let node = sel.anchorNode;
    if (node?.nodeType === 3) node = node.parentElement;
    if (node && editor.contains(node)) {
      const computed = window.getComputedStyle(node as Element);
      const px = Math.round(parseFloat(computed.fontSize));
      if (px) sizeInput.value = String(px);
    }
  }

  // ── Text color ──
  const textColorInput = document.getElementById('textColor') as HTMLInputElement;
  const colorBar = document.getElementById('colorBar') as HTMLElement;
  colorBar.style.background = textColorInput.value;
  textColorInput.addEventListener('input', () => {
    document.execCommand('foreColor', false, textColorInput.value);
    colorBar.style.background = textColorInput.value;
    editor.focus();
  });

  // ── Highlight color ──
  const highlightInput = document.getElementById('highlightColor') as HTMLInputElement;
  const highlightLabel = document.getElementById('highlightLabel') as HTMLElement;
  highlightInput.addEventListener('input', () => {
    document.execCommand('hiliteColor', false, highlightInput.value);
    highlightLabel.style.background = highlightInput.value;
    editor.focus();
  });

  // ── Link button ──
  document.getElementById('linkBtn')!.addEventListener('click', () => {
    const url = prompt('Enter URL:');
    if (url) {
      document.execCommand('createLink', false, url);
      editor.focus();
    }
  });

  // ── Image button — dropdown menu ──
  const imgMenu = document.getElementById('imgMenu') as HTMLElement;
  document.getElementById('imgBtn')!.addEventListener('click', (e) => {
    e.stopPropagation();
    imgMenu.style.display = imgMenu.style.display === 'none' ? 'block' : 'none';
  });

  document.getElementById('imgUploadChoice')!.addEventListener('click', () => {
    imgMenu.style.display = 'none';
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = 'image/*';
    input.onchange = async () => {
      const file = input.files?.[0];
      if (!file) return;
      try {
        const url = await uploadFile(file);
        document.execCommand('insertImage', false, url);
        editor.focus();
      } catch (err: any) {
        alert(err.message);
      }
    };
    input.click();
  });

  document.getElementById('imgUrlChoice')!.addEventListener('click', () => {
    imgMenu.style.display = 'none';
    const url = prompt('Enter image URL:');
    if (url) {
      document.execCommand('insertImage', false, url);
      editor.focus();
    }
  });

  // ── Close dropdowns on outside click ──
  document.addEventListener('click', () => {
    imgMenu.style.display = 'none';
    fontPickerDropdown.style.display = 'none';
  });
</script>
